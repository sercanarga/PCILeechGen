//
// MSI-X Table - {{ .MSIXConfig.NumVectors }} vectors (offsets computed from Bar0Size for NVMe/large)
// Auto-generated by PCILeechGen
// Device: {{ hex04 .DeviceIDs.VendorID }}:{{ hex04 .DeviceIDs.DeviceID }}
//

`timescale 1ns / 1ps

module pcileech_msix_table #(
    parameter NUM_VECTORS    = {{ .MSIXConfig.NumVectors }},
    parameter TABLE_BIR      = {{ .MSIXConfig.TableBIR }},
    parameter TABLE_OFFSET   = 32'h{{ printf "%08X" .MSIXConfig.TableOffset }},
    parameter PBA_BIR        = {{ .MSIXConfig.PBABIR }},
    parameter PBA_OFFSET     = 32'h{{ printf "%08X" .MSIXConfig.PBAOffset }},
    parameter TABLE_ENTRIES  = NUM_VECTORS * 4
)(
    input               rst,
    input               clk,

    // BAR write interface
    input [31:0]        wr_addr,
    input [31:0]        wr_data,
    input [3:0]         wr_be,
    input               wr_valid,
    input               wr_table_select,
    input               wr_pba_select,

    // BAR read interface
    input [87:0]        rd_req_ctx,
    input [31:0]        rd_req_addr,
    input               rd_req_valid,
    input               rd_table_select,
    input               rd_pba_select,

    output reg [87:0]   rd_rsp_ctx,
    output reg [31:0]   rd_rsp_data,
    output reg          rd_rsp_valid,
    output reg [2:0]    rd_rsp_bir,

    // Indexed vector read for the NVMe responder: admin completions use vector
    // 0, the I/O queue uses its programmed IV.  Registered (1-cycle latency) so
    // it infers the same block RAM as the table; vector_select is stable for
    // many cycles before the responder consumes vector_addr/data/masked.
    input  [15:0]       vector_select,
    output [63:0]       vector_addr,
    output [31:0]       vector_data,
    output              vector_masked,

    // Device-side PBA pending-bit set for a masked vector (spec 6.8.3.4).
    input               pba_set_valid,
    input  [15:0]       pba_set_vector,
    input               pba_clear_valid,
    input  [15:0]       pba_clear_vector,

    output              addr_hit  // request targets MSI-X region
);

    localparam TABLE_END = TABLE_OFFSET + NUM_VECTORS * 16;
    localparam PBA_SIZE  = ((NUM_VECTORS + 63) / 64) * 8;
    localparam PBA_END   = PBA_OFFSET + PBA_SIZE;

    wire [31:0] wr_offset     = wr_addr;
    wire [31:0] rd_req_offset = rd_req_addr;

    wire is_table = rd_table_select && (rd_req_offset >= TABLE_OFFSET) && (rd_req_offset < TABLE_END);
    wire is_pba   = rd_pba_select && (rd_req_offset >= PBA_OFFSET) && (rd_req_offset < PBA_END);
    assign addr_hit = rd_req_valid && (is_table || is_pba);

    wire wr_is_table = wr_table_select && (wr_offset >= TABLE_OFFSET) && (wr_offset < TABLE_END);
    reg [31:0] msix_table_ram [0:TABLE_ENTRIES-1];

    initial begin
        $readmemh("msix_table_init.hex", msix_table_ram);
    end

    // Indexed vector read (see port comment).  Each vector occupies 4 DWORDs
    // (addr_lo, addr_hi, data, ctrl).  Clamp an out-of-range select to vector 0.
    wire [31:0] vsel_base = ((vector_select >= NUM_VECTORS) ? 32'd0
                                                            : {16'd0, vector_select}) << 2;
    reg [63:0] vector_addr_r;
    reg [31:0] vector_data_r;
    reg        vector_masked_r;
    always @(posedge clk) begin
        vector_addr_r   <= {msix_table_ram[vsel_base + 32'd1], msix_table_ram[vsel_base]};
        vector_data_r   <= msix_table_ram[vsel_base + 32'd2];
        vector_masked_r <= msix_table_ram[vsel_base + 32'd3][0];
    end
    assign vector_addr   = vector_addr_r;
    assign vector_data   = vector_data_r;
    assign vector_masked = vector_masked_r;

    // PBA - all cleared initially
    reg [31:0] msix_pba [0:((NUM_VECTORS+31)/32)-1];
    wire _unused_wr_pba_select = wr_pba_select;

    integer k;
    initial begin
        for (k = 0; k < (NUM_VECTORS+31)/32; k = k + 1)
            msix_pba[k] = 32'h0;
    end

    // host write logic - table entries only (PBA is host read-only; pending bits are set device-side below)
    always @(posedge clk) begin
        if (!rst && wr_valid && wr_is_table) begin
            if (wr_be[0]) msix_table_ram[(wr_offset - TABLE_OFFSET) >> 2][7:0]   <= wr_data[7:0];
            if (wr_be[1]) msix_table_ram[(wr_offset - TABLE_OFFSET) >> 2][15:8]  <= wr_data[15:8];
            if (wr_be[2]) msix_table_ram[(wr_offset - TABLE_OFFSET) >> 2][23:16] <= wr_data[23:16];
            if (wr_be[3]) msix_table_ram[(wr_offset - TABLE_OFFSET) >> 2][31:24] <= wr_data[31:24];
        end
    end

    always @(posedge clk) begin
        if (rst) begin
            for (k = 0; k < (NUM_VECTORS+31)/32; k = k + 1)
                msix_pba[k] <= 32'h0;
        end else begin
            if (pba_clear_valid && (pba_clear_vector < NUM_VECTORS))
                msix_pba[int'(pba_clear_vector[15:5])][pba_clear_vector[4:0]] <= 1'b0;
            if (pba_set_valid && (pba_set_vector < NUM_VECTORS))
                msix_pba[int'(pba_set_vector[15:5])][pba_set_vector[4:0]] <= 1'b1;
        end
    end

    // read logic - 2-cycle pipeline
    reg [87:0] rd_ctx_d1;
    reg        rd_valid_d1;
    reg [31:0] rd_data_d1;
    reg [2:0]  rd_bir_d1;

    always @(posedge clk) begin
        rd_ctx_d1   <= rd_req_ctx;
        rd_valid_d1 <= addr_hit;
        rd_bir_d1     <= is_table ? TABLE_BIR[2:0] : PBA_BIR[2:0];

        if (addr_hit) begin
            if (is_table)
                rd_data_d1 <= msix_table_ram[(rd_req_offset - TABLE_OFFSET) >> 2];
            else if (is_pba)
                rd_data_d1 <= msix_pba[(rd_req_offset - PBA_OFFSET) >> 2];
            else
                rd_data_d1 <= 32'h0;
        end else begin
            rd_data_d1 <= 32'h0;
        end
    end

    always @(posedge clk) begin
        rd_rsp_ctx   <= rd_ctx_d1;
        rd_rsp_valid <= rd_valid_d1;
        rd_rsp_data  <= rd_data_d1;
        rd_rsp_bir   <= rd_bir_d1;
    end

endmodule
