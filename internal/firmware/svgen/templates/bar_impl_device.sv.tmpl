                6'd47: rirb_rom_response = {32'h00000011, 32'h00000000};
                // 48: SET_POWER_STATE(Node 2 — SPDIF DAC D0)
                6'd48: rirb_rom_response = {32'h00000021, 32'h00000000};
                // 49: SET_POWER_STATE(Node 3 — ADC D0)
                6'd49: rirb_rom_response = {32'h00000031, 32'h00000000};
                // 50: GET_PARAMETERS(Node 4 mixer — repeated runtime poll)
                6'd50: rirb_rom_response = {32'h00000041, 32'h00030000};
                // 51: GET_PARAMETERS(Node 5 mixer — repeated runtime poll)
                6'd51: rirb_rom_response = {32'h00000051, 32'h00020000};
                // 52: GET_PIN_WIDGET_CONTROL(Node 9 — output enable query)
                6'd52: rirb_rom_response = {32'h00000091, 32'h00000040};
                // 53: GET_PIN_WIDGET_CONTROL(Node 10 — input enable query)
                6'd53: rirb_rom_response = {32'h000000A1, 32'h00000020};
                // 54: SET_CONVERTER_SAMPLE_RATE(Node 1 — 48kHz)
                6'd54: rirb_rom_response = {32'h00000011, 32'h00000000};
                // 55: SET_CONVERTER_SAMPLE_RATE(Node 2 — SPDIF 48kHz)
                6'd55: rirb_rom_response = {32'h00000021, 32'h00000000};
                // 56: SET_CONVERTER_STREAM_CHAN(Node 1)
                6'd56: rirb_rom_response = {32'h00000011, 32'h00000000};
                // 57: SET_CONVERTER_STREAM_CHAN(Node 2 — SPDIF)
                6'd57: rirb_rom_response = {32'h00000021, 32'h00000000};
                // 58: GET_AMP_GAIN_MUTE(Node 4 mixer, input 2)
                6'd58: rirb_rom_response = {32'h00000041, 32'h00000002};
                // 59: GET_AMP_GAIN_MUTE(Node 6 selector, input 0)
                6'd59: rirb_rom_response = {32'h00000061, 32'h00000000};
                // 60: SET_POWER_STATE(Node 14 — beep widget D3)
                6'd60: rirb_rom_response = {32'h000000F1, 32'h00000003};
                // 61: GET_PARAMETERS(Node 2 — SPDIF repeated poll)
                6'd61: rirb_rom_response = {32'h00000021, 32'h00020002};
                // 62: GET_PARAMETERS(Node 3 — ADC repeated poll)
                6'd62: rirb_rom_response = {32'h00000031, 32'h00020011};
                // 63: GET_SUBSYSTEM_ID — repeated runtime query
                6'd63: rirb_rom_response = {32'h00000001, 32'h11020010};
                // 64+: catch-all — safe "no-op" response (should not be reached
                // with 6-bit index, but defensive default)
                default: rirb_rom_response = {32'h00000001, 32'h00000000};
            endcase
        end
    endfunction

    // MMIO write detection for FSM-driven registers (0x48, 0x58).
    // These are excluded from the generic write case to avoid multi-driver
    // conflicts, so we detect and forward writes here.
    reg wr_0x48_pending, wr_0x58_pending;
    reg [31:0] wr_0x48_data, wr_0x58_data;
    reg [3:0]  wr_0x48_be,   wr_0x58_be;

    always @(posedge clk) begin
        if (rst) begin
            wr_0x48_pending <= 1'b0;
            wr_0x58_pending <= 1'b0;
        end else begin
            wr_0x48_pending <= wr_valid && (wr_addr[31:0] & 32'hFFFFFFFC) == 32'h00000048;
            wr_0x58_pending <= wr_valid && (wr_addr[31:0] & 32'hFFFFFFFC) == 32'h00000058;
            wr_0x48_data    <= wr_data;
            wr_0x58_data    <= wr_data;
            wr_0x48_be      <= wr_be;
            wr_0x58_be      <= wr_be;
        end
    end

    always @(posedge clk) begin
        if (rst) begin
            rirb_response_fsm  <= 8'h00;
            rirb_fake_response <= 64'h0;
            corbwp_prev        <= 8'h00;
            rirb_pending_count <= 8'h00;
            rirb_wp_count      <= 8'h00;
            rirb_response_idx  <= 6'd0;
            corb_cte_prev      <= 1'b0;
            rirb_cte_prev      <= 1'b0;
            dma_req_valid_r    <= 1'b0;
            dma_resp_lo_r      <= 32'h0;
            dma_resp_hi_r      <= 32'h0;
            dma_resp_wp_r      <= 8'h0;
            intfl_set_req      <= 1'b0;
            // FSM-driven register resets (sole driver for these regs)
            reg_0x00000048     <= 32'h00000000;
            reg_0x00000058     <= 32'h00000000;
            reg_0x0000005C     <= 32'h00420000;
            reg_0x00000070     <= 32'h00000000;
            reg_0x00000074     <= 32'h00000000;
        end else begin
            // Default: no INTFL set request this cycle.
            // Response commit path below may set this to 1.
            intfl_set_req <= 1'b0;

            // CRST falling edge guard: if CRST is being asserted, suppress all
            // FSM activity this cycle. The CRST block (separate always block)
            // resets all state vars — we must not fight it with our own
            // assignments. Without this guard, both blocks drive the same regs
            // and the result is synthesis-tool-dependent.

            // Track CTE for reinitialization detection
            if (!crst_falling && !crst_rising) begin
                corb_cte_prev <= corb_cte;
                rirb_cte_prev <= rirb_cte;

                // corbwp_prev is NOT updated here - only when
                // corbwp_changed fires to avoid losing VERB deltas.
            end else if (crst_falling) begin
                corb_cte_prev <= 1'b0;
                rirb_cte_prev <= 1'b0;
                corbwp_prev   <= 8'h00;
            end

            // CRST rising edge: controller coming out of reset
            if (crst_rising) begin
                rirb_response_idx  <= 6'd0;
                rirb_pending_count <= 8'h00;
                rirb_response_fsm  <= 8'h00;
                rirb_wp_count      <= 8'h00;
                corb_cte_prev      <= 1'b0;
                rirb_cte_prev      <= 1'b0;
                corbwp_prev        <= 8'h00;
                dma_req_valid_r    <= 1'b0;
                dma_resp_lo_r      <= 32'h0;
                dma_resp_hi_r      <= 32'h0;
                dma_resp_wp_r      <= 8'h0;
            end

            // CORB/RIRB reinitialization: driver disabled CTE → reset ROM index
            // and pending state so the next discovery cycle starts from index 0.
            // Guarded by !crst_falling — CRST block handles reset.
            //
            // This is critical: hdaudio.sys re-enumeration expects the same
            // discovery-phase responses (indices 0-19) as the first boot.
            // If we don't reset rirb_response_idx, we'll serve runtime-zone
            // responses to discovery VERBs, causing Code 10 on re-plug.
            if (rb_reinit && !crst_falling) begin
                rirb_response_idx  <= 6'd0;
                rirb_pending_count <= 8'h00;
                rirb_response_fsm  <= 8'h00;
                rirb_wp_count      <= 8'h00;
                corbwp_prev        <= 8'h00;
                reg_0x00000048[23:16] <= 8'h00;  // reset CORBRP to 0
                reg_0x0000005C[9:8] <= 2'b0;  // clear RIRBSTS (RINTFL + OIS)
                // NOTE: RIRBLBASE/RIRBUBASE preserved, driver may not reprogram
                // them on re-init if the buffer address hasn't changed.
            end

            // MMIO write forwarding for FSM-driven registers.
            // These registers are excluded from the generic write case
            // to avoid multi-driver conflicts. Host writes are forwarded
            // through delayed detection flags (wr_0x48_pending, etc.).

            // 0x48: CORBWP (bits 7:0 writable), CORBRPRST (bit 31 self-clear)
            // bits 23:16 (CORBRP) handled by FSM above, not host-writable.
            if (wr_0x48_pending && !rb_reinit && !crst_falling) begin
                if (wr_0x48_be[0]) reg_0x00000048[7:0]   <= (reg_0x00000048[7:0]   & ~8'hFF) | (wr_0x48_data[7:0]   & 8'hFF);
                if (wr_0x48_be[3]) reg_0x00000048[31]    <= wr_0x48_data[31];  // CORBRPRST
            end

            // 0x58: RIRBWPRST (bit 15 self-clear), RINTCNT (bits 31:16 writable)
            // bits 7:0 (RIRBWP) driven by FSM, not host-writable.
            if (wr_0x58_pending && !rb_reinit && !crst_falling) begin
                if (wr_0x58_be[1]) reg_0x00000058[15]    <= wr_0x58_data[15];  // RIRBWPRST
                if (wr_0x58_be[2]) reg_0x00000058[23:16] <= wr_0x58_data[23:16];
                if (wr_0x58_be[3]) reg_0x00000058[31:24] <= wr_0x58_data[31:24];
            end

            // RIRBCTL/RIRBSTS driver write - merged into FSM to avoid multi-driver
            if (rirbctl_rw1c && !rb_reinit) begin
                if (wr_be[0]) begin
                    reg_0x0000005C[0] <= rirbctl_wr_rintctl_val;
                    reg_0x0000005C[1] <= rirbctl_wr_cte_val;
                    reg_0x0000005C[2] <= rirbctl_wr_oie_val;
                end
                if (wr_be[1]) begin
                    reg_0x0000005C[10:8] <= reg_0x0000005C[10:8] & ~rirbsts_clear_mask;
                end
            end

            // RIRBWPRST: driver writes 1 to bit 15 of 0x58 to reset RIRBWP
            if (reg_0x00000058[15] && !crst_falling) begin
                rirb_wp_count <= 8'h00;
                reg_0x00000058[15] <= 1'b0;  // auto-clear RIRBWPRST
            end

            // CORBRPRST: driver writes 1 to bit 31 of 0x48 to reset CORBRP
            if (reg_0x00000048[31] && !crst_falling) begin
                reg_0x00000048[23:16] <= 8'h00;  // reset CORBRP to 0
                reg_0x00000048[31] <= 1'b0;  // auto-clear CORBRPRST
            end

            // Enqueue: add the actual number of entries the driver submitted.
            // Guard: if rb_reinit is active, ignore corbwp_changed in the same
            // cycle. Without this, a driver that changes CORBWP while disabling
            // CTE would leave a stale pending count after reinitialization.
            // Guarded by !crst_falling — CRST block handles reset.
            if (corbwp_changed && !rb_reinit && !crst_falling) begin
                // Saturating addition: prevent overflow when DMA is stuck.
                // If pending_count + delta would exceed 255, cap at 255.
                // Without this, overflow wraps to 0 and the FSM stops
                // producing responses, causing hdaudio.sys Code 10.
                if (rirb_pending_count + corbwp_delta < rirb_pending_count) begin
                    rirb_pending_count <= 8'hFF;
                end else begin
                    rirb_pending_count <= rirb_pending_count + corbwp_delta;
                end
                // Auto-advance CORB read pointer (controller consumed CORB entries)
                reg_0x00000048[23:16] <= reg_0x00000048[23:16] + corbwp_delta;
                // Snapshot CORBWP so next delta is calculated correctly
                corbwp_prev <= reg_0x00000048[7:0];
            end

            // All FSM transitions are guarded by !crst_falling to avoid fighting
            // with the CRST block which resets state vars in a separate always block.

            // Build response data when starting a new response
            if (rirb_response_fsm == 8'h00 && rirb_pending_count > 8'h00 && !crst_falling) begin
                // Look up the next response from the CA0132 ROM
                rirb_fake_response <= rirb_rom_response(rirb_response_idx);
                // Cycle: advance up to 63, then wrap to 32 (extended runtime zone).
                // Wrapping to 32 instead of 0 avoids re-sending discovery-phase
                // responses, which would confuse the driver during sustained operation.
                rirb_response_idx  <= (rirb_response_idx < 6'd63) ? rirb_response_idx + 6'h1 : 6'd32;
                rirb_response_fsm  <= 8'h04; // 4-cycle delay before committing
            end

            // Response FSM countdown
            if (rirb_response_fsm > 8'h00 && rirb_response_fsm <= 8'h04 && !crst_falling) begin
                rirb_response_fsm <= rirb_response_fsm - 8'h01;

                // When FSM reaches 1, initiate DMA write handshake with bridge
                if (rirb_response_fsm == 8'h01) begin
                    dma_req_valid_r <= 1'b1;
                    dma_resp_lo_r   <= rirb_fake_response[31:0];
                    // convert ROM custom format to HDA spec RESP_EX:
                    // ROM resp_hi[3:0] = type (1=solicited, 2=unsolicited)
                    // HDA spec RESP_EX: [3:0]=codec_addr, [4]=unsolicited
                    // all responses come from codec 0 (matches STATESTS bit 0)
                    dma_resp_hi_r   <= (rirb_fake_response[35:32] == 4'h2) ?
                                       32'h00000010 :  // codec 0, unsolicited
                                       32'h00000000;   // codec 0, solicited
                    dma_resp_wp_r   <= rirb_wp_count + 8'h01;
                    rirb_response_fsm <= 8'h10; // enter DMA accept wait (outside countdown range)
                end
            end

            // DMA handshake state machine (states 0x10/0x11, outside countdown range):
            //   0x10: wait for bridge to accept request (dma_req_ready)
            //   0x11: wait for bridge to complete write (dma_done)
            if (rirb_response_fsm == 8'h10 && dma_req_valid_r && dma_req_ready && !crst_falling) begin
                // Bridge accepted the request, clear our request
                dma_req_valid_r <= 1'b0;
                rirb_response_fsm <= 8'h11;
            end

            // Bridge recovery: if bridge timed out (returned to IDLE, dma_req_ready=1)
            // but we're still in state 0x11 waiting for dma_done, re-assert the request
            // so the bridge can accept it again with fresh data.
            // This prevents losing the response on every bridge timeout event.
            if (rirb_response_fsm == 8'h11 && dma_req_ready && !dma_req_valid_r && !crst_falling) begin
                // Bridge returned to IDLE — re-assert request for retry
                dma_req_valid_r <= 1'b1;
                rirb_response_fsm <= 8'h10;
                dma_wait_counter  <= 16'h0;
                dma_timed_out     <= 1'b0;
            end

            if (rirb_response_fsm == 8'h11 && !crst_falling) begin
                // Waiting for DMA bridge to complete the write.
                // Use latched done signal to avoid missing the 1-cycle pulse.
                if (dma_done_latched) begin
                    // DMA write completed — now commit to MMIO registers

                    // Increment RIRBWP counter (8-bit, wraps at 256 per RIRBSIZE).
                    // Mask to RIRBSIZE: the size field at 0x5C[31:24] encodes
                    // supported buffer sizes. 0x40 = 256 entries (full 8-bit range).
                    // We mask to prevent WP from exceeding the programmed size.
                    rirb_wp_count <= rirb_wp_count + 8'h01;

                    // Write response data to MMIO response registers (for drivers
                    // that may fall back to reading these instead of DMA buffer).
                    reg_0x00000070[31:0] <= dma_resp_lo_r;
                    reg_0x00000074[31:0] <= dma_resp_hi_r;

                    // Set RIRBSTS.UIS for unsolicited responses
                    // RESP_EX bit 4 = unsolicited flag (set by format conversion above)
                    if (dma_resp_hi_r[4]) begin
                        reg_0x0000005C[9] <= 1'b1;
                    end

                    // Set RIRBINTSTS.INTFL — tells driver a response is available.
                    // Actual register write is handled by consolidated INTFL driver
                    // at end of FSM block; set flag so it can merge with clear requests.
                    intfl_set_req <= 1'b1;

                    // Decrement pending count (one response delivered)
                    rirb_pending_count <= rirb_pending_count - 8'h01;

                    // Return to idle — ready for next CORB entry
                    rirb_response_fsm <= 8'h00;
                end else if (dma_timed_out) begin
                    // DMA bridge didn't respond within timeout — abort
                    // this transfer to prevent FSM hang and pending_count stall.
                    // Don't increment RIRBWP or set INTFL (response was lost).
                    // Decrement pending_count to allow the FSM to continue.
                    // The bridge's own timeout will return it to IDLE eventually.
                    rirb_pending_count <= rirb_pending_count - 8'h01;
                    rirb_response_fsm <= 8'h00;
                end
            end
        end
    end

    // ========================================================================
    // Consolidated INTFL driver — SINGLE source for reg_0x00000060.
    // All INTFL modifications go through here to avoid multi-driver conflicts.
    // Priority: clear (CRST/rb_reinit/RW1C) takes precedence over set.
    // ========================================================================
    always @(posedge clk) begin
        if (rst) begin
            reg_0x00000060 <= 32'h00000000;
        end else if (intfl_set_req && !intfl_clear_req && !intfl_crst_clear_req) begin
            // RIRB response committed — set INTFL to notify driver.
            reg_0x00000060[0] <= 1'b1;
        end else if (rb_reinit || intfl_crst_clear_req) begin
            // CRST rising edge or CTE reinit — clear INTFL.
            reg_0x00000060[0] <= 1'b0;
        end else if (intfl_clear_req) begin
            // Driver wrote 1 to RIRBINTSTS[0] (RW1C) — clear INTFL.
            reg_0x00000060[0] <= 1'b0;
        end
        // Default: hold current value (no explicit assignment needed for regs).
    end

    // Latch dma_done pulse so we don't miss it during state transitions.
    // dma_done is a 1-cycle pulse from the DMA bridge; if the BAR FSM
    // enters state 3 in the same cycle, it could miss the pulse due to
    // routing delay. The latch holds it until consumed.
    // The latch and timeout logic remain active regardless of CRST state
    // to ensure pulses are not lost during reset transitions.
    always @(posedge clk) begin
        if (rst) begin
            dma_done_latched  <= 1'b0;
            dma_wait_counter  <= 16'h0;
            dma_timed_out     <= 1'b0;
        end else begin
            // priority: consume > set > idle-clear
            if (rirb_response_fsm == 8'h11 && dma_done_latched) begin
                // FSM consumed the latch
                dma_done_latched <= 1'b0;
            end else if (dma_done) begin
                // new pulse from bridge
                dma_done_latched <= 1'b1;
            end else if (rirb_response_fsm != 8'h11 && rirb_response_fsm != 8'h10) begin
                // FSM not in DMA wait states — clear stale latch
                dma_done_latched <= 1'b0;
            end

            // Timeout counter: count cycles while waiting for dma_done
            if (rirb_response_fsm == 8'h11) begin
                dma_wait_counter <= dma_wait_counter + 1'b1;
                if (dma_wait_counter >= 16'hFFFF) begin
                    dma_timed_out <= 1'b1;
                end
            end else begin
                dma_wait_counter  <= 16'h0;
                dma_timed_out     <= 1'b0;
            end
        end
    end

    // Port assignments — expose internal regs to module outputs
    assign dma_req_valid   = dma_req_valid_r;
    assign dma_resp_lo     = dma_resp_lo_r;
    assign dma_resp_hi     = dma_resp_hi_r;
    assign dma_resp_wp     = dma_resp_wp_r;
    assign dma_rirb_lbase  = reg_0x00000050;  // RIRBLBASE
    assign dma_rirb_ubase  = reg_0x00000054;  // RIRBUBASE

    // MSI trigger: 1-cycle pulse when INTFL transitions 0->1
    // We detect the rising edge of reg_0x00000060[0] (RIRBINTSTS.INTFL)
    reg intfl_prev;
    always @(posedge clk) begin
        if (rst) begin
            intfl_prev <= 1'b0;
        end else begin
            intfl_prev <= reg_0x00000060[0];
        end
    end
    // MSI trigger gated by INTCTL: GIE (bit 31) and CIE (bit 30) must be enabled
    wire intctl_gie = reg_0x00000020[31];
    wire intctl_cie = reg_0x00000020[30];
    assign msi_trigger = reg_0x00000060[0] && !intfl_prev && intctl_gie && intctl_cie;
    assign rirbintsts  = reg_0x00000060;  // live RIRBINTSTS value

{{ end }}
{{ if eq .DeviceClass "ethernet" }}
    // PHYAR/ERIAR done-flag auto-clear for r8169 driver.
    // Driver sets bit 31 and polls until it drops.
    // These registers are IsFSMDriven — sole driver is this always block.
    reg [2:0] phyar_cnt;
    reg       phyar_pending;
    reg [2:0] eriar_cnt;
    reg       eriar_pending;

    always @(posedge clk) begin
        if (rst) begin
            phyar_pending  <= 1'b0;
            phyar_cnt      <= 3'h0;
            eriar_pending  <= 1'b0;
            eriar_cnt      <= 3'h0;
            reg_0x000000DC <= 32'h80000000;  // PHYAR: bit31 = ready
            reg_0x000000E0 <= 32'h80000000;  // ERIAR: bit31 = done
        end else begin
            // MMIO write forwarding for PHYAR (0xDC)
            if (wr_valid && (wr_addr[31:0] & 32'hFFFFFFFC) == 32'h000000DC) begin
                if (wr_be[0]) reg_0x000000DC[7:0]   <= wr_data[7:0];
                if (wr_be[1]) reg_0x000000DC[15:8]  <= wr_data[15:8];
                if (wr_be[2]) reg_0x000000DC[23:16] <= wr_data[23:16];
                if (wr_be[3]) reg_0x000000DC[31:24] <= wr_data[31:24];
                if (wr_data[31]) begin
                    phyar_pending <= 1'b1;
                    phyar_cnt     <= 3'h1;
                end
            end
            if (phyar_pending) begin
                phyar_cnt <= phyar_cnt + 1'b1;
                if (phyar_cnt >= 3'h4) begin
                    reg_0x000000DC[31] <= 1'b0;
                    phyar_pending      <= 1'b0;
                end
            end

            // MMIO write forwarding for ERIAR (0xE0)
            if (wr_valid && (wr_addr[31:0] & 32'hFFFFFFFC) == 32'h000000E0) begin
                if (wr_be[0]) reg_0x000000E0[7:0]   <= wr_data[7:0];
                if (wr_be[1]) reg_0x000000E0[15:8]  <= wr_data[15:8];
                if (wr_be[2]) reg_0x000000E0[23:16] <= wr_data[23:16];
                if (wr_be[3]) reg_0x000000E0[31:24] <= wr_data[31:24];
                if (wr_data[31]) begin
                    eriar_pending <= 1'b1;
                    eriar_cnt     <= 3'h1;
                end
            end
            if (eriar_pending) begin
                eriar_cnt <= eriar_cnt + 1'b1;
                if (eriar_cnt >= 3'h4) begin
                    reg_0x000000E0[31] <= 1'b0;
                    eriar_pending      <= 1'b0;
                end
            end
        end
    end
{{ end }}
{{ if .HasMSIX }}
    // ========================================================================
    // MSI-X Interrupt Controller - 4-state FSM
    //   IDLE -> PENDING -> ASSERT -> COOLDOWN
    // Triggered when a writable register is modified.
    // LFSR-based jitter prevents timing fingerprinting.
    // ========================================================================
    localparam [1:0] INT_IDLE     = 2'b00;
    localparam [1:0] INT_PENDING  = 2'b01;
    localparam [1:0] INT_ASSERT   = 2'b10;
    localparam [1:0] INT_COOLDOWN = 2'b11;

    reg [1:0]  int_state;
    reg [5:0]  int_counter;
    reg [5:0]  int_cooldown_target;
    reg        int_trigger;

    // 16-bit LFSR for interrupt timing jitter
    reg [15:0] int_lfsr;
    wire int_lfsr_fb = int_lfsr[15] ^ int_lfsr[14] ^ int_lfsr[12] ^ int_lfsr[3];

    always @(posedge clk) begin
        if (rst)
            int_lfsr <= {4'h0, 4'h{{ hex02 .DeviceIDs.RevisionID }}, 8'h{{ hex02 (index (rwMaskBytes (index .PRNGSeeds 0)) 0) }}};
        else
            int_lfsr <= {int_lfsr[14:0], int_lfsr_fb};
    end

    // Write activity detection - any write to a writable register triggers
    always @(posedge clk) begin
        if (rst)
            int_trigger <= 1'b0;
        else
            int_trigger <= wr_valid;
    end

    always @(posedge clk) begin
        if (rst) begin
            int_state           <= INT_IDLE;
            int_counter         <= 6'h0;
            int_cooldown_target <= 6'h10;
        end else begin
            case (int_state)
                INT_IDLE: begin
                    if (int_trigger) begin
                        int_state   <= INT_PENDING;
                        int_counter <= 6'h0;
                    end
                end

                INT_PENDING: begin
                    int_counter <= int_counter + 1'b1;
                    // Random pending delay (2-6 cycles based on LFSR)
                    if (int_counter >= {4'h0, int_lfsr[1:0]} + 6'h2)
                        int_state <= INT_ASSERT;
                end

                INT_ASSERT: begin
                    // Assert for 1 cycle then cooldown
                    int_state <= INT_COOLDOWN;
                    int_counter <= 6'h0;
                    // Jittered cooldown (16-63 cycles)
                    int_cooldown_target <= {int_lfsr[5:4], 4'h0} + 6'h10;
                end

                INT_COOLDOWN: begin
                    int_counter <= int_counter + 1'b1;
                    if (int_counter >= int_cooldown_target)
                        int_state <= INT_IDLE;
                end
            endcase
        end
    end
