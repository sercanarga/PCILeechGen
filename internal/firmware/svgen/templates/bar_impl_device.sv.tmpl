    // xHCI HCRST auto-clear
    // usbxhci.sys writes USBCMD.HCRST (bit 1) then waits for it to drop.
    // we count a few cycles and clear it so the driver doesn't hang.
    reg [3:0] hcrst_cnt;
    reg       hcrst_pending;

    // R/S -> HCH tracking: when driver sets R/S=1, HCH must clear.
    reg       rs_prev;

    always @(posedge clk) begin
        if (rst) begin
            hcrst_cnt     <= 4'h0;
            hcrst_pending <= 1'b0;
            rs_prev       <= 1'b0;
        end else begin
            rs_prev <= reg_0x00000020[0]; // USBCMD.R/S

            // HCRST handling
            if (reg_0x00000020[1] && !hcrst_pending) begin
                hcrst_pending <= 1'b1;
                hcrst_cnt     <= 4'h0;
            end
            if (hcrst_pending) begin
                hcrst_cnt <= hcrst_cnt + 1'b1;
                if (hcrst_cnt >= 4'h4) begin
                    reg_0x00000020[1] <= 1'b0;    // clear HCRST
                    reg_0x00000024    <= 32'h0001; // USBSTS = HCH (halted after reset)
                    hcrst_pending     <= 1'b0;
