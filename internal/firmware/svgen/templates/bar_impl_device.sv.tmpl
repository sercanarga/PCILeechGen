    // ========================================================================
    // HDA GCTL.CRST handshake + CORB/RIRB auto-response
    // hdaudio.sys writes CRST=0 (assert reset), then CRST=1 (deassert).
    // after deassert, we reload STATESTS so codec discovery works.
    // STATESTS lives in the upper 16 bits of the DWORD at 0x0C.
    //
    // CORB/RIRB auto-response: without this, hdaudio.sys polls RIRBWP
    // endlessly waiting for codec responses, generating massive PCIe
    // read TLP traffic that congests the FPGA fabric and throttles
    // DMA throughput to ~80 KB/s. We generate a fake RIRB response
    // for each VERB the driver submits via CORB, so the driver completes init.
    // ========================================================================

    // ---- Register declarations (must precede CRST block and FSM) ----
    reg crst_prev;
    reg  [7:0] rirb_response_fsm;
    reg [63:0] rirb_fake_response;
    reg  [7:0] corbwp_prev;
    reg  [7:0] rirb_pending_count;  // number of VERBs waiting for response
    reg  [7:0] rirb_wp_count;
    reg  [5:0] rirb_response_idx;   // index into response ROM (0-63)
    reg corb_cte_prev, rirb_cte_prev;

    // Internal DMA interface registers (driven by RIRB FSM)
    reg         dma_req_valid_r;
    reg [31:0]  dma_resp_lo_r;
    reg [31:0]  dma_resp_hi_r;
    reg [7:0]   dma_resp_wp_r;
    reg         dma_done_latched;  // latches the 1-cycle dma_done pulse
    reg [9:0]   dma_wait_counter;
    reg         dma_timed_out;

    // ---- CRST handshake ----
    always @(posedge clk) begin
        if (rst) begin
            crst_prev <= 1'b1;
        end else begin
            crst_prev <= reg_0x00000008[0];

            // rising edge on CRST - controller coming out of reset
            // This is hdaudio.sys re-enumeration — reset everything so the
            // next discovery cycle starts from ROM index 0.
            if (reg_0x00000008[0] && !crst_prev) begin
                reg_0x0000000C[16] <= 1'b1;  // STATESTS bit 0 = codec 0 present
                rirb_response_idx  <= 6'd0;
                rirb_pending_count <= 8'h00;
                rirb_response_fsm  <= 8'h00;
                rirb_wp_count      <= 8'h00;
                corb_cte_prev      <= 1'b0;
                rirb_cte_prev      <= 1'b0;
                corbwp_prev        <= 8'h00;
                // RIRBSTS cleared by main FSM on rb_reinit
                dma_req_valid_r    <= 1'b0;
                dma_resp_lo_r      <= 32'h0;
                dma_resp_hi_r      <= 32'h0;
                dma_resp_wp_r      <= 8'h0;
                dma_done_latched   <= 1'b0;
                dma_timed_out      <= 1'b0;
                dma_wait_counter   <= 10'h0;
                // NOTE: RIRBLBASE/RIRBUBASE are NOT cleared on CRST deassert.
                // HDA spec: DMA engine base addresses survive CRST reset.
                // The driver programs them before CRST=1 and expects them to persist.
                // Clearing them here causes the RIRB DMA to write to address 0,
                // so codec responses never reach the driver buffer, causing Code 10.
            end
            // falling edge on CRST - controller entering reset
            // Only clear STATESTS and prev trackers; main FSM handles RIRB reset
            // via crst_falling guard in its own always block.
            else if (!reg_0x00000008[0] && crst_prev) begin
                reg_0x0000000C[31:16] <= 16'h0000;  // clear STATESTS
            end
        end
    end

    // ========================================================================
    // Fake RIRB response generator (multi-VERB queue, sequence-based ROM)
    //
    // For each VERB the driver submits via CORB (detected by CORBWP changes),
    // we enqueue a fake RIRB response. A counter tracks pending responses;
    // the FSM drains one response at a time. Multiple outstanding VERBs are
    // supported — the driver can submit several CORB entries before we finish
    // responding to the first one.
    //
    // CORBWP delta calculation: the driver may advance CORBWP by N entries
    // in a single write (e.g., submitting multiple VERBs at once). We compute
    // the actual delta to enqueue the correct number of responses.
    //
    // Response ROM: hdaudio.sys sends different VERBs during codec topology
    // discovery and expects different responses. A canned ROM provides a
    // realistic sequence matching CA0132 (Creative Sound Blaster Audigy FX V2).
    // The 64-bit response format:
    //   [63:32] = type (bits [3:0]) | NID (bits [27:4]) | tag (bits [31:28])
    //   [31:0]  = response data (28-bit payload)
    //
    // RIRB response type 0x1 = standard VERB response data.
    // ========================================================================

    // CORBWP change detection: driver submitted new VERB(s).
    wire corb_cte = reg_0x0000004C[7];   // CORBCTL.CTE
    wire rirb_cte  = reg_0x0000005C[0];   // RIRBCTL.CTE
    wire corbwp_changed = (corbwp_prev != reg_0x00000048[7:0]) && corb_cte && rirb_cte;
    // CRST falling edge detection — guards FSM against fighting with CRST block
    wire crst_falling = !reg_0x00000008[0] && crst_prev;
    // Calculate how many entries the driver added (handles wrap-around at 256)
    wire [7:0] corbwp_delta_raw = reg_0x00000048[7:0] - corbwp_prev;
    // If delta > 32, the driver reset CORBWP without disabling CTE — treat as
    // no new VERBs. Without this, a WP reset enqueues 200+ phantom responses
    // that drain the ROM into the catch-all zone.
    wire [7:0] corbwp_delta = (corbwp_delta_raw > 8'h20) ? 8'h00 : corbwp_delta_raw;

    // CORB/RIRB reinitialization detection: driver disables CTE to reset buffers.
    // When CTE goes low, the driver is reinitializing — reset ROM index and
    // pending state so the next discovery cycle starts fresh.
    wire corb_reinit = corb_cte_prev && !corb_cte;
    wire rirb_reinit = rirb_cte_prev && !rirb_cte;
    wire rb_reinit   = corb_reinit || rirb_reinit;

    // ========================================================================
    // RIRBINTSTS RW1C (write-1-to-clear) detection.
    // RIRBINTSTS (offset 0x60) has IsRW1C=true, so it is excluded from the
    // generic write handler by the (not .IsRW1C) template filter.
    // HD Audio spec requires RIRBINTSTS bit 0 (INTFL) to be RW1C:
    //   write 1 → clear the flag, write 0 → no change.
    //
    // We detect the write here but DON'T write to reg_0x00000060 directly —
    // that would create a multi-driver conflict with the main FSM which also
    // sets INTFL. Instead, we produce a clear request that the main FSM
    // merges into the single reg_0x00000060[0] driver.
    reg rirbintsts_rw1c;

    always @(posedge clk) begin
        if (rst) begin
            rirbintsts_rw1c <= 1'b0;
        end else begin
            // Detect write to RIRBINTSTS at 0x60
            rirbintsts_rw1c <= wr_valid && (wr_addr[31:0] & 32'hFFFFFFFC) == 32'h00000060;
        end
    end

    // Clear request: driver writes 1 to bit 0 → clear INTFL.
    wire intfl_clear_req = rirbintsts_rw1c && wr_data[0];

    // CRST rising edge clear request: codec reset means driver is re-enumerating,
    // so INTFL must be cleared to prevent stale interrupt from pending response.
    // crst_prev is the PREVIOUS cycle value (updated by CRST block), so this
    // wire fires on the cycle where CRST transitions 0→1.
    wire intfl_crst_clear_req = reg_0x00000008[0] && !crst_prev;

    // INTFL set request from RIRB response commit FSM.
    // This is a flag that the FSM uses to request INTFL be set to 1.
    // The actual reg_0x00000060[0] write is consolidated in a single always
    // block to avoid multi-driver conflicts.
    reg intfl_set_req;

    // ========================================================================
    // RIRBCTL/RIRBSTS (0x5C) driver write handler.
    // This register is IsRW1C — excluded from generic write logic. We must
    // handle ALL MMIO writes here:
    //   - Control bits [2:0]: CTE (bit 0), OIE (bit 2) — standard writable
    //   - Status bits [10:8]: OIS (bit 8), UIS (bit 9), INTFL (bit 10) — RW1C
    // RW1C for status: driver writes 1 → clear to 0, writes 0 → preserve.
    // Standard write for control: driver writes value → update the bit.
    // ========================================================================
    reg rirbctl_rw1c;

    always @(posedge clk) begin
        if (rst) begin
            rirbctl_rw1c <= 1'b0;
        end else begin
            rirbctl_rw1c <= wr_valid && (wr_addr[31:0] & 32'hFFFFFFFC) == 32'h0000005C;
        end
    end

    always @(posedge clk) begin
        if (!rst && rirbctl_rw1c) begin
            // Control bits (CTE, OIE): standard writable — apply write through
            // mask 0x05 = bits 0 and 2
            reg_0x0000005C[0] <= (reg_0x0000005C[0] & ~1'b1) | (wr_data[0] & 1'b1);
            reg_0x0000005C[2] <= (reg_0x0000005C[2] & ~1'b1) | (wr_data[2] & 1'b1);

            // Status bits (OIS, UIS, INTFL): RW1C — write 1 to clear
            // mask 0x07 = bits 0, 1, 2 of RIRBSTS → DWORD bits 8, 9, 10
            reg_0x0000005C[10:8] <= reg_0x0000005C[10:8] & ~wr_data[10:8];
        end
    end

    // ========================================================================
    // CORBCTL/CORBSTS (0x4C) driver write handler.
    // This register is IsRW1C — excluded from generic write logic. We must
    // handle ALL MMIO writes here:
    //   - Control bits: CTE (bit 7), MEIE (bit 1) — standard writable
    //   - Status bit: RPWP (bit 8) — RW1C
    // RW1C for RPWP: driver writes 1 -> clear to 0, writes 0 -> preserve.
    // Standard write for control: driver writes value -> update the bit.
    // ========================================================================
    reg corbsts_rw1c;

    always @(posedge clk) begin
        if (rst) begin
            corbsts_rw1c <= 1'b0;
        end else begin
            corbsts_rw1c <= wr_valid && (wr_addr[31:0] & 32'hFFFFFFFC) == 32'h0000004C;
        end
    end

    always @(posedge clk) begin
        if (!rst && corbsts_rw1c) begin
            // Control bits (CTE, MEIE): standard writable — apply write through
            // mask 0x82 = bits 1 and 7 of CORBCTL
            reg_0x0000004C[1] <= (reg_0x0000004C[1] & ~1'b1) | (wr_data[1] & 1'b1);
            reg_0x0000004C[7] <= (reg_0x0000004C[7] & ~1'b1) | (wr_data[7] & 1'b1);

            // Status bit (RPWP): RW1C — write 1 to clear
            reg_0x0000004C[8] <= reg_0x0000004C[8] & ~wr_data[8];
        end
    end

    // CA0132 codec response ROM — provides unique responses per VERB
    // so hdaudio.sys can complete codec topology discovery.
    // Format: {type_nid[31:0], response_data[31:0]}
    // type=1 in bits [3:0], NID in [27:4], tag in [31:28].
    //
    // Entries 0–19: initial codec discovery (node parameters, configs).
    // Entries 20–31: runtime responses (power state, pin sense, amp settings,
    //   extra nodes) to prevent catch-all saturation during extended operation.
    // Entries 32–63: extended runtime phase — cycling zone for repeated VERBs
    //   (power transitions, converter/stream queries, jack detect simulation,
    //   EAPD/BTL, repeated node parameters). After index 63, the counter wraps
    //   back to 32 (runtime zone) rather than 0 (discovery zone), preventing
    //   duplicate discovery responses during sustained operation.
    function [63:0] rirb_rom_response;
        input [5:0] idx;
        begin
            case (idx)
                // === DISCOVERY PHASE (indices 0–19) ===
                // 0: GET_PARAMETERS(Node 0 — AFG)
                // NumSubNodes=16 | StartNode=1 | FuncType=AFG(0x1)
                6'd0:  rirb_rom_response = {32'h00000001, 32'h01010001};
                // 1: GET_SUBSYSTEM_ID
                // SubsystemID = 0x11020010 (Creative SB Audigy FX)
                6'd1:  rirb_rom_response = {32'h00000001, 32'h11020010};
                // 2: GET_PARAMETERS(Node 1 — Audio Out, playback DAC)
                // OutAmp=0, InAmp=0, Cap=0x3 (Out+Stereo), Type=0x1
                6'd2:  rirb_rom_response = {32'h00000011, 32'h00030001};
                // 3: GET_PARAMETERS(Node 2 — Audio Out, SPDIF out)
                // DigOut, Type=0x2
                6'd3:  rirb_rom_response = {32'h00000021, 32'h00020002};
                // 4: GET_PARAMETERS(Node 3 — Audio In, recording ADC)
                // InAmp present, Cap=0x2 (In), Type=0x1
                6'd4:  rirb_rom_response = {32'h00000031, 32'h00020011};
                // 5: GET_PARAMETERS(Node 4 — Audio Mixer)
                // 3 inputs, mixer type=0x0
                6'd5:  rirb_rom_response = {32'h00000041, 32'h00030000};
                // 6: GET_PARAMETERS(Node 5 — Audio Mixer)
                // 2 inputs, mixer type=0x0
                6'd6:  rirb_rom_response = {32'h00000051, 32'h00020000};
                // 7: GET_PARAMETERS(Node 6 — Audio Selector)
                // 2 inputs, sel type=0x3
                6'd7:  rirb_rom_response = {32'h00000061, 32'h00020003};
                // 8: GET_PARAMETERS(Node 7 — Audio Selector)
                // 3 inputs, sel type=0x3
                6'd8:  rirb_rom_response = {32'h00000071, 32'h00030003};
                // 9: GET_PARAMETERS(Node 8 — Audio Selector)
                // 2 inputs, sel type=0x3
                6'd9:  rirb_rom_response = {32'h00000081, 32'h00020003};
                // 10: GET_PARAMETERS(Node 9 — Pin Complex, line-out)
                // Cap=0x40000 (Out), type=0x4, default=0x01014010
                6'd10: rirb_rom_response = {32'h00000091, 32'h00040004};
                // 11: GET_CONFIG_DEFAULT(Node 9 pin)
                // Default assoc=1, seq=0, device=Line Out, loc=Ext, conn=1/8
                6'd11: rirb_rom_response = {32'h00000091, 32'h01014010};
                // 12: GET_PARAMETERS(Node 10 — Pin Complex, mic in)
                // Cap=0x20000 (In), type=0x4
                6'd12: rirb_rom_response = {32'h000000A1, 32'h00040024};
                // 13: GET_CONFIG_DEFAULT(Node 10 pin)
                // Mic In, rear, 3.5mm
                6'd13: rirb_rom_response = {32'h000000A1, 32'h01A19020};
                // 14: GET_PARAMETERS(Node 11 — Vendor-defined widget)
                6'd14: rirb_rom_response = {32'h000000B1, 32'h0000000F};
                // 15: GET_PARAMETERS(Node 12 — Vendor-defined widget)
                6'd15: rirb_rom_response = {32'h000000C1, 32'h0000000F};
                // 16: GET_PARAMETERS(Node 13 — Audio Selector)
                6'd16: rirb_rom_response = {32'h000000D1, 32'h00020003};
                // 17: GET_CONNECT_LIST(Node 7 — input amp connections)
                6'd17: rirb_rom_response = {32'h000000E1, 32'h00050004};
                // 18: GET_PARAMETERS(Node 14 — Beep generator)
                6'd18: rirb_rom_response = {32'h000000F1, 32'h00070007};
                // 19: GET_PARAMETERS(Node 15 — Vendor-defined)
                6'd19: rirb_rom_response = {32'h00000101, 32'h0000000F};
                // === RUNTIME PHASE (indices 20–31) ===
                // 20: SET_POWER_STATE(Node 0 AFG — D0 ack)
                6'd20: rirb_rom_response = {32'h00000001, 32'h00000000};
                // 21: GET_PIN_SENSE(Node 9 — line-out, no jack detect trigger)
                6'd21: rirb_rom_response = {32'h00000091, 32'h00000000};
                // 22: GET_PIN_SENSE(Node 10 — mic in, no jack detect trigger)
                6'd22: rirb_rom_response = {32'h000000A1, 32'h00000000};
                // 23: GET_AMP_GAIN_MUTE(Node 4 mixer, input 0)
                6'd23: rirb_rom_response = {32'h00000041, 32'h00000000};
                // 24: GET_AMP_GAIN_MUTE(Node 4 mixer, input 1)
                6'd24: rirb_rom_response = {32'h00000041, 32'h00000001};
                // 25: GET_CONVERTER_SAMPLE_RATE(Node 1)
                6'd25: rirb_rom_response = {32'h00000011, 32'h0000BB80};  // 48000 Hz
                // 26: GET_CONVERTER_STREAM_CHAN(Node 1)
                6'd26: rirb_rom_response = {32'h00000011, 32'h00000000};
                // 27: GET_VOLUME_KNOCK_CONTROL(Node 14 beep)
                6'd27: rirb_rom_response = {32'h000000F1, 32'h00000000};
                // 28: GET_EAPD_BTLENABLE(Node 1 — DAC)
                6'd28: rirb_rom_response = {32'h00000011, 32'h00000002};
                // 29: SET_PIN_WIDGET_CONTROL(Node 9 — OUT enable)
                6'd29: rirb_rom_response = {32'h00000091, 32'h00000000};
                // 30: SET_PIN_WIDGET_CONTROL(Node 10 — IN enable)
                6'd30: rirb_rom_response = {32'h000000A1, 32'h00000000};
                // 31: GET_PARAMETERS(Node 1 — repeated for runtime poll)
                6'd31: rirb_rom_response = {32'h00000011, 32'h00030001};
                // === EXTENDED RUNTIME PHASE (indices 32–63) ===
                // Cycled after index 63 wraps back to 32, avoiding discovery zone.
                // 32: SET_POWER_STATE(Node 0 AFG — D3 sleep ack)
                6'd32: rirb_rom_response = {32'h00000001, 32'h00000003};
                // 33: SET_POWER_STATE(Node 0 AFG — D0 wake ack)
                6'd33: rirb_rom_response = {32'h00000001, 32'h00000000};
                // 34: GET_PIN_SENSE(Node 9 — line-out, plugged in)
                6'd34: rirb_rom_response = {32'h00000091, 32'h01000000};
                // 35: GET_PIN_SENSE(Node 10 — mic in, plugged in)
                6'd35: rirb_rom_response = {32'h000000A1, 32'h01000000};
                // 36: GET_AMP_GAIN_MUTE(Node 5 mixer, input 0)
                6'd36: rirb_rom_response = {32'h00000041, 32'h00000000};
                // 37: GET_AMP_GAIN_MUTE(Node 5 mixer, input 1)
                6'd37: rirb_rom_response = {32'h00000051, 32'h00000001};
                // 38: GET_CONVERTER_FORMAT(Node 1 — 48kHz 16-bit stereo)
                6'd38: rirb_rom_response = {32'h00000011, 32'h00000040};
                // 39: GET_CONVERTER_FORMAT(Node 2 — SPDIF 48kHz)
                6'd39: rirb_rom_response = {32'h00000021, 32'h00000040};
                // 40: GET_STREAM_ID(Node 1 — stream 1)
                6'd40: rirb_rom_response = {32'h00000011, 32'h00000001};
                // 41: GET_STREAM_ID(Node 2 — stream 2 for SPDIF)
                6'd41: rirb_rom_response = {32'h00000021, 32'h00000002};
                // 42: GET_EAPD_BTLENABLE(Node 2 — SPDIF DAC, EAPD enabled)
                6'd42: rirb_rom_response = {32'h00000021, 32'h00000002};
                // 43: SET_EAPD_BTLENABLE(Node 1 — enable EAPD)
                6'd43: rirb_rom_response = {32'h00000011, 32'h00000000};
                // 44: SET_EAPD_BTLENABLE(Node 2 — enable SPDIF EAPD)
                6'd44: rirb_rom_response = {32'h00000021, 32'h00000000};
                // 45: Unsolicited response — jack detect (line-out present)
                // type=2 (unsolicited), tag=1, NID=9
                6'd45: rirb_rom_response = {32'h11000092, 32'h01000000};
                // 46: Unsolicited response — jack detect (mic present)
                // type=2 (unsolicited), tag=2, NID=10
                6'd46: rirb_rom_response = {32'h210000A2, 32'h01000000};
                // 47: SET_POWER_STATE(Node 1 — DAC D0)
                6'd47: rirb_rom_response = {32'h00000011, 32'h00000000};
                // 48: SET_POWER_STATE(Node 2 — SPDIF DAC D0)
                6'd48: rirb_rom_response = {32'h00000021, 32'h00000000};
                // 49: SET_POWER_STATE(Node 3 — ADC D0)
                6'd49: rirb_rom_response = {32'h00000031, 32'h00000000};
                // 50: GET_PARAMETERS(Node 4 mixer — repeated runtime poll)
                6'd50: rirb_rom_response = {32'h00000041, 32'h00030000};
                // 51: GET_PARAMETERS(Node 5 mixer — repeated runtime poll)
                6'd51: rirb_rom_response = {32'h00000051, 32'h00020000};
                // 52: GET_PIN_WIDGET_CONTROL(Node 9 — output enable query)
                6'd52: rirb_rom_response = {32'h00000091, 32'h00000040};
                // 53: GET_PIN_WIDGET_CONTROL(Node 10 — input enable query)
                6'd53: rirb_rom_response = {32'h000000A1, 32'h00000020};
                // 54: SET_CONVERTER_SAMPLE_RATE(Node 1 — 48kHz)
                6'd54: rirb_rom_response = {32'h00000011, 32'h00000000};
                // 55: SET_CONVERTER_SAMPLE_RATE(Node 2 — SPDIF 48kHz)
                6'd55: rirb_rom_response = {32'h00000021, 32'h00000000};
                // 56: SET_CONVERTER_STREAM_CHAN(Node 1)
                6'd56: rirb_rom_response = {32'h00000011, 32'h00000000};
                // 57: SET_CONVERTER_STREAM_CHAN(Node 2 — SPDIF)
                6'd57: rirb_rom_response = {32'h00000021, 32'h00000000};
                // 58: GET_AMP_GAIN_MUTE(Node 4 mixer, input 2)
                6'd58: rirb_rom_response = {32'h00000041, 32'h00000002};
                // 59: GET_AMP_GAIN_MUTE(Node 6 selector, input 0)
                6'd59: rirb_rom_response = {32'h00000061, 32'h00000000};
                // 60: SET_POWER_STATE(Node 14 — beep widget D3)
                6'd60: rirb_rom_response = {32'h000000F1, 32'h00000003};
                // 61: GET_PARAMETERS(Node 2 — SPDIF repeated poll)
                6'd61: rirb_rom_response = {32'h00000021, 32'h00020002};
                // 62: GET_PARAMETERS(Node 3 — ADC repeated poll)
                6'd62: rirb_rom_response = {32'h00000031, 32'h00020011};
                // 63: GET_SUBSYSTEM_ID — repeated runtime query
                6'd63: rirb_rom_response = {32'h00000001, 32'h11020010};
                // 64+: catch-all — safe "no-op" response (should not be reached
                // with 6-bit index, but defensive default)
                default: rirb_rom_response = {32'h00000001, 32'h00000000};
            endcase
        end
    endfunction

    always @(posedge clk) begin
        if (rst) begin
            rirb_response_fsm  <= 8'h00;
            rirb_fake_response <= 64'h0;
            corbwp_prev        <= 8'h00;
            rirb_pending_count <= 8'h00;
            rirb_wp_count      <= 8'h00;
            rirb_response_idx  <= 6'd0;
            corb_cte_prev      <= 1'b0;
            rirb_cte_prev      <= 1'b0;
            dma_req_valid_r    <= 1'b0;
            dma_resp_lo_r      <= 32'h0;
            dma_resp_hi_r      <= 32'h0;
            dma_resp_wp_r      <= 8'h0;
            dma_done_latched   <= 1'b0;
            intfl_set_req      <= 1'b0;
        end else begin
            // Default: no INTFL set request this cycle.
            // Response commit path below may set this to 1.
            intfl_set_req <= 1'b0;

            // CRST falling edge guard: if CRST is being asserted, suppress all
            // FSM activity this cycle. The CRST block (separate always block)
            // resets all state vars — we must not fight it with our own
            // assignments. Without this guard, both blocks drive the same regs
            // and the result is synthesis-tool-dependent.

            // Track CTE for reinitialization detection
            if (!crst_falling) begin
                corb_cte_prev <= corb_cte;
                rirb_cte_prev <= rirb_cte;

                // Track CORBWP for change detection
                corbwp_prev <= reg_0x00000048[7:0];
            end else begin
                corb_cte_prev <= 1'b0;
                rirb_cte_prev <= 1'b0;
                corbwp_prev   <= 8'h00;
            end

            // CORB/RIRB reinitialization: driver disabled CTE → reset ROM index
            // and pending state so the next discovery cycle starts from index 0.
            // Guarded by !crst_falling — CRST block handles reset.
            //
            // This is critical: hdaudio.sys re-enumeration expects the same
            // discovery-phase responses (indices 0-19) as the first boot.
            // If we don't reset rirb_response_idx, we'll serve runtime-zone
            // responses to discovery VERBs, causing Code 10 on re-plug.
            if (rb_reinit && !crst_falling) begin
                rirb_response_idx  <= 6'd0;
                rirb_pending_count <= 8'h00;
                rirb_response_fsm  <= 8'h00;
                rirb_wp_count      <= 8'h00;
                corbwp_prev        <= 8'h00;
                reg_0x00000048[15:8] <= 8'h00;  // reset CORBRP to 0
                reg_0x0000005C[1:0] <= 2'b0;  // clear RIRBSTS (UIS + OIS)
                // NOTE: RIRBLBASE/RIRBUBASE preserved, driver may not reprogram
                // them on re-init if the buffer address hasn't changed.
            end

            // Enqueue: add the actual number of entries the driver submitted.
            // Guard: if rb_reinit is active, ignore corbwp_changed in the same
            // cycle. Without this, a driver that changes CORBWP while disabling
            // CTE would leave a stale pending count after reinitialization.
            // Guarded by !crst_falling — CRST block handles reset.
            if (corbwp_changed && !rb_reinit && !crst_falling) begin
                // Saturating addition: prevent overflow when DMA is stuck.
                // If pending_count + delta would exceed 255, cap at 255.
                // Without this, overflow wraps to 0 and the FSM stops
                // producing responses, causing hdaudio.sys Code 10.
                if (rirb_pending_count + corbwp_delta < rirb_pending_count) begin
                    rirb_pending_count <= 8'hFF;
                end else begin
                    rirb_pending_count <= rirb_pending_count + corbwp_delta;
                end
                // Auto-advance CORB read pointer (controller consumed CORB entries)
                reg_0x00000048[15:8] <= reg_0x00000048[15:8] + corbwp_delta;
            end

            // All FSM transitions are guarded by !crst_falling to avoid fighting
            // with the CRST block which resets state vars in a separate always block.

            // Build response data when starting a new response
            if (rirb_response_fsm == 8'h00 && rirb_pending_count > 8'h00 && !crst_falling) begin
                // Look up the next response from the CA0132 ROM
                rirb_fake_response <= rirb_rom_response(rirb_response_idx);
                // Cycle: advance up to 63, then wrap to 32 (extended runtime zone).
                // Wrapping to 32 instead of 0 avoids re-sending discovery-phase
                // responses, which would confuse the driver during sustained operation.
                rirb_response_idx  <= (rirb_response_idx < 6'd63) ? rirb_response_idx + 6'h1 : 6'd32;
                rirb_response_fsm  <= 8'h04; // 4-cycle delay before committing
            end

            // Response FSM countdown
            if (rirb_response_fsm > 8'h00 && !crst_falling) begin
                rirb_response_fsm <= rirb_response_fsm - 8'h01;

                // When FSM reaches 1, initiate DMA write handshake with bridge
                if (rirb_response_fsm == 8'h01) begin
                    dma_req_valid_r <= 1'b1;
                    dma_resp_lo_r   <= rirb_fake_response[31:0];
                    dma_resp_hi_r   <= rirb_fake_response[63:32];
                    dma_resp_wp_r   <= rirb_wp_count;
                    rirb_response_fsm <= 8'h02; // enter DMA wait
                end
            end

            // DMA handshake state machine:
            //   state 2: wait for bridge to accept request (dma_req_ready)
            //   state 3: wait for bridge to complete write (dma_done)
            //   state 4: commit RIRBWP and INTFL, return to idle
            if (rirb_response_fsm == 8'h02 && dma_req_valid_r && dma_req_ready && !crst_falling) begin
                // Bridge accepted the request, clear our request
                dma_req_valid_r <= 1'b0;
                rirb_response_fsm <= 8'h03;
            end

            if (rirb_response_fsm == 8'h03 && !crst_falling) begin
                // Waiting for DMA bridge to complete the write.
                // Use latched done signal to avoid missing the 1-cycle pulse.
                if (dma_done_latched) begin
                    // DMA write completed — now commit to MMIO registers

                    // Increment RIRBWP counter (8-bit, wraps at 256 per RIRBSIZE).
                    // Mask to RIRBSIZE: the size field at 0x5C[31:24] encodes
                    // supported buffer sizes. 0x40 = 256 entries (full 8-bit range).
                    // We mask to prevent WP from exceeding the programmed size.
                    rirb_wp_count <= rirb_wp_count + 8'h01;
                    reg_0x00000058[15:8] <= (rirb_wp_count + 8'h01) & 8'hFF;

                    // Write response data to MMIO response registers (for drivers
                    // that may fall back to reading these instead of DMA buffer).
                    reg_0x00000070[31:0] <= dma_resp_lo_r;
                    reg_0x00000074[31:0] <= dma_resp_hi_r;

                    // Set RIRBSTS.UIS only for unsolicited responses (type=2)
                    if (dma_resp_lo_r[3:0] == 4'h2) begin
                        reg_0x0000005C[1] <= 1'b1;
                    end

                    // Set RIRBINTSTS.INTFL — tells driver a response is available.
                    // Actual register write is handled by consolidated INTFL driver
                    // at end of FSM block; set flag so it can merge with clear requests.
                    intfl_set_req <= 1'b1;

                    // Decrement pending count (one response delivered)
                    rirb_pending_count <= rirb_pending_count - 8'h01;

                    // Return to idle — ready for next CORB entry
                    rirb_response_fsm <= 8'h00;
                end else if (dma_timed_out) begin
                    // DMA bridge didn't respond within 1024 cycles — abort
                    // this transfer to prevent FSM hang and pending_count stall.
                    // Don't increment RIRBWP or set INTFL (response was lost).
                    // Decrement pending_count to allow the FSM to continue.
                    // Clear dma_done_latched to prevent stale signal corruption
                    // on the next transfer.
                    rirb_pending_count <= rirb_pending_count - 8'h01;
                    dma_done_latched   <= 1'b0;
                    rirb_response_fsm <= 8'h00;
                end
            end
        end
    end

    // ========================================================================
    // Consolidated INTFL driver — SINGLE source for reg_0x00000060[0].
    // All INTFL modifications go through here to avoid multi-driver conflicts.
    // Priority: clear (CRST/rb_reinit/RW1C) takes precedence over set.
    // ========================================================================
    always @(posedge clk) begin
        if (rst) begin
            reg_0x00000060[0] <= 1'b0;
        end else if (intfl_set_req && !intfl_clear_req && !intfl_crst_clear_req) begin
            // RIRB response committed — set INTFL to notify driver.
            reg_0x00000060[0] <= 1'b1;
        end else if (rb_reinit || intfl_crst_clear_req) begin
            // CRST rising edge or CTE reinit — clear INTFL.
            reg_0x00000060[0] <= 1'b0;
        end else if (intfl_clear_req) begin
            // Driver wrote 1 to RIRBINTSTS[0] (RW1C) — clear INTFL.
            reg_0x00000060[0] <= 1'b0;
        end
        // Default: hold current value (no explicit assignment needed for regs).
    end

    // Latch dma_done pulse so we don't miss it during state transitions.
    // dma_done is a 1-cycle pulse from the DMA bridge; if the BAR FSM
    // enters state 3 in the same cycle, it could miss the pulse due to
    // routing delay. The latch holds it until consumed.
    // The latch and timeout logic remain active regardless of CRST state
    // to ensure pulses are not lost during reset transitions.
    always @(posedge clk) begin
        if (rst) begin
            dma_done_latched  <= 1'b0;
            dma_wait_counter  <= 10'h0;
            dma_timed_out     <= 1'b0;
        end else begin
            if (dma_done) begin
                dma_done_latched <= 1'b1;
            end
            if (rirb_response_fsm == 8'h03 && dma_done_latched) begin
                dma_done_latched <= 1'b0;
            end

            // Timeout counter: count cycles while waiting for dma_done
            if (rirb_response_fsm == 8'h03) begin
                dma_wait_counter <= dma_wait_counter + 1'b1;
                if (dma_wait_counter >= 10'h3FF) begin
                    dma_timed_out <= 1'b1;
                end
            end else begin
                dma_wait_counter  <= 10'h0;
                dma_timed_out     <= 1'b0;
            end
        end
    end

    // Port assignments — expose internal regs to module outputs
    assign dma_req_valid   = dma_req_valid_r;
    assign dma_resp_lo     = dma_resp_lo_r;
    assign dma_resp_hi     = dma_resp_hi_r;
    assign dma_resp_wp     = dma_resp_wp_r;
    assign dma_rirb_lbase  = reg_0x00000050;  // RIRBLBASE
    assign dma_rirb_ubase  = reg_0x00000054;  // RIRBUBASE

    // MSI trigger: 1-cycle pulse when INTFL transitions 0->1
    // We detect the rising edge of reg_0x00000060[0] (RIRBINTSTS.INTFL)
    reg intfl_prev;
    always @(posedge clk) begin
        if (rst) begin
            intfl_prev <= 1'b0;
        end else begin
            intfl_prev <= reg_0x00000060[0];
        end
    end
    assign msi_trigger = reg_0x00000060[0] && !intfl_prev;
    assign rirbintsts  = reg_0x00000060;  // live RIRBINTSTS value

{{ end }}
{{ if eq .DeviceClass "ethernet" }}
    // PHYAR/ERIAR done-flag auto-clear for r8169 driver.
    // Driver sets bit 31 and polls until it drops.
    reg [2:0] phyar_cnt;
    reg       phyar_pending;
    reg [2:0] eriar_cnt;
    reg       eriar_pending;

    always @(posedge clk) begin
        if (rst) begin
            phyar_pending <= 1'b0;
            phyar_cnt     <= 3'h0;
            eriar_pending <= 1'b0;
            eriar_cnt     <= 3'h0;
        end else begin
            // PHYAR at 0xDC
            if (wr_valid && (wr_addr[31:0] & 32'hFFFFFFFC) == 32'h000000DC && wr_data[31]) begin
                phyar_pending <= 1'b1;
                phyar_cnt     <= 3'h1;
            end
            if (phyar_pending) begin
                phyar_cnt <= phyar_cnt + 1'b1;
                if (phyar_cnt >= 3'h4) begin
                    reg_0x000000DC[31] <= 1'b0;
                    phyar_pending      <= 1'b0;
                end
            end

            // ERIAR at 0xE0
            if (wr_valid && (wr_addr[31:0] & 32'hFFFFFFFC) == 32'h000000E0 && wr_data[31]) begin
                eriar_pending <= 1'b1;
                eriar_cnt     <= 3'h1;
            end
            if (eriar_pending) begin
                eriar_cnt <= eriar_cnt + 1'b1;
                if (eriar_cnt >= 3'h4) begin
                    reg_0x000000E0[31] <= 1'b0;
                    eriar_pending      <= 1'b0;
                end
            end
        end
    end
{{ end }}
{{ if .HasMSIX }}
    // ========================================================================
    // MSI-X Interrupt Controller - 4-state FSM
    //   IDLE -> PENDING -> ASSERT -> COOLDOWN
    // Triggered when a writable register is modified.
    // LFSR-based jitter prevents timing fingerprinting.
    // ========================================================================
    localparam [1:0] INT_IDLE     = 2'b00;
    localparam [1:0] INT_PENDING  = 2'b01;
    localparam [1:0] INT_ASSERT   = 2'b10;
    localparam [1:0] INT_COOLDOWN = 2'b11;

    reg [1:0]  int_state;
    reg [5:0]  int_counter;
    reg [5:0]  int_cooldown_target;
    reg        int_trigger;

    // 16-bit LFSR for interrupt timing jitter
    reg [15:0] int_lfsr;
    wire int_lfsr_fb = int_lfsr[15] ^ int_lfsr[14] ^ int_lfsr[12] ^ int_lfsr[3];

    always @(posedge clk) begin
        if (rst)
            int_lfsr <= {4'h0, 4'h{{ hex02 .DeviceIDs.RevisionID }}, 8'h{{ hex02 (index (rwMaskBytes (index .PRNGSeeds 0)) 0) }}};
        else
            int_lfsr <= {int_lfsr[14:0], int_lfsr_fb};
    end

    // Write activity detection - any write to a writable register triggers
    always @(posedge clk) begin
        if (rst)
            int_trigger <= 1'b0;
        else
            int_trigger <= wr_valid;
    end

    always @(posedge clk) begin
        if (rst) begin
            int_state           <= INT_IDLE;
            int_counter         <= 6'h0;
            int_cooldown_target <= 6'h10;
        end else begin
            case (int_state)
                INT_IDLE: begin
                    if (int_trigger) begin
                        int_state   <= INT_PENDING;
                        int_counter <= 6'h0;
                    end
                end

                INT_PENDING: begin
                    int_counter <= int_counter + 1'b1;
                    // Random pending delay (2-6 cycles based on LFSR)
                    if (int_counter >= {4'h0, int_lfsr[1:0]} + 6'h2)
                        int_state <= INT_ASSERT;
                end

                INT_ASSERT: begin
                    // Assert for 1 cycle then cooldown
                    int_state <= INT_COOLDOWN;
                    int_counter <= 6'h0;
                    // Jittered cooldown (16-63 cycles)
                    int_cooldown_target <= {int_lfsr[5:4], 4'h0} + 6'h10;
                end

                INT_COOLDOWN: begin
                    int_counter <= int_counter + 1'b1;
                    if (int_counter >= int_cooldown_target)
                        int_state <= INT_IDLE;
                end
            endcase
        end
    end
{{ end }}

    // ========================================================================
    // Reset and Write Logic
    // ========================================================================

    always @(posedge clk) begin
        if (rst) begin
{{ range .BARModel.Registers }}            reg_0x{{ hex08 .Offset }} <= {{ mul .Width 8 }}'h{{ hex08 .Reset }};
{{ end }}        end
        else if (wr_valid) begin
            case (wr_addr[31:0] & 32'hFFFFFFFC)
{{ range .BARModel.Registers }}{{ if and (ne .RWMask 0) (not .IsRW1C) }}                32'h{{ hex08 (alignedOffset .Offset) }}: begin
                    if (wr_be[0]) reg_0x{{ hex08 .Offset }}[7:0]   <= (reg_0x{{ hex08 .Offset }}[7:0]   & ~8'h{{ hex02 (index (rwMaskBytes .RWMask) 0) }}) | (wr_data[7:0]   & 8'h{{ hex02 (index (rwMaskBytes .RWMask) 0) }});
                    if (wr_be[1]) reg_0x{{ hex08 .Offset }}[15:8]  <= (reg_0x{{ hex08 .Offset }}[15:8]  & ~8'h{{ hex02 (index (rwMaskBytes .RWMask) 1) }}) | (wr_data[15:8]  & 8'h{{ hex02 (index (rwMaskBytes .RWMask) 1) }});
                    if (wr_be[2]) reg_0x{{ hex08 .Offset }}[23:16] <= (reg_0x{{ hex08 .Offset }}[23:16] & ~8'h{{ hex02 (index (rwMaskBytes .RWMask) 2) }}) | (wr_data[23:16] & 8'h{{ hex02 (index (rwMaskBytes .RWMask) 2) }});
                    if (wr_be[3]) reg_0x{{ hex08 .Offset }}[31:24] <= (reg_0x{{ hex08 .Offset }}[31:24] & ~8'h{{ hex02 (index (rwMaskBytes .RWMask) 3) }}) | (wr_data[31:24] & 8'h{{ hex02 (index (rwMaskBytes .RWMask) 3) }});
                end
{{ end }}{{ end }}                default: begin
                    // unregistered offset - ignore write
                end
            endcase
        end
    end

    // ========================================================================
    // Read Logic (2-cycle latency)
    // ========================================================================

    reg [87:0] rd_req_ctx_d1;
    reg        rd_req_valid_d1;
    reg [31:0] rd_data_d1;

    always @(posedge clk) begin
        rd_req_ctx_d1   <= rd_req_ctx;
        rd_req_valid_d1 <= rd_req_valid;

        if (rd_req_valid) begin
            case (rd_req_addr[31:0] & 32'hFFFFFFFC)
{{ range .BARModel.Registers }}                32'h{{ hex08 (alignedOffset .Offset) }}: rd_data_d1 <= reg_0x{{ hex08 .Offset }};
{{ end }}                default: rd_data_d1 <= 32'h00000000;
            endcase
        end
        else begin
            rd_data_d1 <= 32'h00000000;
        end
    end

    always @(posedge clk) begin
        rd_rsp_ctx   <= rd_req_ctx_d1;
        rd_rsp_valid <= rd_req_valid_d1;
        rd_rsp_data  <= rd_data_d1;
    end

{{ else }}
// No learned register map - fallback to BRAM-based storage.
module pcileech_bar_impl_device #(
    parameter BAR_SIZE = 4096
)(
    input               rst,
    input               clk,

    input [31:0]        wr_addr,
    input [31:0]        wr_data,
    input [3:0]         wr_be,
    input               wr_valid,

    input [87:0]        rd_req_ctx,
    input [31:0]        rd_req_addr,
    input               rd_req_valid,

    output reg [87:0]   rd_rsp_ctx,
    output reg [31:0]   rd_rsp_data,
    output reg          rd_rsp_valid
);

    reg [87:0] rd_req_ctx_d1;
    reg        rd_req_valid_d1;
    wire [31:0] doutb;

    always @(posedge clk) begin
        rd_req_ctx_d1   <= rd_req_ctx;
        rd_req_valid_d1 <= rd_req_valid;
        rd_rsp_ctx      <= rd_req_ctx_d1;
        rd_rsp_valid    <= rd_req_valid_d1;
        rd_rsp_data     <= doutb;
    end

    bram_bar_zero4k i_bram_bar_fallback(
        .addra  ( wr_addr[11:2]     ),
        .clka   ( clk               ),
        .dina   ( wr_data           ),
        .ena    ( wr_valid          ),
        .wea    ( wr_be             ),
        .addrb  ( rd_req_addr[11:2] ),
        .clkb   ( clk               ),
        .doutb  ( doutb             ),
        .enb    ( rd_req_valid      )
    );

{{ end }}
endmodule
