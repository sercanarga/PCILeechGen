{{ end }}{{ end }}                default: begin
                    // unregistered offset - ignore write
                end
            endcase
        end
{{ if eq .DeviceClass "audio" }}
        // CORBCTL/CORBSTS - delayed RW1C handler (1 cycle after wr_valid)
        if (!rst && corbsts_rw1c) begin
            if (wr_be[0]) begin
                reg_0x0000004C[0] <= corbctl_wr_cmeie_val;
                reg_0x0000004C[1] <= corbctl_wr_run_val;
