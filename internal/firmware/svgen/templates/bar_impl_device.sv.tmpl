    // ========================================================================
    // Reset and Write Logic
    // ========================================================================

    always @(posedge clk) begin
        if (rst) begin
{{ range .BARModel.Registers }}{{ if not .IsFSMDriven }}            reg_0x{{ hex08 .Offset }} <= {{ mul .Width 8 }}'h{{ hex08 .Reset }};
{{ end }}{{ end }}        end
        else if (wr_valid) begin
