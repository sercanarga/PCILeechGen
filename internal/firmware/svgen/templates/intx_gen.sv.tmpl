//
// Legacy INTx interrupt generator for {{ hex04 .DeviceIDs.VendorID }}:{{ hex04 .DeviceIDs.DeviceID }}
// Auto-generated by PCILeechGen
//
// Converts a single-cycle intr_req pulse into a level-triggered legacy INTx
// assert/deassert sequence driven through the PCIe hard IP's cfg_interrupt
// interface. This mirrors the legacy INTx FSM used by real-device forks
// that need legacy line interrupts (e.g. Atheros ath9k AR9287, some audio
// controllers) where the driver binds to the INTx line and never enables MSI.
//
// Interface (driven into the board cfg module / Xilinx PCIe IP):
//   cfg_interrupt                 - interrupt request strobe
//   cfg_interrupt_assert          - 1 = Assert_INTx, 0 = Deassert_INTx
//   cfg_pciecap_interrupt_msgnum  - INTA(0)..INTD(3) line selector
//
// FSM: IDLE -> ASSERT (hold assert for ASSERT_TICKS) -> DEASSERT (hold
// deassert for DEASSERT_TICKS) -> IDLE. One intr_req pulse produces exactly
// one assert/deassert pair. A re-trigger during DEASSERT is latched so the
// next assert begins immediately after deassert completes (no lost IRQs).
//

`timescale 1ns / 1ps
`include "pcileech_header.svh"

module pcileech_intx_gen #(
    parameter [2:0] INTX_LINE        = 3'd0,  // 0=INTA,1=INTB,2=INTC,3=INTD
    parameter [7:0] ASSERT_TICKS     = 8'd4, // cycles to hold Assert_INTx
    parameter [7:0] DEASSERT_TICKS   = 8'd4  // cycles to hold Deassert_INTx
)(
    input                   clk,
    input                   rst,
    input                   intr_req,      // single-cycle request pulse
    output reg              cfg_interrupt,
    output reg              cfg_interrupt_assert,
    output reg  [2:0]       cfg_pciecap_interrupt_msgnum
);

    localparam [1:0]
        ST_IDLE      = 2'd0,
        ST_ASSERT    = 2'd1,
        ST_DEASSERT  = 2'd2;

    reg [1:0]  state;
    reg [7:0]  tick;
    reg       pending;   // latched re-trigger during assert/deassert

    always @(posedge clk) begin
        if (rst) begin
            state        <= ST_IDLE;
            tick         <= 8'd0;
            pending      <= 1'b0;
            cfg_interrupt        <= 1'b0;
            cfg_interrupt_assert <= 1'b0;
            cfg_pciecap_interrupt_msgnum <= 3'd0;
        end else begin
            // latch any request that arrives while we are busy
            if (intr_req && state != ST_IDLE)
                pending <= 1'b1;

            case (state)
                ST_IDLE: begin
                    cfg_interrupt        <= 1'b0;
                    cfg_interrupt_assert <= 1'b0;
                    if (intr_req || pending) begin
                        pending      <= 1'b0;
                        state        <= ST_ASSERT;
                        tick         <= 8'd0;
                        cfg_interrupt        <= 1'b1;
                        cfg_interrupt_assert <= 1'b1;
                        cfg_pciecap_interrupt_msgnum <= INTX_LINE;
                    end
                end

                ST_ASSERT: begin
                    cfg_interrupt        <= 1'b1;
                    cfg_interrupt_assert <= 1'b1;
                    cfg_pciecap_interrupt_msgnum <= INTX_LINE;
                    if (tick >= ASSERT_TICKS - 1) begin
                        state <= ST_DEASSERT;
                        tick  <= 8'd0;
                        cfg_interrupt_assert <= 1'b0; // Deassert_INTx
                    end else begin
                        tick <= tick + 8'd1;
                    end
                end

                ST_DEASSERT: begin
                    cfg_interrupt        <= 1'b1;
                    cfg_interrupt_assert <= 1'b0;
                    cfg_pciecap_interrupt_msgnum <= INTX_LINE;
                    if (tick >= DEASSERT_TICKS - 1) begin
                        state <= ST_IDLE;
                        tick  <= 8'd0;
                        cfg_interrupt        <= 1'b0;
                        cfg_interrupt_assert <= 1'b0;
                    end else begin
                        tick <= tick + 8'd1;
                    end
                end

                default: state <= ST_IDLE;
            endcase
        end
    end

endmodule