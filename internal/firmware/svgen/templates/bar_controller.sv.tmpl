        .rst                ( rst                           ),
        .clk                ( clk                           ),
        .cc_en              ( nvme_reg_cc[0]                ),
        .asq_lo             ( nvme_reg_asq_lo               ),
        .asq_hi             ( nvme_reg_asq_hi               ),
        .acq_lo             ( nvme_reg_acq_lo               ),
        .acq_hi             ( nvme_reg_acq_hi               ),
        .aqa                ( nvme_reg_aqa                  ),
        .sq0_doorbell_wr    ( nvme_sq0_db_wr                ),
        .sq0_doorbell_val   ( wr_data[15:0]                 ),
        .cq0_doorbell_wr    ( nvme_cq0_db_wr                ),
        .cq0_doorbell_val   ( wr_data[15:0]                 ),
        .dma_rd_req         ( nvme_dma_rd_req               ),
        .dma_rd_addr        ( nvme_dma_rd_addr              ),
        .dma_rd_len         ( nvme_dma_rd_len               ),
        .dma_rd_valid       ( nvme_dma_rd_valid             ),
        .dma_rd_data        ( nvme_dma_rd_data              ),
        .dma_rd_done        ( nvme_dma_rd_done              ),
        .dma_wr_req         ( nvme_dma_wr_req               ),
        .dma_wr_addr        ( nvme_dma_wr_addr              ),
        .dma_wr_data        ( nvme_dma_wr_data              ),
        .dma_wr_be          ( nvme_dma_wr_be                ),
        .dma_wr_valid       ( nvme_dma_wr_valid             ),
        .dma_wr_done        ( nvme_dma_wr_done              ),
        .msix_trigger       ( nvme_msix_trigger             ),
        .id_rom_addr        ( nvme_id_rom_addr              ),
        .id_rom_data        ( nvme_id_rom_data              )
    );

    // this guy does the real PCIe legwork
    pcileech_nvme_dma_bridge i_nvme_dma_bridge(
        .rst                ( rst                           ),
        .clk                ( clk                           ),
        .pcie_id            ( pcie_id                       ),
        .dma_wr_req         ( nvme_dma_wr_req               ),
        .dma_wr_addr        ( nvme_dma_wr_addr              ),
        .dma_wr_data        ( nvme_dma_wr_data              ),
        .dma_wr_be          ( nvme_dma_wr_be                ),
        .dma_wr_valid       ( nvme_dma_wr_valid             ),
        .dma_wr_done        ( nvme_dma_wr_done              ),
        .dma_rd_req         ( nvme_dma_rd_req               ),
        .dma_rd_addr        ( nvme_dma_rd_addr              ),
        .dma_rd_len         ( nvme_dma_rd_len               ),
        .dma_rd_valid       ( nvme_dma_rd_valid             ),
        .dma_rd_data        ( nvme_dma_rd_data              ),
        .dma_rd_done        ( nvme_dma_rd_done              ),
        .tlp_tx_tdata       ( nvme_tlp_tx_tdata             ),
        .tlp_tx_tkeepdw     ( nvme_tlp_tx_tkeepdw           ),
        .tlp_tx_tvalid      ( nvme_tlp_tx_tvalid            ),
        .tlp_tx_tlast       ( nvme_tlp_tx_tlast             ),
        .tlp_tx_tuser       ( nvme_tlp_tx_tuser             ),
        .tlp_rx_tdata       ( tlps_in.tdata                 ),
        .tlp_rx_tvalid      ( tlps_in.tvalid                ),
        .tlp_rx_tuser       ( tlps_in.tuser                 )
    );

    // identify data ROM – loaded from hex at synthesis, read with 1-cycle latency
    reg [31:0] nvme_identify_rom [0:2047];
    initial $readmemh("identify_init.hex", nvme_identify_rom);

    reg [31:0] nvme_id_rom_data_r;
    always @(posedge clk)
        nvme_id_rom_data_r <= nvme_identify_rom[nvme_id_rom_addr[12:2]];
    assign nvme_id_rom_data = nvme_id_rom_data_r;

    // mux DMA bridge TLPs with rdengine BAR responses onto tlps_out
    // bridge gets priority -- its MWr/MRd TLPs can't wait
    assign tlps_out.tdata    = nvme_tlp_tx_tvalid ? nvme_tlp_tx_tdata    : tlps_rdeng.tdata;
    assign tlps_out.tkeepdw  = nvme_tlp_tx_tvalid ? nvme_tlp_tx_tkeepdw  : tlps_rdeng.tkeepdw;
    assign tlps_out.tvalid   = nvme_tlp_tx_tvalid || tlps_rdeng.tvalid;
    assign tlps_out.tlast    = nvme_tlp_tx_tvalid ? nvme_tlp_tx_tlast    : tlps_rdeng.tlast;
    assign tlps_out.tuser    = nvme_tlp_tx_tvalid ? nvme_tlp_tx_tuser    : tlps_rdeng.tuser;
    assign tlps_out.has_data = nvme_tlp_tx_tvalid || tlps_rdeng.has_data;
    assign tlps_rdeng.tready = tlps_out.tready && !nvme_tlp_tx_tvalid;
{{ end }}

    // BAR1: address loopback
    pcileech_bar_impl_loopaddr i_bar1(
        .rst            ( rst                           ),
        .clk            ( clk                           ),
        .wr_addr        ( wr_addr                       ),
        .wr_be          ( wr_be                         ),
        .wr_data        ( wr_data                       ),
        .wr_valid       ( wr_valid && wr_bar[1]         ),
        .rd_req_ctx     ( rd_req_ctx                    ),
        .rd_req_addr    ( rd_req_addr                   ),
        .rd_req_valid   ( rd_req_valid && rd_req_bar[1] ),
        .rd_rsp_ctx     ( bar_rsp_ctx[1]                ),
        .rd_rsp_data    ( bar_rsp_data[1]               ),
        .rd_rsp_valid   ( bar_rsp_valid[1]              )
    );

    // BAR2-6: unimplemented
    genvar gi;
    generate
        for (gi = 2; gi < 7; gi = gi + 1) begin : gen_bar_none
            pcileech_bar_impl_none i_bar_none(
                .rst            ( rst                           ),
                .clk            ( clk                           ),
                .wr_addr        ( wr_addr                       ),
                .wr_be          ( wr_be                         ),
                .wr_data        ( wr_data                       ),
                .wr_valid       ( wr_valid && wr_bar[gi]        ),
                .rd_req_ctx     ( rd_req_ctx                    ),
                .rd_req_addr    ( rd_req_addr                   ),
                .rd_req_valid   ( rd_req_valid && rd_req_bar[gi]),
                .rd_rsp_ctx     ( bar_rsp_ctx[gi]               ),
                .rd_rsp_data    ( bar_rsp_data[gi]              ),
                .rd_rsp_valid   ( bar_rsp_valid[gi]             )
