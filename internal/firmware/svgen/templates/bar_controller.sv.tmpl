        .rsp_ctx        ( bar0_emu_ctx                  ),
        .rsp_data       ( bar0_emu_data                 ),
{{ end }}
        .rsp_ready      ( bar0_emu_ready                ),
        .wr_valid       ( wr_valid && wr_bar[0]         ),
        .wr_addr        ( wr_addr                       ),
        .wr_ack         ( bar0_wr_ack                   )
    );

    // 1-deep buffer FSM: captures BAR responses when emulator is busy
    always @(posedge clk) begin
        if (rst) begin
            bar0_buf_valid <= 1'b0;
        end else begin
            if (bar0_buf_write) begin
                bar0_buf_ctx  <= bar0_raw_ctx;
                bar0_buf_data <= bar0_raw_data;
                bar0_buf_valid <= 1'b1;
            end else if (bar0_buf_valid && bar0_emu_ready) begin
                bar0_buf_valid <= 1'b0;
            end
        end
    end

{{ end }}

