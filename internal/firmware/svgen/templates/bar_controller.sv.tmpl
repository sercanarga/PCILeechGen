{{ if and (eq .DeviceClass "nvme") .NVMeIdentify }}
    // NVMe admin responder + DMA bridge
    // - responder handles what the driver throws at us during init
    // - bridge turns those simple DMA ops into actual PCIe TLPs

    // catch doorbell writes -- offset derived from CAP.DSTRD
    wire nvme_sq0_db_wr = wr_valid && wr_bar[0] && (wr_addr[31:0] == 32'h{{ printf "%08X" .NVMeSQ0DoorbellOffset }});
    wire nvme_cq0_db_wr = wr_valid && wr_bar[0] && (wr_addr[31:0] == 32'h{{ printf "%08X" .NVMeCQ0DoorbellOffset }});

