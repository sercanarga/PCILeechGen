`timescale 1ns / 1ps
`include "pcileech_header.svh"

module pcileech_tlps128_bar_controller(
    input                   rst,
    input                   clk,
    input                   bar_en,
    input [15:0]            pcie_id,
    IfAXIS128.sink_lite     tlps_in,
    IfAXIS128.source        tlps_out,
    // HDA MSI interrupt — aggregated request from all BARs.
    // A single-cycle pulse that gets OR'd into cfg_interrupt by the
    // cfg module (pcileech_pcie_cfg_a7). Unused for non-HDA devices —
    // synthesis prunes it.
    output                  intr_req
);

    // TLP receive
    wire in_is_wr_ready;
    bit  in_is_wr_last;
    wire in_is_first    = tlps_in.tuser[0];
    wire in_is_bar      = bar_en && (tlps_in.tuser[8:2] != 0);
    wire in_is_rd       = (in_is_first && tlps_in.tlast && ((tlps_in.tdata[31:25] == 7'b0000000) || (tlps_in.tdata[31:25] == 7'b0010000) || (tlps_in.tdata[31:24] == 8'b00000010)));
    wire in_is_wr       = in_is_wr_last || (in_is_first && in_is_wr_ready && ((tlps_in.tdata[31:25] == 7'b0100000) || (tlps_in.tdata[31:25] == 7'b0110000) || (tlps_in.tdata[31:24] == 8'b01000010)));

    always @ ( posedge clk )
        if ( rst ) begin
            in_is_wr_last <= 0;
        end
        else if ( tlps_in.tvalid ) begin
            in_is_wr_last <= !tlps_in.tlast && in_is_wr;
        end

    wire [6:0]  wr_bar;
    wire [31:0] wr_addr;
    wire [3:0]  wr_be;
    wire [31:0] wr_data;
    wire        wr_valid;
    wire [87:0] rd_req_ctx;
    wire [6:0]  rd_req_bar;
    wire [31:0] rd_req_addr;
    wire        rd_req_valid;
    wire [87:0] rd_rsp_ctx;
    wire [31:0] rd_rsp_data;
    wire        rd_rsp_valid;

{{ if .BARModel }}
    localparam [31:0] BAR0_ADDR_MASK = 32'h{{ printf "%08X" (sub .BARModel.Size 1) }}; // BAR0 aperture mask (Bar0Size)
    wire [31:0] wr_addr_bar0     = wr_addr     & BAR0_ADDR_MASK;
    wire [31:0] rd_req_addr_bar0 = rd_req_addr & BAR0_ADDR_MASK;
{{ end }}

{{ if and (eq .DeviceClass "nvme") .NVMeIdentify }}
    // rdengine goes to an intermediate bus so we can mux in DMA bridge TLPs
    IfAXIS128 tlps_rdeng();

    pcileech_tlps128_bar_rdengine i_pcileech_tlps128_bar_rdengine(
        .rst            ( rst                           ),
        .clk            ( clk                           ),
        .pcie_id        ( pcie_id                       ),
        .tlps_in        ( tlps_in                       ),
        .tlps_in_valid  ( tlps_in.tvalid && in_is_bar && in_is_rd ),
        .tlps_out       ( tlps_rdeng.source             ),
        .rd_req_ctx     ( rd_req_ctx                    ),
        .rd_req_bar     ( rd_req_bar                    ),
        .rd_req_addr    ( rd_req_addr                   ),
        .rd_req_valid   ( rd_req_valid                  ),
        .rd_rsp_ctx     ( rd_rsp_ctx                    ),
        .rd_rsp_data    ( rd_rsp_data                   ),
        .rd_rsp_valid   ( rd_rsp_valid                  )
    );
{{ else }}
    // rdengine output goes to intermediate for DMA bridge TLP muxing
    IfAXIS128 tlps_rdeng();

    pcileech_tlps128_bar_rdengine i_pcileech_tlps128_bar_rdengine(
        .rst            ( rst                           ),
        .clk            ( clk                           ),
        .pcie_id        ( pcie_id                       ),
        .tlps_in        ( tlps_in                       ),
        .tlps_in_valid  ( tlps_in.tvalid && in_is_bar && in_is_rd ),
        .tlps_out       ( tlps_rdeng.source             ),
        .rd_req_ctx     ( rd_req_ctx                    ),
        .rd_req_bar     ( rd_req_bar                    ),
        .rd_req_addr    ( rd_req_addr                   ),
        .rd_req_valid   ( rd_req_valid                  ),
        .rd_rsp_ctx     ( rd_rsp_ctx                    ),
        .rd_rsp_data    ( rd_rsp_data                   ),
        .rd_rsp_valid   ( rd_rsp_valid                  )
    );
{{ end }}

    pcileech_tlps128_bar_wrengine i_pcileech_tlps128_bar_wrengine(
        .rst            ( rst                           ),
        .clk            ( clk                           ),
        .tlps_in        ( tlps_in                       ),
        .tlps_in_valid  ( tlps_in.tvalid && in_is_bar && in_is_wr ),
        .tlps_in_ready  ( wrengine_ready                ),
        .wr_bar         ( wr_bar                        ),
        .wr_addr        ( wr_addr                       ),
        .wr_be          ( wr_be                         ),
        .wr_data        ( wr_data                       ),
        .wr_valid       ( wr_valid                      )
    );

{{ if .LatencyConfig }}
{{ if eq .DeviceClass "nvme" }}
    // The incoming PCIe RX stream has no backpressure at this layer. Gating
    // writes on emulated latency would drop MMIO writes such as AQA/ASQ/ACQ/CC
    // during the controller-enable handshake. bar0_wr_ack is still driven by the
    // latency emulator but no longer gates write acceptance.
    wire        bar0_wr_ack;
    wire        wrengine_ready;
    assign in_is_wr_ready = wrengine_ready;
{{ else }}
    // Write backpressure: combine wrengine ready with BAR0 write latency ack.
    // New writes are blocked until the previous BAR0 write's emulated latency completes.
    wire        bar0_wr_ack;
    wire        wrengine_ready;
    assign in_is_wr_ready = wrengine_ready && bar0_wr_ack;
{{ end }}
{{ if not (eq .DeviceClass "audio") }}
    // Non-HDA builds have no CRST reset source; tie inert so the latency
    // emulator / spill reset arms never fire. Declared here because the latency
    // FSM below references it unconditionally (HDA builds declare a real wire
    // driven by the RIRB DMA bridge further down).
    wire        hda_crst_falling = 1'b0;
{{ end }}
{{ else }}
    wire        wrengine_ready;
    assign in_is_wr_ready = wrengine_ready;
{{ end }}

{{ if .LatencyConfig }}
    // BAR0 raw response wires (before latency emulation)
    wire [87:0] bar0_raw_ctx;
    wire [31:0] bar0_raw_data;
    wire        bar0_raw_valid;

    // latency emulated response
    wire [87:0] bar0_emu_ctx;
    wire [31:0] bar0_emu_data;
    wire        bar0_emu_valid;
    wire        bar0_emu_busy; // from latency emulator: request_pending
    wire        bar0_emu_ready = !bar0_emu_busy; // 1 when emulator can accept new data
    reg         bar0_emu_busy_d1; // delayed busy for edge detection
    wire        bar0_emu_accepted = bar0_emu_busy && !bar0_emu_busy_d1; // 0->1 edge = data taken

    // 16-deep circular buffer between BAR engine and latency emulator.
    // Always captures BAR responses on bar0_raw_valid (1-cycle pulse).
    // The latency emulator processes one request at a time; the 16-deep
    // buffer absorbs back-to-back BAR responses from multi-DWORD reads.
    //
    // Sizing: the BAR produces responses at 1/cycle (pipelined 2-cycle latency).
    // The emulator drains at 1 per MIN_LATENCY cycles (default MIN=2, drain=0.5/cycle).
    // Net fill rate = 0.5 entries/cycle. For a max 32-DWORD BAR read (128 bytes),
    // the worst-case peak is 16 entries — hence 16-deep.
    //
    // AXI-style handshake:
    //   Push: bar0_raw_valid && !full  (unconditional capture)
    //   Pop:  bar0_emu_accepted        (emulator went idle->busy = took data)
    //
    // Address capture: rd_req_addr is a live signal that increments every
    // cycle during multi-DWORD reads. By the time the BAR produces a response
    // (2-cycle latency), rd_req_addr has advanced. We reconstruct the correct
    // address from rd_req_ctx which contains {first, last, data[31:12], dwaddr}
    // set by the rdengine at request time.
    reg  [87:0] bar0_buf_ctx  [0:15];
    reg  [31:0] bar0_buf_data [0:15];
    reg  [31:0] bar0_buf_addr [0:15]; // reconstructed request address from ctx
    reg  [4:0]  bar0_buf_count;   // number of entries (0-16)
    reg  [3:0]  bar0_buf_rd;      // read pointer
    reg  [3:0]  bar0_buf_wr;      // write pointer
    wire        bar0_buf_full  = (bar0_buf_count >= 5'd16);
    wire        bar0_buf_empty = (bar0_buf_count == 5'd0);
    wire [87:0] bar0_buf_ctx_w   = bar0_buf_ctx[bar0_buf_rd];
    wire [31:0] bar0_buf_data_w  = bar0_buf_data[bar0_buf_rd];
    wire [31:0] bar0_buf_addr_w  = bar0_buf_addr[bar0_buf_rd]; // address from buffer head
    // bar0_buf_write defined in spill section below (line 199)
    wire        bar0_buf_pop     = bar0_emu_accepted && !bar0_buf_empty;
    // Reconstruct address from ctx: {first[87], last[86], data[31:12]..}
    wire [31:0] bar0_req_addr_from_ctx = {bar0_raw_ctx[31:12], bar0_raw_ctx[11:2], 2'b00};

    // Buffer overflow retry: when the buffer is full, hold the response in
    // a spill register and retry on the next cycle. Prevents silent data loss
    // during sustained multi-DWORD reads when the latency emulator can't drain
    // fast enough (e.g., during HDA DMA backpressure).
    //
    // CRITICAL: spill drains BEFORE accepting new data. Without this, when
    // buffer stays full across multiple cycles, each new response overwrites
    // the spill and permanently loses the previous one.
    reg         bar0_spill_valid;
    reg  [87:0] bar0_spill_ctx;
    reg  [31:0] bar0_spill_data;

    always @(posedge clk) begin
        if (rst) begin
            bar0_spill_valid <= 1'b0;
            bar0_spill_ctx   <= 88'h0;
            bar0_spill_data  <= 32'h0;
        end else if (hda_crst_falling) begin
            // CRST soft reset: clear spill register.
            // Old spill data would otherwise be injected into the cleared buffer.
            bar0_spill_valid <= 1'b0;
            bar0_spill_ctx   <= 88'h0;
            bar0_spill_data  <= 32'h0;
        end else if (bar0_spill_valid && !bar0_buf_full) begin
            // Drain spill to buffer — takes priority over new data
            bar0_spill_valid <= 1'b0;
        end else if (!bar0_spill_valid && bar0_raw_valid && bar0_buf_full) begin
            // Only capture new response in spill when spill slot is empty.
            // If spill is already valid and buffer is full, the new response
            // is dropped (buffer will drain soon and spill will retry).
            bar0_spill_valid <= 1'b1;
            bar0_spill_ctx   <= bar0_raw_ctx;
            bar0_spill_data  <= bar0_raw_data;
        end
    end

    // Push to buffer: either new response or retry from spill.
    // Spill drain takes priority — new data is only accepted when spill is empty.
    wire bar0_buf_write = (bar0_spill_valid && !bar0_buf_full) ||
                          (!bar0_spill_valid && bar0_raw_valid && !bar0_buf_full);
{{ end }}
{{ if .MSIXConfig }}
    // MSI-X intermediate wires
    wire [87:0] bar0_base_ctx;
    wire [31:0] bar0_base_data;
    wire        bar0_base_valid;

    wire [87:0] msix_rsp_ctx;
    wire [31:0] msix_rsp_data;
    wire        msix_rsp_valid;
    wire        msix_addr_hit;
{{ if eq .DeviceClass "nvme" }}
    wire [63:0] msix_vector0_addr;
    wire [31:0] msix_vector0_data;
    wire        msix_vector0_masked;
{{ end }}
{{ if and (eq .DeviceClass "nvme") .LatencyConfig }}
    // NVMe BAR0 registers are used in tight polling loops during controller
    // enable (CC.EN -> CSTS.RDY). Return those MMIO completions directly; the
    // artificial latency FIFO may otherwise hold stale CSTS=0 reads long enough
    // for stornvme to fail ControllerEnable.
    assign bar0_base_ctx   = bar0_raw_ctx;
    assign bar0_base_data  = bar0_raw_data;
    assign bar0_base_valid = bar0_raw_valid;
{{ end }}
{{ end }}

    wire [87:0] bar_rsp_ctx[7];
    wire [31:0] bar_rsp_data[7];
    wire        bar_rsp_valid[7];

{{ if and (eq .DeviceClass "nvme") .NVMeIdentify }}
    wire [31:0] nvme_debug_status;
    wire [31:0] nvme_debug_last_cmd;
    wire [31:0] nvme_debug_last_nsid;
    wire [31:0] nvme_debug_last_cdw10;
    wire [31:0] nvme_debug_queue_state;
{{ end }}
{{ if and (eq .DeviceClass "nvme") .NVMeIdentify .BARModel }}
    // Diagnostic registers are read-only and sit immediately after all four
    // admin + IO queue doorbells (SQ0/CQ0/SQ1/CQ1), using the same DSTRD spacing.
    wire        nvme_diag_addr_hit = rd_req_valid && rd_req_bar[0] &&
                                     (rd_req_addr_bar0 >= 32'h{{ printf "%08X" .NVMeDiagBaseOffset }}) &&
                                     (rd_req_addr_bar0 <= 32'h{{ printf "%08X" .NVMeDiagQueueStateOffset }});
    wire        nvme_diag_wr_addr_hit = wr_valid && wr_bar[0] &&
                                        (wr_addr_bar0 >= 32'h{{ printf "%08X" .NVMeDiagBaseOffset }}) &&
                                        (wr_addr_bar0 <= 32'h{{ printf "%08X" .NVMeDiagQueueStateOffset }});
    wire [87:0] nvme_diag_ctx   = rd_req_ctx;
    wire        nvme_diag_valid = nvme_diag_addr_hit;
    reg  [31:0] nvme_diag_data;

    always @(*) begin
        case (rd_req_addr_bar0)
            32'h{{ printf "%08X" .NVMeDiagBaseOffset }}: nvme_diag_data = nvme_debug_status;
            32'h{{ printf "%08X" .NVMeDiagLastCommandOffset }}: nvme_diag_data = nvme_debug_last_cmd;
            32'h{{ printf "%08X" .NVMeDiagLastNSIDOffset }}: nvme_diag_data = nvme_debug_last_nsid;
            32'h{{ printf "%08X" .NVMeDiagLastCDW10Offset }}: nvme_diag_data = nvme_debug_last_cdw10;
            32'h{{ printf "%08X" .NVMeDiagQueueStateOffset }}: nvme_diag_data = nvme_debug_queue_state;
            default: nvme_diag_data = 32'h0;
        endcase
    end
{{ end }}

{{ if and .LatencyConfig .MSIXConfig }}
    // latency -> MSI-X mux -> bar_rsp[0]
{{ if and (eq .DeviceClass "nvme") .NVMeIdentify .BARModel }}
    assign bar_rsp_ctx[0]   = nvme_diag_valid ? nvme_diag_ctx :
                              msix_rsp_valid ? msix_rsp_ctx   : bar0_base_ctx;
    assign bar_rsp_data[0]  = nvme_diag_valid ? nvme_diag_data :
                              msix_rsp_valid ? msix_rsp_data  : bar0_base_data;
    assign bar_rsp_valid[0] = nvme_diag_valid || msix_rsp_valid || bar0_base_valid;
{{ else }}
    assign bar_rsp_ctx[0]   = msix_rsp_valid ? msix_rsp_ctx   : bar0_base_ctx;
    assign bar_rsp_data[0]  = msix_rsp_valid ? msix_rsp_data  : bar0_base_data;
    assign bar_rsp_valid[0] = msix_rsp_valid || bar0_base_valid;
{{ end }}
{{ else if .LatencyConfig }}
{{ if and (eq .DeviceClass "nvme") .NVMeIdentify .BARModel }}
    assign bar_rsp_ctx[0]   = nvme_diag_valid ? nvme_diag_ctx : bar0_emu_ctx;
    assign bar_rsp_data[0]  = nvme_diag_valid ? nvme_diag_data : bar0_emu_data;
    assign bar_rsp_valid[0] = nvme_diag_valid || bar0_emu_valid;
{{ else }}
    assign bar_rsp_ctx[0]   = bar0_emu_ctx;
    assign bar_rsp_data[0]  = bar0_emu_data;
    assign bar_rsp_valid[0] = bar0_emu_valid;
{{ end }}
{{ else if .MSIXConfig }}
    // MSI-X mux -> bar_rsp[0]
{{ if and (eq .DeviceClass "nvme") .NVMeIdentify .BARModel }}
    assign bar_rsp_ctx[0]   = nvme_diag_valid ? nvme_diag_ctx :
                              msix_rsp_valid ? msix_rsp_ctx   : bar0_base_ctx;
    assign bar_rsp_data[0]  = nvme_diag_valid ? nvme_diag_data :
                              msix_rsp_valid ? msix_rsp_data  : bar0_base_data;
    assign bar_rsp_valid[0] = nvme_diag_valid || msix_rsp_valid || bar0_base_valid;
{{ else }}
    assign bar_rsp_ctx[0]   = msix_rsp_valid ? msix_rsp_ctx   : bar0_base_ctx;
    assign bar_rsp_data[0]  = msix_rsp_valid ? msix_rsp_data  : bar0_base_data;
    assign bar_rsp_valid[0] = msix_rsp_valid || bar0_base_valid;
{{ end }}
{{ else }}
    // Neither latency nor MSI-X config — direct BAR0 passthrough.
{{ if and (eq .DeviceClass "nvme") .NVMeIdentify .BARModel }}
    wire [87:0] bar0_direct_ctx;
    wire [31:0] bar0_direct_data;
    wire        bar0_direct_valid;
    assign bar_rsp_ctx[0]   = nvme_diag_valid ? nvme_diag_ctx  : bar0_direct_ctx;
    assign bar_rsp_data[0]  = nvme_diag_valid ? nvme_diag_data : bar0_direct_data;
    assign bar_rsp_valid[0] = nvme_diag_valid || bar0_direct_valid;
{{ else }}
    assign bar_rsp_ctx[0]   = 0;
    assign bar_rsp_data[0]  = 32'h0;
    assign bar_rsp_valid[0] = 1'b0;
{{ end }}
{{ end }}

    // response mux
    assign rd_rsp_ctx = bar_rsp_valid[0] ? bar_rsp_ctx[0] :
                        bar_rsp_valid[1] ? bar_rsp_ctx[1] :
                        bar_rsp_valid[2] ? bar_rsp_ctx[2] :
                        bar_rsp_valid[3] ? bar_rsp_ctx[3] :
                        bar_rsp_valid[4] ? bar_rsp_ctx[4] :
                        bar_rsp_valid[5] ? bar_rsp_ctx[5] :
                        bar_rsp_valid[6] ? bar_rsp_ctx[6] : 0;
    assign rd_rsp_data = bar_rsp_valid[0] ? bar_rsp_data[0] :
                        bar_rsp_valid[1] ? bar_rsp_data[1] :
                        bar_rsp_valid[2] ? bar_rsp_data[2] :
                        bar_rsp_valid[3] ? bar_rsp_data[3] :
                        bar_rsp_valid[4] ? bar_rsp_data[4] :
                        bar_rsp_valid[5] ? bar_rsp_data[5] :
                        bar_rsp_valid[6] ? bar_rsp_data[6] : 0;
    assign rd_rsp_valid = bar_rsp_valid[0] || bar_rsp_valid[1] || bar_rsp_valid[2] || bar_rsp_valid[3] || bar_rsp_valid[4] || bar_rsp_valid[5] || bar_rsp_valid[6];

    // BAR0: {{ if .BARModel }}device-specific{{ else }}generic zerowrite4k{{ end }}

{{ if and (eq .DeviceClass "nvme") .BARModel }}
    // NVMe register wires -- from bar_impl_device to admin responder
    wire [31:0] nvme_reg_cc;
    wire [31:0] nvme_reg_aqa;
    wire [31:0] nvme_reg_asq_lo;
    wire [31:0] nvme_reg_asq_hi;
    wire [31:0] nvme_reg_acq_lo;
    wire [31:0] nvme_reg_acq_hi;
    wire [31:0] nvme_reg_csts;
{{ end }}

{{ if .BARModel }}
    pcileech_bar_impl_device #(
        .BAR_SIZE       ( {{ .BARModel.Size }} ) // var Bar0Size
    ) i_bar0(
{{ else }}
    pcileech_bar_impl_zerowrite4k i_bar0(
{{ end }}
        .rst            ( rst                           ),
        .clk            ( clk                           ),
        .wr_addr        ( {{ if .BARModel }}wr_addr_bar0{{ else }}wr_addr{{ end }}                       ),
        .wr_be          ( wr_be                         ),
        .wr_data        ( wr_data                       ),
        .wr_valid       ( wr_valid && wr_bar[0]{{ if and (eq .DeviceClass "nvme") .NVMeIdentify .BARModel }} && !nvme_diag_wr_addr_hit{{ end }} ),
        .rd_req_ctx     ( rd_req_ctx                    ),
        .rd_req_addr    ( {{ if .BARModel }}rd_req_addr_bar0{{ else }}rd_req_addr{{ end }}                   ),
        .rd_req_valid   ( rd_req_valid && rd_req_bar[0]{{ if .MSIXConfig }} && !msix_addr_hit{{ end }}{{ if and (eq .DeviceClass "nvme") .NVMeIdentify .BARModel }} && !nvme_diag_addr_hit{{ end }} ),
{{ if .LatencyConfig }}
        .rd_rsp_ctx     ( bar0_raw_ctx                  ),
        .rd_rsp_data    ( bar0_raw_data                 ),
        .rd_rsp_valid   ( bar0_raw_valid                )
{{ else if .MSIXConfig }}
        .rd_rsp_ctx     ( bar0_base_ctx                 ),
        .rd_rsp_data    ( bar0_base_data                ),
        .rd_rsp_valid   ( bar0_base_valid               )
{{ else }}
{{ if and (eq .DeviceClass "nvme") .NVMeIdentify .BARModel }}
        .rd_rsp_ctx     ( bar0_direct_ctx               ),
        .rd_rsp_data    ( bar0_direct_data              ),
