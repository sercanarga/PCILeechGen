{{ end }}
{{ if and (eq .DeviceClass "nvme") .BARModel }}        ,
        .nvme_cc        ( nvme_reg_cc                   ),
        .nvme_aqa       ( nvme_reg_aqa                  ),
        .nvme_asq_lo    ( nvme_reg_asq_lo               ),
        .nvme_asq_hi    ( nvme_reg_asq_hi               ),
        .nvme_acq_lo    ( nvme_reg_acq_lo               ),
        .nvme_acq_hi    ( nvme_reg_acq_hi               )
{{ end }}{{ if and (eq .DeviceClass "audio") .BARModel }}        ,
        // HDA RIRB DMA bridge ports
        .dma_req_valid   ( hda_dma_req_valid             ),
        .dma_resp_lo     ( hda_dma_resp_lo               ),
        .dma_resp_hi     ( hda_dma_resp_hi               ),
        .dma_resp_wp     ( hda_dma_resp_wp               ),
        .dma_rirb_lbase  ( hda_dma_rirb_lbase            ),
        .dma_rirb_ubase  ( hda_dma_rirb_ubase            ),
        .dma_req_ready   ( hda_dma_req_ready             ),
        .dma_done        ( hda_dma_done                  )
{{ end }}
    );

{{ if .LatencyConfig }}
    tlp_latency_emulator i_latency_emu(
        .clk            ( clk                           ),
        .rst            ( rst                           ),
        .req_valid      ( !bar0_buf_empty               ), // data available in buffer
        .req_ctx        ( bar0_buf_ctx_w                ), // read from buffer head
        .req_data       ( bar0_buf_data_w               ),
        .req_addr       ( bar0_buf_addr_w               ), // address from buffered request head
        .req_ready      (                               ),
{{ if .MSIXConfig }}
        .rsp_valid      ( bar0_base_valid               ),
        .rsp_ctx        ( bar0_base_ctx                 ),
        .rsp_data       ( bar0_base_data                ),
{{ else }}
        .rsp_valid      ( bar0_emu_valid                ),
        .rsp_ctx        ( bar0_emu_ctx                  ),
        .rsp_data       ( bar0_emu_data                 ),
{{ end }}
        .rsp_ready      ( bar0_emu_ready                ),
        .wr_valid       ( wr_valid && wr_bar[0]         ),
        .wr_addr        ( wr_addr                       ),
        .wr_ack         ( bar0_wr_ack                   ),
        .busy           ( bar0_emu_busy                 )
    );

    // 16-deep circular buffer FSM:
    // Push: on bar0_raw_valid, push to write slot if not full.
    // Pop:  when emulator goes idle->busy (bar0_emu_accepted), it took the head data.
    // Both push and pop can happen in the same cycle (count adjusts correctly).
    always @(posedge clk) begin
        if (rst) begin
            bar0_buf_count     <= 3'd0;
            bar0_buf_rd        <= 2'd0;
            bar0_buf_wr        <= 2'd0;
            bar0_emu_busy_d1   <= 1'b0;
        end else begin
            bar0_emu_busy_d1 <= bar0_emu_busy;

            // Pop head when emulator accepted (idle->busy transition = took head data)
            if (bar0_buf_pop) begin
                bar0_buf_rd <= bar0_buf_rd + 2'd1;
                bar0_buf_count <= bar0_buf_count - 3'd1;
            end

            // Push tail on new BAR response
            if (bar0_buf_write) begin
                bar0_buf_ctx[bar0_buf_wr]  <= bar0_raw_ctx;
                bar0_buf_data[bar0_buf_wr] <= bar0_raw_data;
                bar0_buf_addr[bar0_buf_wr] <= bar0_req_addr_from_ctx; // reconstruct address from ctx
                bar0_buf_wr <= bar0_buf_wr + 2'd1;
                bar0_buf_count <= bar0_buf_count + 3'd1;
            end
        end
    end

{{ end }}

