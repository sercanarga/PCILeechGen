{{ if and (eq .DeviceClass "audio") .BARModel }}
    // ========================================================================
    // HDA RIRB DMA Bridge
    // Writes fake RIRB responses to system memory so hdaudio.sys can read
    // codec responses. Without this, responses only go to MMIO registers
    // that the driver never reads.
    // ========================================================================
    wire        hda_dma_req_valid;
    wire [31:0] hda_dma_resp_lo;
    wire [31:0] hda_dma_resp_hi;
    wire [7:0]  hda_dma_resp_wp;
    wire [31:0] hda_dma_rirb_lbase;
    wire [31:0] hda_dma_rirb_ubase;
    wire        hda_dma_req_ready;
    wire        hda_dma_done;
    wire        hda_crst_falling;

    wire [127:0] hda_tlp_tx_tdata;
    wire [3:0]   hda_tlp_tx_tkeepdw;
    wire         hda_tlp_tx_tvalid;
    wire         hda_tlp_tx_tlast;
    wire [8:0]   hda_tlp_tx_tuser;

    pcileech_hda_rirb_dma i_hda_rirb_dma(
        .rst            ( rst                           ),
        .clk            ( clk                           ),
        .pcie_id        ( pcie_id                       ),
        .crst_falling   ( hda_crst_falling              ),
        .dma_req_valid  ( hda_dma_req_valid             ),
        .dma_req_lo     ( hda_dma_resp_lo               ),
        .dma_req_hi     ( hda_dma_resp_hi               ),
        .dma_req_wp     ( hda_dma_resp_wp               ),
        .dma_req_ready  ( hda_dma_req_ready             ),
        .rirb_lbase     ( hda_dma_rirb_lbase            ),
        .rirb_ubase     ( hda_dma_rirb_ubase            ),
        .dma_done       ( hda_dma_done                  ),
        .tlp_tx_tdata   ( hda_tlp_tx_tdata              ),
        .tlp_tx_tkeepdw ( hda_tlp_tx_tkeepdw            ),
        .tlp_tx_tvalid  ( hda_tlp_tx_tvalid             ),
        .tlp_tx_tlast   ( hda_tlp_tx_tlast              ),
        .tlp_tx_tuser   ( hda_tlp_tx_tuser              ),
        .tlp_tx_tready  ( tlps_out.tready && !dma_yield  )
    );

    // ========================================================================
    // HDA MSI Interrupt Generator
    // Fires an intr_req pulse when RIRBINTSTS.INTFL transitions 0->1.
    // The cfg module routes this to cfg_interrupt for MSI TLP generation —
    // without MSI, the hdaudio.sys driver polls RIRBWP endlessly and
    // eventually times out with Code 10.
    // ========================================================================
    wire        hda_msi_trigger;
    wire [31:0] hda_rirbintsts;
    wire        hda_intr_req;

    pcileech_hda_msi i_hda_msi(
        .rst            ( rst                           ),
        .clk            ( clk                           ),
        .pcie_id        ( pcie_id                       ),
        .msi_trigger    ( hda_msi_trigger               ),
        .rirbintsts     ( hda_rirbintsts                ),
        .crst_falling   ( hda_crst_falling              ),
        .intr_req       ( hda_intr_req                  )
    );

{{ end }}

{{ if eq .DeviceClass "nvme" }}
    // nvme_msix_trigger wired into intr_req OR for NVMe (driven by responder when NVMeIdentify present)
    wire        nvme_msix_trigger;
    // MSI-X enable/function-mask originate in PCIe config space
    // (cfg_interrupt_msixenable / cfg_interrupt_msixfm in pcileech_pcie_cfg_a7)
    // and are not routed to this controller's port list across board variants.
    // Static-tie to enabled/unmasked: the device always wants admin-completion
    // interrupts, and per-vector masking is still honoured via
    // msix_vector0_masked sourced from the MSI-X table.
    wire        msix_enable        = 1'b1;
    wire        msix_function_mask = 1'b0;
{{ end }}
{{ if and (eq .DeviceClass "nvme") .NVMeIdentify }}
    // NVMe admin responder + DMA bridge
    // - responder handles what the driver throws at us during init
    // - bridge turns those simple DMA ops into actual PCIe TLPs

    // Stub HDA TLP signals — unused in NVME-only builds but referenced
    // by the TLP mux below. In HDA+NVME builds, real signals override these.
{{ if not (eq .DeviceClass "audio") }}    wire        hda_tlp_tx_tvalid = 1'b0;
    wire [127:0] hda_tlp_tx_tdata = 128'h0;
    wire [3:0]   hda_tlp_tx_tkeepdw = 4'h0;
    wire         hda_tlp_tx_tlast = 1'b0;
    wire [8:0]   hda_tlp_tx_tuser = 9'h0;
{{ end }}

    // catch doorbell writes -- offset derived from CAP.DSTRD + computed from (variable) Bar0Size
    wire nvme_sq0_db_wr = wr_valid && wr_bar[0] && (wr_addr_bar0 == 32'h{{ printf "%08X" .NVMeSQ0DoorbellOffset }});
    wire nvme_cq0_db_wr = wr_valid && wr_bar[0] && (wr_addr_bar0 == 32'h{{ printf "%08X" .NVMeCQ0DoorbellOffset }});
    wire nvme_sq1_db_wr = wr_valid && wr_bar[0] && (wr_addr_bar0 == 32'h{{ printf "%08X" .NVMeSQ1DoorbellOffset }});
    wire nvme_cq1_db_wr = wr_valid && wr_bar[0] && (wr_addr_bar0 == 32'h{{ printf "%08X" .NVMeCQ1DoorbellOffset }});

    // plumbing between the responder and the DMA bridge
    wire        nvme_dma_rd_req;
    wire [63:0] nvme_dma_rd_addr;
    wire [9:0]  nvme_dma_rd_len;
    wire        nvme_dma_rd_valid;
    wire [31:0] nvme_dma_rd_data;
    wire        nvme_dma_rd_done;
    wire        nvme_dma_wr_req;
    wire [63:0] nvme_dma_wr_addr;
    wire [31:0] nvme_dma_wr_data;
    wire [3:0]  nvme_dma_wr_be;
    wire        nvme_dma_wr_valid;
    wire        nvme_dma_wr_done;
    // nvme_msix_trigger declared at module scope for NVMe (see wiring below)

    wire [12:0] nvme_id_rom_addr;
    wire [31:0] nvme_id_rom_data;

    // TLP wires coming out of the DMA bridge
    wire [127:0] nvme_tlp_tx_tdata;
    wire [3:0]   nvme_tlp_tx_tkeepdw;
    wire         nvme_tlp_tx_tvalid;
    wire         nvme_tlp_tx_tlast;
    wire [8:0]   nvme_tlp_tx_tuser;
    wire         nvme_tlp_tx_tready;

    pcileech_nvme_admin_responder i_nvme_responder(
        .rst                ( rst                           ),
        .clk                ( clk                           ),
        .cc_en              ( nvme_reg_cc[0]                ),
        .asq_lo             ( nvme_reg_asq_lo               ),
        .asq_hi             ( nvme_reg_asq_hi               ),
        .acq_lo             ( nvme_reg_acq_lo               ),
        .acq_hi             ( nvme_reg_acq_hi               ),
        .aqa                ( nvme_reg_aqa                  ),
        .sq0_doorbell_wr    ( nvme_sq0_db_wr                ),
        .sq0_doorbell_val   ( wr_data[15:0]                 ),
        .cq0_doorbell_wr    ( nvme_cq0_db_wr                ),
        .cq0_doorbell_val   ( wr_data[15:0]                 ),
        .sq1_doorbell_wr    ( nvme_sq1_db_wr                ),
        .sq1_doorbell_val   ( wr_data[15:0]                 ),
        .cq1_doorbell_wr    ( nvme_cq1_db_wr                ),
        .cq1_doorbell_val   ( wr_data[15:0]                 ),
        .msix_enable        ( msix_enable                   ),
        .msix_function_mask ( msix_function_mask            ),
        .msix_vector0_addr  ( msix_vector0_addr             ),
        .msix_vector0_data  ( msix_vector0_data             ),
        .msix_vector0_masked( msix_vector0_masked           ),
        .dma_rd_req         ( nvme_dma_rd_req               ),
        .dma_rd_addr        ( nvme_dma_rd_addr              ),
        .dma_rd_len         ( nvme_dma_rd_len               ),
        .dma_rd_valid       ( nvme_dma_rd_valid             ),
        .dma_rd_data        ( nvme_dma_rd_data              ),
        .dma_rd_done        ( nvme_dma_rd_done              ),
        .dma_wr_req         ( nvme_dma_wr_req               ),
        .dma_wr_addr        ( nvme_dma_wr_addr              ),
        .dma_wr_data        ( nvme_dma_wr_data              ),
        .dma_wr_be          ( nvme_dma_wr_be                ),
        .dma_wr_valid       ( nvme_dma_wr_valid             ),
        .dma_wr_done        ( nvme_dma_wr_done              ),
        .msix_trigger       ( nvme_msix_trigger             ),
        .id_rom_addr        ( nvme_id_rom_addr              ),
        .id_rom_data        ( nvme_id_rom_data              ),
        .debug_status       ( nvme_debug_status             ),
        .debug_last_cmd     ( nvme_debug_last_cmd           ),
        .debug_last_nsid    ( nvme_debug_last_nsid          ),
        .debug_last_cdw10   ( nvme_debug_last_cdw10         ),
        .debug_queue_state  ( nvme_debug_queue_state        )
    );

    // this guy does the real PCIe legwork
    pcileech_nvme_dma_bridge i_nvme_dma_bridge(
        .rst                ( rst                           ),
        .clk                ( clk                           ),
        .pcie_id            ( pcie_id                       ),
        .dma_wr_req         ( nvme_dma_wr_req               ),
        .dma_wr_addr        ( nvme_dma_wr_addr              ),
        .dma_wr_data        ( nvme_dma_wr_data              ),
        .dma_wr_be          ( nvme_dma_wr_be                ),
        .dma_wr_valid       ( nvme_dma_wr_valid             ),
        .dma_wr_done        ( nvme_dma_wr_done              ),
        .dma_rd_req         ( nvme_dma_rd_req               ),
        .dma_rd_addr        ( nvme_dma_rd_addr              ),
        .dma_rd_len         ( nvme_dma_rd_len               ),
        .dma_rd_valid       ( nvme_dma_rd_valid             ),
        .dma_rd_data        ( nvme_dma_rd_data              ),
        .dma_rd_done        ( nvme_dma_rd_done              ),
        .tlp_tx_tdata       ( nvme_tlp_tx_tdata             ),
        .tlp_tx_tkeepdw     ( nvme_tlp_tx_tkeepdw           ),
        .tlp_tx_tvalid      ( nvme_tlp_tx_tvalid            ),
        .tlp_tx_tlast       ( nvme_tlp_tx_tlast             ),
        .tlp_tx_tuser       ( nvme_tlp_tx_tuser             ),
        .tlp_tx_tready      ( nvme_tlp_tx_tready            ),
        .tlp_rx_tdata       ( tlps_in.tdata                 ),
        .tlp_rx_tkeepdw     ( tlps_in.tkeepdw               ),
        .tlp_rx_tvalid      ( tlps_in.tvalid                ),
        .tlp_rx_tuser       ( tlps_in.tuser                 )
    );

    // identify data ROM – loaded from hex at synthesis, read with 1-cycle latency
    reg [31:0] nvme_identify_rom [0:2047];
    initial $readmemh("identify_init.hex", nvme_identify_rom);

    reg [31:0] nvme_id_rom_data_r;
    always @(posedge clk)
        nvme_id_rom_data_r <= nvme_identify_rom[nvme_id_rom_addr[12:2]];
    assign nvme_id_rom_data = nvme_id_rom_data_r;

    // mux DMA bridge TLPs with rdengine BAR responses onto tlps_out
    // bridge gets priority -- its MWr/MRd TLPs can't wait
    // HDA takes priority over NVME (both can fire, HDA RIRB writes are time-critical)
    //
    // fairness: after 8 consecutive DMA TLP words a 1-cycle gap is forced so
    // BAR read completions cannot be starved by sustained DMA bursts
    reg [2:0] dma_burst_cnt;
    wire dma_active = hda_tlp_tx_tvalid || nvme_tlp_tx_tvalid;
    wire dma_yield = (dma_burst_cnt == 3'd7);
    wire dma_tx    = dma_active && tlps_out.tready && !dma_yield;
    assign nvme_tlp_tx_tready = tlps_out.tready && !dma_yield && !hda_tlp_tx_tvalid;

    always @(posedge clk) begin
        if (dma_yield)
            dma_burst_cnt <= 3'd0;
        else if (dma_tx && dma_burst_cnt != 3'd7)
            dma_burst_cnt <= dma_burst_cnt + 3'd1;
        else if (!dma_active)
            dma_burst_cnt <= 3'd0;
    end

    assign tlps_out.tdata    = (hda_tlp_tx_tvalid && !dma_yield) ? hda_tlp_tx_tdata    : (nvme_tlp_tx_tvalid && !dma_yield) ? nvme_tlp_tx_tdata    : tlps_rdeng.tdata;
    assign tlps_out.tkeepdw  = (hda_tlp_tx_tvalid && !dma_yield) ? hda_tlp_tx_tkeepdw  : (nvme_tlp_tx_tvalid && !dma_yield) ? nvme_tlp_tx_tkeepdw  : tlps_rdeng.tkeepdw;
    assign tlps_out.tvalid   = (dma_active && !dma_yield) || tlps_rdeng.tvalid;
    assign tlps_out.tlast    = (hda_tlp_tx_tvalid && !dma_yield) ? hda_tlp_tx_tlast    : (nvme_tlp_tx_tvalid && !dma_yield) ? nvme_tlp_tx_tlast    : tlps_rdeng.tlast;
    assign tlps_out.tuser    = (hda_tlp_tx_tvalid && !dma_yield) ? hda_tlp_tx_tuser    : (nvme_tlp_tx_tvalid && !dma_yield) ? nvme_tlp_tx_tuser    : tlps_rdeng.tuser;
    assign tlps_out.has_data = (dma_active && !dma_yield) || tlps_rdeng.has_data;
    assign tlps_rdeng.tready = tlps_out.tready && (dma_yield || !dma_active);
{{ end }}

{{ if and (eq .DeviceClass "audio") .BARModel }}{{ if not (and (eq .DeviceClass "nvme") .NVMeIdentify) }}
    // HDA-only build: mux HDA DMA TLPs with rdengine BAR responses
    //
    // fairness: after 8 consecutive DMA TLP words a 1-cycle gap is forced so
    // BAR read completions cannot be starved by sustained DMA bursts
    reg [2:0] dma_burst_cnt;
    wire dma_yield = (dma_burst_cnt == 3'd7);

    always @(posedge clk) begin
        if (dma_yield)
            dma_burst_cnt <= 3'd0;
        else if (hda_tlp_tx_tvalid && tlps_out.tready && dma_burst_cnt != 3'd7)
            dma_burst_cnt <= dma_burst_cnt + 3'd1;
        else if (!hda_tlp_tx_tvalid)
            dma_burst_cnt <= 3'd0;
    end

    assign tlps_out.tdata    = (hda_tlp_tx_tvalid && !dma_yield) ? hda_tlp_tx_tdata    : tlps_rdeng.tdata;
    assign tlps_out.tkeepdw  = (hda_tlp_tx_tvalid && !dma_yield) ? hda_tlp_tx_tkeepdw  : tlps_rdeng.tkeepdw;
    assign tlps_out.tvalid   = (hda_tlp_tx_tvalid && !dma_yield) || tlps_rdeng.tvalid;
    assign tlps_out.tlast    = (hda_tlp_tx_tvalid && !dma_yield) ? hda_tlp_tx_tlast    : tlps_rdeng.tlast;
    assign tlps_out.tuser    = (hda_tlp_tx_tvalid && !dma_yield) ? hda_tlp_tx_tuser    : tlps_rdeng.tuser;
    assign tlps_out.has_data = (hda_tlp_tx_tvalid && !dma_yield) || tlps_rdeng.has_data;
    assign tlps_rdeng.tready = tlps_out.tready && (dma_yield || !hda_tlp_tx_tvalid);
{{ end }}{{ end }}

{{ if not (or (and (eq .DeviceClass "nvme") .NVMeIdentify) (and (eq .DeviceClass "audio") .BARModel)) }}
    // no DMA bridge: rdengine output goes straight to tlps_out
    assign tlps_out.tdata    = tlps_rdeng.tdata;
    assign tlps_out.tkeepdw  = tlps_rdeng.tkeepdw;
    assign tlps_out.tvalid   = tlps_rdeng.tvalid;
    assign tlps_out.tlast    = tlps_rdeng.tlast;
    assign tlps_out.tuser    = tlps_rdeng.tuser;
    assign tlps_out.has_data = tlps_rdeng.has_data;
    assign tlps_rdeng.tready = tlps_out.tready;
{{ end }}

    // BAR1: address loopback
    pcileech_bar_impl_loopaddr i_bar1(
        .rst            ( rst                           ),
        .clk            ( clk                           ),
        .wr_addr        ( wr_addr                       ),
        .wr_be          ( wr_be                         ),
        .wr_data        ( wr_data                       ),
        .wr_valid       ( wr_valid && wr_bar[1]         ),
        .rd_req_ctx     ( rd_req_ctx                    ),
        .rd_req_addr    ( rd_req_addr                   ),
        .rd_req_valid   ( rd_req_valid && rd_req_bar[1] ),
        .rd_rsp_ctx     ( bar_rsp_ctx[1]                ),
        .rd_rsp_data    ( bar_rsp_data[1]               ),
        .rd_rsp_valid   ( bar_rsp_valid[1]              )
    );

    // BAR2: MSI doorbell interrupt — write to offset 0x00 triggers MSI
    wire        bar2_intr_req;

    pcileech_bar_impl_msi i_bar2(
        .rst            ( rst                           ),
        .clk            ( clk                           ),
        .wr_addr        ( wr_addr                       ),
        .wr_be          ( wr_be                         ),
        .wr_data        ( wr_data                       ),
        .wr_valid       ( wr_valid && wr_bar[2]         ),
        .rd_req_ctx     ( rd_req_ctx                    ),
        .rd_req_addr    ( rd_req_addr                   ),
        .rd_req_valid   ( rd_req_valid && rd_req_bar[2] ),
        .rd_rsp_ctx     ( bar_rsp_ctx[2]                ),
        .rd_rsp_data    ( bar_rsp_data[2]               ),
        .rd_rsp_valid   ( bar_rsp_valid[2]              ),
        .intr_req       ( bar2_intr_req                 )
    );

    // BAR3-6: unimplemented
    genvar gi;
    generate
        for (gi = 3; gi < 7; gi = gi + 1) begin : gen_bar_none
            pcileech_bar_impl_none i_bar_none(
                .rst            ( rst                           ),
                .clk            ( clk                           ),
                .wr_addr        ( wr_addr                       ),
                .wr_be          ( wr_be                         ),
                .wr_data        ( wr_data                       ),
                .wr_valid       ( wr_valid && wr_bar[gi]        ),
                .rd_req_ctx     ( rd_req_ctx                    ),
                .rd_req_addr    ( rd_req_addr                   ),
                .rd_req_valid   ( rd_req_valid && rd_req_bar[gi]),
                .rd_rsp_ctx     ( bar_rsp_ctx[gi]               ),
                .rd_rsp_data    ( bar_rsp_data[gi]              ),
                .rd_rsp_valid   ( bar_rsp_valid[gi]             )
            );
        end
    endgenerate

    assign intr_req = bar2_intr_req{{ if eq .DeviceClass "audio" }} | hda_intr_req{{ end }}{{ if eq .DeviceClass "nvme" }} | nvme_msix_trigger{{ end }};

endmodule
