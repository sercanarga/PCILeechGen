        .tlp_tx_tuser       ( nvme_tlp_tx_tuser             ),
        .tlp_rx_tdata       ( tlps_in.tdata                 ),
        .tlp_rx_tvalid      ( tlps_in.tvalid                ),
        .tlp_rx_tuser       ( tlps_in.tuser                 )
    );

    // identify data ROM – loaded from hex at synthesis, read with 1-cycle latency
    reg [31:0] nvme_identify_rom [0:2047];
    initial $readmemh("identify_init.hex", nvme_identify_rom);

    reg [31:0] nvme_id_rom_data_r;
    always @(posedge clk)
        nvme_id_rom_data_r <= nvme_identify_rom[nvme_id_rom_addr[12:2]];
    assign nvme_id_rom_data = nvme_id_rom_data_r;

    // mux DMA bridge TLPs with rdengine BAR responses onto tlps_out
    // bridge gets priority -- its MWr/MRd TLPs can't wait
    // HDA takes priority over NVME (both can fire, HDA RIRB writes are time-critical)
    assign tlps_out.tdata    = hda_tlp_tx_tvalid ? hda_tlp_tx_tdata    : nvme_tlp_tx_tvalid ? nvme_tlp_tx_tdata    : tlps_rdeng.tdata;
    assign tlps_out.tkeepdw  = hda_tlp_tx_tvalid ? hda_tlp_tx_tkeepdw  : nvme_tlp_tx_tvalid ? nvme_tlp_tx_tkeepdw  : tlps_rdeng.tkeepdw;
    assign tlps_out.tvalid   = hda_tlp_tx_tvalid || nvme_tlp_tx_tvalid || tlps_rdeng.tvalid;
    assign tlps_out.tlast    = hda_tlp_tx_tvalid ? hda_tlp_tx_tlast    : nvme_tlp_tx_tvalid ? nvme_tlp_tx_tlast    : tlps_rdeng.tlast;
    assign tlps_out.tuser    = hda_tlp_tx_tvalid ? hda_tlp_tx_tuser    : nvme_tlp_tx_tvalid ? nvme_tlp_tx_tuser    : tlps_rdeng.tuser;
    assign tlps_out.has_data = hda_tlp_tx_tvalid || nvme_tlp_tx_tvalid || tlps_rdeng.has_data;
    assign tlps_rdeng.tready = tlps_out.tready && !nvme_tlp_tx_tvalid && !hda_tlp_tx_tvalid;
{{ end }}

{{ if and (eq .DeviceClass "audio") .BARModel }}{{ if not (and (eq .DeviceClass "nvme") .NVMeIdentify) }}
    // HDA-only build: mux HDA DMA TLPs with rdengine BAR responses
    assign tlps_out.tdata    = hda_tlp_tx_tvalid ? hda_tlp_tx_tdata    : tlps_rdeng.tdata;
    assign tlps_out.tkeepdw  = hda_tlp_tx_tvalid ? hda_tlp_tx_tkeepdw  : tlps_rdeng.tkeepdw;
    assign tlps_out.tvalid   = hda_tlp_tx_tvalid || tlps_rdeng.tvalid;
    assign tlps_out.tlast    = hda_tlp_tx_tvalid ? hda_tlp_tx_tlast    : tlps_rdeng.tlast;
    assign tlps_out.tuser    = hda_tlp_tx_tvalid ? hda_tlp_tx_tuser    : tlps_rdeng.tuser;
    assign tlps_out.has_data = hda_tlp_tx_tvalid || tlps_rdeng.has_data;
    assign tlps_rdeng.tready = tlps_out.tready && !hda_tlp_tx_tvalid;
{{ end }}{{ end }}

    // BAR1: address loopback
    pcileech_bar_impl_loopaddr i_bar1(
        .rst            ( rst                           ),
        .clk            ( clk                           ),
        .wr_addr        ( wr_addr                       ),
        .wr_be          ( wr_be                         ),
        .wr_data        ( wr_data                       ),
        .wr_valid       ( wr_valid && wr_bar[1]         ),
        .rd_req_ctx     ( rd_req_ctx                    ),
        .rd_req_addr    ( rd_req_addr                   ),
        .rd_req_valid   ( rd_req_valid && rd_req_bar[1] ),
        .rd_rsp_ctx     ( bar_rsp_ctx[1]                ),
        .rd_rsp_data    ( bar_rsp_data[1]               ),
        .rd_rsp_valid   ( bar_rsp_valid[1]              )
    );

    // BAR2-6: unimplemented
    genvar gi;
    generate
        for (gi = 2; gi < 7; gi = gi + 1) begin : gen_bar_none
            pcileech_bar_impl_none i_bar_none(
                .rst            ( rst                           ),
                .clk            ( clk                           ),
                .wr_addr        ( wr_addr                       ),
                .wr_be          ( wr_be                         ),
                .wr_data        ( wr_data                       ),
                .wr_valid       ( wr_valid && wr_bar[gi]        ),
                .rd_req_ctx     ( rd_req_ctx                    ),
                .rd_req_addr    ( rd_req_addr                   ),
                .rd_req_valid   ( rd_req_valid && rd_req_bar[gi]),
                .rd_rsp_ctx     ( bar_rsp_ctx[gi]               ),
                .rd_rsp_data    ( bar_rsp_data[gi]              ),
                .rd_rsp_valid   ( bar_rsp_valid[gi]             )
            );
        end
    endgenerate

endmodule
