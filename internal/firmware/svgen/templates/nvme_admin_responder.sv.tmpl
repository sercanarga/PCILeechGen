//
// Minimal NVMe controller responder for the {{ hex04 .DeviceIDs.VendorID }}:{{ hex04 .DeviceIDs.DeviceID }} config.
//
// Queue 0 handles admin commands. Queue 1 is a small NVM I/O queue backed by
// the selected disk backend in the BAR controller.
//

`timescale 1ns / 1ps

module pcileech_nvme_admin_responder #(
    // Must match the Identify Namespace NSZE (nvme.BuildIdentifyData) so IO
    // LBA-range validation agrees with what the host was told.
    parameter [63:0]    NVME_ADVERTISED_LBAS = 64'd{{ if gt .NVMeAdvertisedLBAs 0 }}{{ .NVMeAdvertisedLBAs }}{{ else }}2000409264{{ end }},
    parameter           NVME_ENABLE_IO_QUEUES = 1'b1,
    parameter           NVME_STUB_IO_DATA = 1'b0,
    parameter           NVME_ZERO_IO_READS = 1'b0,
    parameter           NVME_PRP_ONLY_IO = 1'b0,
    parameter           NVME_TIMING_ENABLE = 1'b0,
    parameter integer   NVME_TIMING_CLK_HZ = 125000000
) (
    input               rst,
    input               clk,
    input tri1          dma_enabled,

    input               cc_en,
    input               cc_enable_wr,
    input               cc_disable_wr,

    input [31:0]        asq_lo,
    input [31:0]        asq_hi,
    input [31:0]        acq_lo,
    input [31:0]        acq_hi,
    input [31:0]        aqa,

    input               doorbell_wr,
    input               doorbell_is_cq,
    input [15:0]        doorbell_qid,
    input [15:0]        doorbell_val,

    input [63:0]        msix_vector_addr,
    input [31:0]        msix_vector_data,
    input               irq_delivery_valid,
    output              irq_delivery_ready,
    output reg          irq_delivery_done,

    (* DONT_TOUCH = "TRUE" *) output reg          dma_rd_req,
    (* DONT_TOUCH = "TRUE" *) output reg [63:0]   dma_rd_addr,
    (* DONT_TOUCH = "TRUE" *) output reg [9:0]    dma_rd_len,
    input               dma_rd_valid,
    input [31:0]        dma_rd_data,
    input               dma_rd_done,

    (* DONT_TOUCH = "TRUE" *) output reg          dma_wr_req,
    (* DONT_TOUCH = "TRUE" *) output reg [63:0]   dma_wr_addr,
    (* DONT_TOUCH = "TRUE" *) output reg [31:0]   dma_wr_data,
    (* DONT_TOUCH = "TRUE" *) output reg [3:0]    dma_wr_be,
    (* DONT_TOUCH = "TRUE" *) output reg          dma_wr_valid,
    input               dma_wr_done,

    output reg          disk_req_valid,
    output reg          disk_req_write,
    output reg          disk_req_flush,
    output reg [63:0]   disk_req_lba,
    output reg [6:0]    disk_req_word,
    output reg [31:0]   disk_req_wdata,
    input               disk_req_done,
    input [31:0]        disk_req_rdata,
    input               disk_req_hit,
    input               disk_busy,
    input               disk_error,

    output reg          msix_trigger,

    // PBA pending bit for a masked vector (spec 6.8.3.4).
    output reg          pba_set_valid,
    output reg [15:0]   pba_set_vector,

    output reg [12:0]   id_rom_addr,
    input [31:0]        id_rom_data,

    output [7:0]        dbg_state,
    output [15:0]       dbg_active_qid,
    output [7:0]        dbg_opcode,
    output [31:0]       dbg_admin_queues,
    output [31:0]       dbg_cmd_info
);

    localparam [5:0] S_IDLE              = 6'd0;
    localparam [5:0] S_FETCH_SQE         = 6'd1;
    localparam [5:0] S_DECODE_CMD        = 6'd2;
    localparam [5:0] S_EXEC_IDENTIFY     = 6'd3;
    localparam [5:0] S_EXEC_NSLIST       = 6'd4;
    localparam [5:0] S_EXEC_LOGPAGE      = 6'd5;
    localparam [5:0] S_EXEC_ZERO4K       = 6'd6;
    localparam [5:0] S_BUILD_CQE         = 6'd7;
    localparam [5:0] S_POST_CQE          = 6'd8;
    localparam [5:0] S_SEND_MSIX         = 6'd9;
    localparam [5:0] S_WAIT_DMA_WR       = 6'd10;
    localparam [5:0] S_IO_WRITE_DMA_REQ  = 6'd11;
    localparam [5:0] S_IO_WRITE_DMA_WAIT = 6'd12;
    localparam [5:0] S_IO_DISK_WR_WAIT   = 6'd13;
    localparam [5:0] S_IO_READ_DISK_REQ  = 6'd14;
    localparam [5:0] S_IO_READ_DISK_WAIT = 6'd15;
    localparam [5:0] S_IO_ADVANCE        = 6'd16;
    localparam [5:0] S_IO_ZERO_REQ       = 6'd17;
    localparam [5:0] S_IO_FLUSH_REQ      = 6'd18;
    localparam [5:0] S_IO_FLUSH_WAIT     = 6'd19;
    localparam [5:0] S_SHUTDOWN          = 6'd20;
    localparam [5:0] S_EXEC_NSID_DESC    = 6'd21;
    localparam [5:0] S_RESOLVE_IO_PRP    = 6'd22;
    localparam [5:0] S_PRP_LIST_RD_LO    = 6'd23;
    localparam [5:0] S_PRP_LIST_RD_HI    = 6'd24;
    localparam [5:0] S_IO_READ_HOST_WR   = 6'd25;
    localparam [5:0] S_DSM_FETCH_REQ     = 6'd26;
    localparam [5:0] S_DSM_FETCH_WAIT    = 6'd27;
    localparam [5:0] S_DSM_CLEAR_WAIT    = 6'd28;
    localparam [5:0] S_FORMAT_CLEAR      = 6'd29;
    localparam [5:0] S_TIMING_DELAY      = 6'd30;
    localparam [5:0] S_TIMING_PREP       = 6'd31;
    localparam [5:0] S_TIMING_EVAL       = 6'd32;
    localparam [5:0] S_AER_POST          = 6'd33;
    localparam [5:0] S_AER_FINISH        = 6'd34;

    localparam [1:0] IO_DIR_READ  = 2'd0;
    localparam [1:0] IO_DIR_WRITE = 2'd1;
    localparam [1:0] IO_DIR_ZERO  = 2'd2;

    localparam [3:0] TIMING_ADMIN_SHORT    = 4'h1;
    localparam [3:0] TIMING_IDENTIFY       = 4'h2;
    localparam [3:0] TIMING_GET_LOG        = 4'h3;
    localparam [3:0] TIMING_READ_PENDING   = 4'h4;
    localparam [3:0] TIMING_READ_HIT       = 4'h5;
    localparam [3:0] TIMING_READ_MISS_ZERO = 4'h6;
    localparam [3:0] TIMING_WRITE          = 4'h7;
    localparam [3:0] TIMING_WRITE_ZEROES   = 4'h8;
    localparam [3:0] TIMING_FLUSH          = 4'h9;
    localparam [3:0] TIMING_DSM            = 4'hA;
    localparam [3:0] TIMING_FORMAT         = 4'hB;
    localparam [3:0] TIMING_ERROR          = 4'hC;

    localparam integer NVME_TIMING_CYCLES_PER_US =
        (NVME_TIMING_CLK_HZ < 1000000) ? 1 : (NVME_TIMING_CLK_HZ / 1000000);

    localparam [14:0] NVME_SC_DATA_XFER_ERROR    = 15'h0004;
    localparam [14:0] NVME_SC_INVALID_FIELD      = 15'h0002;
    localparam [14:0] NVME_SC_INVALID_NS         = 15'h000B;
    localparam [14:0] NVME_SC_PRP_OFFSET_INVALID = 15'h0013;
    localparam [14:0] NVME_SC_LBA_RANGE          = 15'h0080;
    localparam [14:0] NVME_SC_INVALID_FORMAT     = 15'h010A;

    // MDTS = 32 KiB (8192 DWORDs). I/O transfers larger than this are rejected.
    localparam [23:0] MAX_XFER_DW = 24'd8192;
    // Upper bound on PRP list entries we will walk before failing the command.
    localparam [19:0] PRP_LIST_MAX_ENTRIES = 20'd512;
{{ if .MSIXConfig }}    localparam [15:0] NVME_NUM_MSIX_VECTORS = 16'd{{ .MSIXConfig.NumVectors }};{{ else }}    localparam [15:0] NVME_NUM_MSIX_VECTORS = 16'd1;{{ end }}

    (* DONT_TOUCH = "TRUE" *) reg [5:0] state;
    (* DONT_TOUCH = "TRUE" *) reg [5:0] return_state;
    assign dbg_state = {2'b00, state};

    reg [15:0] active_qid;
    assign dbg_active_qid = active_qid;

    // Admin queue bookkeeping.
    reg [15:0] sq_tail;
    reg [15:0] sq_head;
    reg [15:0] cq_tail;
    reg [15:0] cq_head_db;
    reg        cq_phase;

    reg [31:0] admin_aqa;
    reg [31:0] admin_asq_lo;
    reg [31:0] admin_asq_hi;
    reg [31:0] admin_acq_lo;
    reg [31:0] admin_acq_hi;

    wire [11:0] asqs = admin_aqa[11:0];
    wire [11:0] acqs = admin_aqa[27:16];
    wire [15:0] asq_last = {4'h0, asqs};
    wire [15:0] acq_last = {4'h0, acqs};
    wire        asq_power2_entries = ((asq_last & (asq_last + 16'd1)) == 16'h0000);
    wire        acq_power2_entries = ((acq_last & (acq_last + 16'd1)) == 16'h0000);
    wire [15:0] sq_head_next = (sq_head >= asq_last) ? 16'h0 : (sq_head + 16'h1);
    wire [15:0] cq_tail_next = (cq_tail >= acq_last) ? 16'h0 : (cq_tail + 16'h1);
    wire [63:0] asq_base = {admin_asq_hi, admin_asq_lo & 32'hFFFFF000};
    wire [63:0] acq_base = {admin_acq_hi, admin_acq_lo & 32'hFFFFF000};
    wire        admin_aqa_valid = (asqs >= 12'd1) && (acqs >= 12'd1);
    wire        admin_asq_valid = ({admin_asq_hi, admin_asq_lo} != 64'h0000000000000000) && (admin_asq_lo[11:0] == 12'h000);
    wire        admin_acq_valid = ({admin_acq_hi, admin_acq_lo} != 64'h0000000000000000) && (admin_acq_lo[11:0] == 12'h000);
    wire        admin_queue_config_valid = admin_aqa_valid && admin_asq_valid && admin_acq_valid;

    // I/O queue 1.  Windows normally creates one SQ/CQ pair after admin init.
    reg        io_sq_created;
    reg        io_cq_created;
    reg [63:0] io_sq_base;
    reg [63:0] io_cq_base;
    reg [15:0] io_sq_last;
    reg [15:0] io_cq_last;
    reg [15:0] io_sq_tail;
    reg [15:0] io_sq_head;
    reg [15:0] io_cq_tail;
    reg [15:0] io_cq_head_db;
    reg        io_cq_phase;
    reg [15:0] io_vector;

    wire        io_sq_power2_entries = ((io_sq_last & (io_sq_last + 16'd1)) == 16'h0000);
    wire        io_cq_power2_entries = ((io_cq_last & (io_cq_last + 16'd1)) == 16'h0000);
    wire [15:0] io_sq_head_next = (io_sq_head >= io_sq_last) ? 16'h0 : (io_sq_head + 16'h1);
    wire [15:0] io_cq_tail_next = (io_cq_tail >= io_cq_last) ? 16'h0 : (io_cq_tail + 16'h1);

    wire active_io = (active_qid != 16'h0000);
    assign irq_delivery_ready = dma_enabled && (state == S_IDLE) && cc_en && !irq_delivery_done;
    wire [15:0] active_sq_head_next = active_io ? io_sq_head_next : sq_head_next;
    wire [15:0] active_cq_tail      = active_io ? io_cq_tail      : cq_tail;
    wire [15:0] active_cq_last      = active_io ? io_cq_last      : acq_last;
    wire [63:0] active_cq_base      = active_io ? io_cq_base      : acq_base;
    wire        active_cq_phase     = active_io ? io_cq_phase     : cq_phase;

    reg [31:0] sqe [0:15];
    reg [3:0]  sqe_dw_idx;

    wire [7:0]  cmd_opcode = sqe[0][7:0];
    wire [15:0] cmd_cid    = sqe[0][31:16];
    wire [31:0] cmd_nsid   = sqe[1];
    wire [63:0] cmd_prp1   = {sqe[7], sqe[6]};
    wire [63:0] cmd_prp2   = {sqe[9], sqe[8]};
    wire        cmd_prp1_page_valid = (cmd_prp1 != 64'h0000000000000000) && (cmd_prp1[11:0] == 12'h000);
    wire [31:0] cmd_cdw10  = sqe[10];
    wire [31:0] cmd_cdw11  = sqe[11];
    wire [31:0] cmd_cdw12  = sqe[12];
    wire [31:0] cmd_cdw13  = sqe[13];
    wire [31:0] cmd_cdw14  = sqe[14];
    wire [31:0] cmd_cdw15  = sqe[15];
    wire [7:0]  identify_cns = cmd_cdw10[7:0];
    wire        cmd_nsid_selects_ns1 = (cmd_nsid == 32'd1) || (cmd_nsid == 32'hFFFFFFFF);
    wire        cmd_nsid_lists_ns1   = (cmd_nsid == 32'd0) || (cmd_nsid == 32'hFFFFFFFF);
    assign dbg_opcode = cmd_opcode;

    wire [63:0] cmd_slba = {cmd_cdw11, cmd_cdw10};
    wire [16:0] cmd_nlb_count = {1'b0, cmd_cdw12[15:0]} + 17'd1;
    assign dbg_admin_queues = active_io ?
                                      {cmd_cdw12[15:0], io_sq_head[7:0], io_sq_tail[7:0]} :
                                      {sq_head[7:0], sq_tail[7:0], asq_last[7:0], cq_head_db[7:0]};
    wire [63:0] cmd_nlb_count64 = {47'h0, cmd_nlb_count};
    wire        cmd_lba_ok =
        (cmd_nsid == 32'd1) &&
        (cmd_slba < NVME_ADVERTISED_LBAS) &&
        (cmd_nlb_count64 <= (NVME_ADVERTISED_LBAS - cmd_slba));
    wire        format_nvm_ok =
        (cmd_nsid == 32'd1) &&
        (cmd_cdw10[3:0] == 4'h0) &&
        (cmd_cdw10[8:5] == 4'h0) &&
        (cmd_cdw10[31:9] == 23'h000000) &&
        (cmd_cdw11 == 32'h00000000) &&
        (cmd_cdw12 == 32'h00000000) &&
        (cmd_cdw13 == 32'h00000000) &&
        (cmd_cdw14 == 32'h00000000) &&
        (cmd_cdw15 == 32'h00000000);
    wire [23:0] cmd_total_dw = {cmd_nlb_count, 7'b0000000};
    wire        cmd_mdts_ok = (cmd_total_dw <= MAX_XFER_DW);
    wire [127:0] nvme_disk_bytes = {55'h0, NVME_ADVERTISED_LBAS, 9'h000};
    wire [10:0] cmd_log_last_dw = (cmd_cdw10[31:16] > 16'd1023) ? 11'd1023 : cmd_cdw10[26:16];

    function [63:0] prp_data_addr;
        input [23:0] dw_index;
        reg [31:0] byte_off;
        reg [31:0] first_span;
        begin
            byte_off = {6'h00, dw_index, 2'b00};
            first_span = 32'd4096 - {20'h00000, cmd_prp1[11:0]};
            if (byte_off < first_span)
                prp_data_addr = cmd_prp1 + {32'h00000000, byte_off};
            else
                prp_data_addr = cmd_prp2 + {32'h00000000, (byte_off - first_span)};
        end
    endfunction

    function [31:0] identify_data_word;
        input [12:0] base;
        input [10:0] dw_index;
        input [31:0] rom_data;
        begin
            identify_data_word = rom_data;
            if (base == 13'h0000) begin
                case (dw_index)
                    // SN/MN/FR (bytes 4..71) come from the donor identify ROM;
                    // only optional feature fields are substituted below.
                    11'd64: identify_data_word = 32'h07030002; // OACS: Format NVM only.
                    11'd65: identify_data_word = 32'h00000002; // ELPE/LPA/one power state.
                    11'd66: identify_data_word = 32'h01570000; // WCTEMP=343K.
                    11'd67: identify_data_word = 32'h00000166; // CCTEMP=358K.
                    11'd70: identify_data_word = nvme_disk_bytes[31:0];  // TNVMCAP low.
                    11'd71: identify_data_word = nvme_disk_bytes[63:32];
                    11'd72: identify_data_word = nvme_disk_bytes[95:64];
                    11'd73: identify_data_word = nvme_disk_bytes[127:96];
                    11'd74: identify_data_word = 32'h00000000;  // UNVMCAP low.
                    11'd75: identify_data_word = 32'h00000000;
                    11'd76: identify_data_word = 32'h00000000;
                    11'd77: identify_data_word = 32'h00000000;
                    11'd128: identify_data_word = 32'h00004466; // SQES=64B, CQES=16B.
                    11'd129: identify_data_word = 32'h00000001; // NN: one namespace.
                    11'd130: identify_data_word = 32'h0000000C; // Dataset Management and Write Zeroes.
                    11'd131: identify_data_word = 32'h00000100; // VWC present.
                    11'd512: identify_data_word = 32'h00000320; // PSD0: 8.00 W active state.
                    11'd513: identify_data_word = 32'h00000000;
                    11'd514: identify_data_word = 32'h00000000;
                    11'd515: identify_data_word = 32'h00000000;
                    11'd516: identify_data_word = 32'h00000000;
                    11'd517: identify_data_word = 32'h00000000;
                    11'd518: identify_data_word = 32'h00000000;
                    11'd519: identify_data_word = 32'h00000000;
                    default: identify_data_word = rom_data;
                endcase
            end else if (base == 13'h1000) begin
                case (dw_index)
                    11'd0,
                    11'd2,
                    11'd4: identify_data_word = NVME_ADVERTISED_LBAS[31:0];
                    11'd1,
                    11'd3,
                    11'd5: identify_data_word = NVME_ADVERTISED_LBAS[63:32];
                    11'd6: identify_data_word = 32'h00000000; // One LBA format, no metadata.
                    11'd7: identify_data_word = 32'h00000000; // No PI/DPS/namespace features.
                    11'd32: identify_data_word = 32'h00090000; // LBAF0: 512-byte LBAs.
                    default: identify_data_word = 32'h00000000;
                endcase
            end
        end
    endfunction

    reg [31:0] cqe [0:3];
    reg [1:0]  cqe_dw_idx;
    reg [31:0] cqe_result;
    reg [14:0] cqe_status;
    reg [63:0] last_error_count;
    reg [15:0] last_error_sqid;
    reg [15:0] last_error_cid;
    reg [15:0] last_error_status;
    reg [15:0] last_error_peloc;
    reg [63:0] last_error_lba;
    reg [31:0] last_error_nsid;
    reg [3:0]  timing_class;
    reg [3:0]  timing_effective_class;
    reg        timing_done_for_cmd;
    reg        timing_cmd_active;
    reg        timing_saturated;
    reg        timing_read_seen_hit;
    reg        timing_read_seen_miss;
    reg [15:0] timing_lfsr;
    reg [15:0] timing_jitter_sample;
    reg [31:0] timing_elapsed_cycles;
    reg [31:0] timing_target_cycles;
    reg [31:0] timing_wait_cycles;

    reg [10:0] data_dw_cnt;
    reg [12:0] id_rom_offset;

    localparam [7:0] LOG_PAGE_SUPPORTED = 8'h00;
    localparam [7:0] LOG_PAGE_ERROR     = 8'h01;
    localparam [7:0] LOG_PAGE_SMART     = 8'h02;
    localparam [7:0] LOG_PAGE_FW_SLOT   = 8'h03;

    reg [63:0] stat_data_units_read;
    reg [63:0] stat_data_units_written;
    reg [63:0] stat_host_read_cmds;
    reg [63:0] stat_host_write_cmds;
    reg [63:0] stat_flush_cmds;
    reg [63:0] stat_write_zero_cmds;
    reg [63:0] stat_dataset_cmds;
    reg [63:0] stat_cmds_completed;
    reg [31:0] stat_media_errors;
    reg [31:0] stat_error_log_entries;
    reg [31:0] stat_unsafe_shutdowns;
    reg [31:0] power_cycle_count;
    reg [31:0] power_on_hours;
    reg [11:0] hour_second_count;
    reg [26:0] second_tick;
    reg [7:0]  thermal_load;
    reg [31:0] warning_temp_time;
    reg [31:0] critical_temp_time;

    wire [15:0] smart_temp_k = 16'd303 + {11'h000, thermal_load[7:3]};
    // Critical warning byte: bit1=temp over WCTEMP(343K), bit2=reliability(media errors).
    wire [7:0]  smart_warning_byte = {5'b00000, (stat_media_errors != 32'h00000000), (smart_temp_k >= 16'd343), 1'b0};

    function [63:0] data_units_for_nlb;
        input [16:0] nlb_count;
        reg [31:0] units;
        begin
            units = ({15'h0000, nlb_count} + 32'd1023) >> 10;
            data_units_for_nlb = {48'h000000000000, units[15:0]};
        end
    endfunction

    function [15:0] timing_mix_lfsr;
        input [15:0] current;
        input [31:0] mix;
        reg [15:0] x;
        begin
            x = current ^ mix[15:0] ^ mix[31:16];
            if (x == 16'h0000)
                x = 16'hACE1;
            timing_mix_lfsr = {x[14:0], x[15] ^ x[13] ^ x[12] ^ x[10]};
        end
    endfunction

    function [31:0] timing_min_u32;
        input [31:0] a;
        input [31:0] b;
        begin
            timing_min_u32 = (a < b) ? a : b;
        end
    endfunction

    function [31:0] timing_us_to_cycles;
        input [31:0] us;
        begin
            case (NVME_TIMING_CYCLES_PER_US)
                125: timing_us_to_cycles = (us << 7) - (us << 1) - us;
                100: timing_us_to_cycles = (us << 6) + (us << 5) + (us << 2);
                default: timing_us_to_cycles = us * NVME_TIMING_CYCLES_PER_US;
            endcase
        end
    endfunction

    function [31:0] timing_profile_us;
        input [3:0]  cls;
        input [16:0] lbas;
        input [7:0]  dsm_ranges;
        input [15:0] jitter;
        reg [31:0] lba32;
        reg [31:0] range32;
        begin
            lba32 = {15'h0000, lbas};
            range32 = {24'h000000, dsm_ranges};
            case (cls)
                TIMING_IDENTIFY:
                    timing_profile_us = 32'd35 + {29'h0, jitter[2:0]};
                TIMING_GET_LOG:
                    timing_profile_us = 32'd28 + {29'h0, jitter[2:0]};
                TIMING_READ_HIT:
                    timing_profile_us = 32'd70 + timing_min_u32(lba32, 32'd32) +
                                        {28'h0, jitter[3:0]};
                TIMING_READ_MISS_ZERO:
                    timing_profile_us = 32'd115 + timing_min_u32({lba32[30:0], 1'b0}, 32'd64) +
                                        {27'h0, jitter[4:0]};
                TIMING_WRITE:
                    timing_profile_us = 32'd150 + timing_min_u32((lba32 + {lba32[30:0], 1'b0}), 32'd128) +
                                        {26'h0, jitter[5:0]};
                TIMING_WRITE_ZEROES:
                    timing_profile_us = 32'd180 + timing_min_u32(lba32, 32'd128) +
                                        {26'h0, jitter[5:0]};
                TIMING_FLUSH:
                    timing_profile_us = 32'd220 + {26'h0, jitter[5:0]};
                TIMING_DSM:
                    timing_profile_us = 32'd250 + timing_min_u32({range32[28:0], 3'b000}, 32'd1000) +
                                        {25'h0, jitter[6:0]};
                TIMING_FORMAT:
                    timing_profile_us = 32'd8000 + {20'h00000, jitter[11:0]};
                TIMING_ERROR:
                    timing_profile_us = 32'd12 + {30'h0, jitter[1:0]};
                default:
                    timing_profile_us = 32'd12 + {30'h0, jitter[1:0]};
            endcase
        end
    endfunction

    function [31:0] timing_profile_cycles;
        input [3:0]  cls;
        input [16:0] lbas;
        input [7:0]  dsm_ranges;
        input [15:0] jitter;
        begin
            timing_profile_cycles = timing_us_to_cycles(timing_profile_us(cls, lbas, dsm_ranges, jitter));
        end
    endfunction

    function [31:0] log_page_word;
        input [10:0] dw_index;
        begin
            case (cmd_cdw10[7:0])
                LOG_PAGE_SUPPORTED: begin
                    case (dw_index[7:0])
                        8'h00: log_page_word = 32'h01010101; // 00h, 01h, 02h, 03h supported.
                        default: log_page_word = 32'h00000000;
                    endcase
                end
                LOG_PAGE_ERROR: begin
                    case (dw_index[7:0])
                        8'd0: log_page_word = last_error_count[31:0];
                        8'd1: log_page_word = last_error_count[63:32];
                        8'd2: log_page_word = {last_error_cid, last_error_sqid};
                        8'd3: log_page_word = {last_error_peloc, last_error_status};
                        8'd4: log_page_word = last_error_lba[31:0];
                        8'd5: log_page_word = last_error_lba[63:32];
                        8'd6: log_page_word = last_error_nsid;
                        8'd7: log_page_word = 32'h00000000;
                        default: log_page_word = 32'h00000000;
                    endcase
                end
                LOG_PAGE_SMART: begin
                    case (dw_index[7:0])
                        8'd0:  log_page_word = {8'd100, smart_temp_k, smart_warning_byte};
                        8'd1:  log_page_word = 32'h0000000A; // spare threshold 10%, used 0%.
                        8'd8:  log_page_word = stat_data_units_read[31:0];
                        8'd9:  log_page_word = stat_data_units_read[63:32];
                        8'd12: log_page_word = stat_data_units_written[31:0];
                        8'd13: log_page_word = stat_data_units_written[63:32];
                        8'd16: log_page_word = stat_host_read_cmds[31:0];
                        8'd17: log_page_word = stat_host_read_cmds[63:32];
                        8'd20: log_page_word = stat_host_write_cmds[31:0];
                        8'd21: log_page_word = stat_host_write_cmds[63:32];
                        8'd24: log_page_word = stat_cmds_completed[31:0];
                        8'd25: log_page_word = stat_cmds_completed[63:32];
                        8'd28: log_page_word = power_cycle_count;
                        8'd32: log_page_word = power_on_hours;
                        8'd36: log_page_word = stat_unsafe_shutdowns;
                        8'd40: log_page_word = stat_media_errors;
                        8'd44: log_page_word = stat_error_log_entries;
                        8'd48: log_page_word = warning_temp_time;
                        8'd49: log_page_word = critical_temp_time;
                        8'd50: log_page_word = {smart_temp_k, smart_temp_k};
                        8'd51: log_page_word = {16'h0000, smart_temp_k};
                        default: log_page_word = 32'h00000000;
                    endcase
                end
                LOG_PAGE_FW_SLOT: begin
                    case (dw_index[7:0])
                        8'd0: log_page_word = 32'h00000001;
                        8'd2: log_page_word = 32'h{{ if .NVMeIdentify }}{{ hex02 (index .NVMeIdentify.Controller 67) }}{{ hex02 (index .NVMeIdentify.Controller 66) }}{{ hex02 (index .NVMeIdentify.Controller 65) }}{{ hex02 (index .NVMeIdentify.Controller 64) }}{{ else }}20202020{{ end }}; // "DNV1" little-endian.
                        8'd3: log_page_word = 32'h{{ if .NVMeIdentify }}{{ hex02 (index .NVMeIdentify.Controller 71) }}{{ hex02 (index .NVMeIdentify.Controller 70) }}{{ hex02 (index .NVMeIdentify.Controller 69) }}{{ hex02 (index .NVMeIdentify.Controller 68) }}{{ else }}20202020{{ end }}; // ".000" little-endian-ish filler.
                        default: log_page_word = 32'h00000000;
                    endcase
                end
                default: log_page_word = 32'h00000000;
            endcase
        end
    endfunction

    reg         cc_en_prev;
    wire        cc_start_event = (cc_en && !cc_en_prev) || (cc_enable_wr && !cc_en_prev);
    wire        cc_stop_event  = (!cc_en && cc_en_prev) || (cc_disable_wr && cc_en_prev);
    wire        cc_reset_event = cc_start_event || cc_stop_event;
    reg         aer_registered;
    reg [15:0]  aer_cid;
    reg         aer_event_pending;
    reg [31:0]  aer_event_info;
    reg [31:0]  num_queues_granted;
    reg [31:0]  feat_arbitration;
    reg [31:0]  feat_power_mgmt;
    reg [31:0]  feat_temp_threshold;
    reg [31:0]  feat_write_cache;
    reg [31:0]  feat_irq_coalescing;
    reg [31:0]  feat_async_event_cfg;

    reg [1:0]   io_dir;
    reg [63:0]  io_slba;
    reg [23:0]  io_total_dw;
    reg [23:0]  io_dw_idx;
    reg [31:0]  io_host_data;
    reg [63:0]  io_host_addr;
    reg [31:0]  prp_entry_lo;
    reg [31:0]  prp_entry_hi;
    reg         prp_cached_valid;
    reg [19:0]  prp_cached_index;
    reg [63:0]  prp_cached_base;
    reg [7:0]   dsm_range_idx;
    reg [7:0]   dsm_range_last;
    reg [1:0]   dsm_dw_idx;
    reg [31:0]  dsm_dw0;
    reg [31:0]  dsm_dw1;
    reg [31:0]  dsm_dw2;
    reg [31:0]  dsm_dw3;

    wire [31:0] io_prp_byte_off = {6'h00, io_dw_idx, 2'b00};
    wire [31:0] io_prp_first_span = 32'd4096 - {20'h00000, cmd_prp1[11:0]};
    wire [31:0] io_prp_after_first = io_prp_byte_off - io_prp_first_span;
    wire [31:0] io_prp_total_bytes = {6'h00, io_total_dw, 2'b00};
    wire        io_prp_after_first_page = (io_prp_byte_off >= io_prp_first_span);
    wire        io_prp2_required = (io_prp_total_bytes > io_prp_first_span);
    wire        io_prp_uses_list = (io_prp_total_bytes > (io_prp_first_span + 32'd4096));
    wire [19:0] io_prp_list_index = io_prp_after_first[31:12];
    wire [63:0] io_prp_list_entry_addr = cmd_prp2 + {41'h0, io_prp_list_index, 3'b000};
    wire [31:0] prp_entry_hi_value = dma_rd_valid ? dma_rd_data : prp_entry_hi;
    wire [63:0] prp_list_entry_value = {prp_entry_hi_value, prp_entry_lo};
    wire [63:0] prp_list_page_base = {prp_entry_hi_value, prp_entry_lo[31:12], 12'h000};
    wire        io_prp1_invalid = (io_total_dw == 24'h0) ||
                                  (cmd_prp1 == 64'h0000000000000000) ||
                                  (cmd_prp1[1:0] != 2'b00);
    wire        io_prp2_invalid = io_prp2_required &&
                                  ((cmd_prp2 == 64'h0000000000000000) ||
                                   (cmd_prp2[11:0] != 12'h000));
    wire        prp_list_entry_invalid = (prp_list_entry_value == 64'h0000000000000000) ||
                                         (prp_list_entry_value[11:0] != 12'h000);
    wire [31:0] dsm_dw3_value = dma_rd_valid ? dma_rd_data : dsm_dw3;
    wire [63:0] dsm_lba_value = {dsm_dw3_value, dsm_dw2};
    wire [63:0] dsm_nlb64 = {32'h00000000, dsm_dw1};
    wire [7:0]  dsm_range_next = dsm_range_idx + 8'd1;
    wire [7:0]  timing_dsm_ranges = cmd_cdw10[7:0] + 8'd1;
    wire        dsm_range_ok =
        (dsm_dw1 != 32'h00000000) &&
        (dsm_lba_value < NVME_ADVERTISED_LBAS) &&
        (dsm_nlb64 <= (NVME_ADVERTISED_LBAS - dsm_lba_value));

    wire [63:0] io_disk_lba    = io_slba + {47'h0, io_dw_idx[23:7]};
    wire [6:0]  io_disk_word   = io_dw_idx[6:0];
    wire        io_last_dw     = ((io_dw_idx + 24'd1) >= io_total_dw);
    wire [3:0]  timing_completion_class =
        (cqe_status != 15'h0000) ? TIMING_ERROR :
        (timing_class == TIMING_READ_PENDING) ?
            (timing_read_seen_miss ? TIMING_READ_MISS_ZERO : TIMING_READ_HIT) :
        timing_class;
    wire [31:0] dbg_timing_info = {
        timing_saturated,
        timing_effective_class,
        timing_wait_cycles[26:0]
    };
    wire [31:0] dbg_io_progress = {cqe_status[7:0], io_dir[1:0], io_last_dw, io_dw_idx[20:0]};
    wire [31:0] dbg_io_cmd_info =
        (state == S_DECODE_CMD) ? cmd_slba[31:0] :
                                  dbg_io_progress;
    assign dbg_cmd_info = ((state == S_TIMING_PREP) ||
                           (state == S_TIMING_EVAL) ||
                           (state == S_TIMING_DELAY)) ? dbg_timing_info :
                          active_io ? dbg_io_cmd_info :
                           {cqe_status[7:0], identify_cns, cmd_nsid[7:0], data_dw_cnt[7:0]};

    always @(posedge clk) begin
        if (rst) begin
            state              <= S_IDLE;
            return_state       <= S_IDLE;
            active_qid         <= 16'h0000;

            sq_tail            <= 16'h0;
            sq_head            <= 16'h0;
            cq_tail            <= 16'h0;
            cq_head_db         <= 16'h0;
            cq_phase           <= 1'b1;
            admin_aqa          <= 32'h0;
            admin_asq_lo       <= 32'h0;
            admin_asq_hi       <= 32'h0;
            admin_acq_lo       <= 32'h0;
            admin_acq_hi       <= 32'h0;

            io_sq_created      <= 1'b0;
            io_cq_created      <= 1'b0;
            io_sq_base         <= 64'h0;
            io_cq_base         <= 64'h0;
            io_sq_last         <= 16'h0;
            io_cq_last         <= 16'h0;
            io_sq_tail         <= 16'h0;
            io_sq_head         <= 16'h0;
            io_cq_tail         <= 16'h0;
            io_cq_head_db      <= 16'h0;
            io_cq_phase        <= 1'b1;
            io_vector          <= 16'h0;

            dma_rd_req         <= 1'b0;
            dma_rd_addr        <= 64'h0;
            dma_rd_len         <= 10'h0;
            dma_wr_req         <= 1'b0;
            dma_wr_addr        <= 64'h0;
            dma_wr_data        <= 32'h0;
            dma_wr_be          <= 4'hF;
            dma_wr_valid       <= 1'b0;
            irq_delivery_done  <= 1'b0;
            disk_req_valid     <= 1'b0;
            disk_req_write     <= 1'b0;
            disk_req_flush     <= 1'b0;
            disk_req_lba       <= 64'h0;
            disk_req_word      <= 7'h0;
            disk_req_wdata     <= 32'h0;
            msix_trigger       <= 1'b0;
            pba_set_valid      <= 1'b0;
            pba_set_vector     <= 16'h0;

            sqe_dw_idx         <= 4'h0;
            cqe_dw_idx         <= 2'h0;
            cqe_result         <= 32'h0;
            cqe_status         <= 15'h0;
            last_error_count   <= 64'h0;
            last_error_sqid    <= 16'h0;
            last_error_cid     <= 16'h0;
            last_error_status  <= 16'h0;
            last_error_peloc   <= 16'h0;
            last_error_lba     <= 64'h0;
            last_error_nsid    <= 32'h0;
            timing_class       <= TIMING_ADMIN_SHORT;
            timing_effective_class <= TIMING_ADMIN_SHORT;
            timing_done_for_cmd <= 1'b0;
            timing_cmd_active  <= 1'b0;
            timing_saturated   <= 1'b0;
            timing_read_seen_hit <= 1'b0;
            timing_read_seen_miss <= 1'b0;
            timing_lfsr        <= 16'hACE1;
            timing_jitter_sample <= 16'h0000;
            timing_elapsed_cycles <= 32'h00000000;
            timing_target_cycles <= 32'h00000000;
            timing_wait_cycles <= 32'h00000000;
            data_dw_cnt        <= 11'h0;
            id_rom_offset      <= 13'h0;
            id_rom_addr        <= 13'h0;
            cc_en_prev         <= 1'b0;
            aer_registered     <= 1'b0;
            aer_cid            <= 16'h0000;
            aer_event_pending  <= 1'b0;
            aer_event_info     <= 32'h00000000;
            num_queues_granted <= 32'h00000000;
            feat_arbitration   <= 32'h00000000;
            feat_power_mgmt    <= 32'h00000000;
            feat_temp_threshold <= 32'h00000157;
            feat_write_cache   <= 32'h00000001;
            feat_irq_coalescing <= 32'h00000000;
            feat_async_event_cfg <= 32'h00000000;

            io_dir             <= IO_DIR_READ;
            io_slba            <= 64'h0;
            io_total_dw        <= 24'h0;
            io_dw_idx          <= 24'h0;
            io_host_data       <= 32'h0;
            io_host_addr       <= 64'h0;
            prp_entry_lo       <= 32'h0;
            prp_entry_hi       <= 32'h0;
            prp_cached_valid   <= 1'b0;
            prp_cached_index   <= 20'h0;
            prp_cached_base    <= 64'h0;
            dsm_range_idx      <= 8'h0;
            dsm_range_last     <= 8'h0;
            dsm_dw_idx         <= 2'h0;
            dsm_dw0            <= 32'h0;
            dsm_dw1            <= 32'h0;
            dsm_dw2            <= 32'h0;
            dsm_dw3            <= 32'h0;

            stat_data_units_read    <= 64'h{{ hex16 .NVMeSMART.DataUnitsRead }};
            stat_data_units_written <= 64'h{{ hex16 .NVMeSMART.DataUnitsWritten }};
            stat_host_read_cmds     <= 64'h{{ hex16 .NVMeSMART.HostReadCommands }};
            stat_host_write_cmds    <= 64'h{{ hex16 .NVMeSMART.HostWriteCommands }};
            stat_flush_cmds         <= 64'h0;
            stat_write_zero_cmds    <= 64'h0;
            stat_dataset_cmds       <= 64'h0;
            stat_cmds_completed     <= 64'h{{ hex16 .NVMeSMART.ControllerBusyMin }};
            stat_media_errors       <= 32'h{{ hex08 .NVMeSMART.MediaErrors }};
            stat_error_log_entries  <= 32'h{{ hex08 .NVMeSMART.ErrorLogEntries }};
            stat_unsafe_shutdowns   <= 32'h{{ hex08 .NVMeSMART.UnsafeShutdowns }};
            power_cycle_count       <= 32'h{{ hex08 .NVMeSMART.PowerCycles }};
            power_on_hours          <= 32'h{{ hex08 .NVMeSMART.PowerOnHours }};
            hour_second_count       <= 12'h0;
            second_tick             <= 27'h0;
            thermal_load            <= 8'h08;
            warning_temp_time       <= 32'h0;
            critical_temp_time      <= 32'h0;
        end else begin
            dma_rd_req     <= 1'b0;
            dma_wr_req     <= 1'b0;
            dma_wr_valid   <= 1'b0;
            disk_req_valid <= 1'b0;
            msix_trigger   <= 1'b0;
            irq_delivery_done <= 1'b0;
            pba_set_valid  <= 1'b0;
            if (timing_cmd_active && (timing_elapsed_cycles != 32'hFFFFFFFF))
                timing_elapsed_cycles <= timing_elapsed_cycles + 1'b1;

            if (cc_en) begin
                if (second_tick >= 27'd124999999) begin
                    second_tick <= 27'h0;
                    thermal_load <= (thermal_load == 8'h00) ? 8'h00 : (thermal_load - 1'b1);
                    if ((smart_temp_k >= 16'd343) && (warning_temp_time != 32'hFFFFFFFF))
                        warning_temp_time <= warning_temp_time + 1'b1;
                    if ((smart_temp_k >= 16'd358) && (critical_temp_time != 32'hFFFFFFFF))
                        critical_temp_time <= critical_temp_time + 1'b1;
                    if (hour_second_count >= 12'd3599) begin
                        hour_second_count <= 12'h0;
                        power_on_hours <= power_on_hours + 1'b1;
                    end else begin
                        hour_second_count <= hour_second_count + 1'b1;
                    end
                end else begin
                    second_tick <= second_tick + 1'b1;
                end
            end

            cc_en_prev <= cc_en;

            if (cc_en && doorbell_wr) begin
                if (doorbell_qid == 16'h0000) begin
                    if (doorbell_is_cq) begin
                        if (doorbell_val <= acq_last)
                            cq_head_db <= doorbell_val;
                        else if (acq_power2_entries)
                            cq_head_db <= doorbell_val & acq_last;
                    end else begin
                        if (doorbell_val <= asq_last)
                            sq_tail <= doorbell_val;
                        else if (asq_power2_entries)
                            sq_tail <= doorbell_val & asq_last;
                    end
                end else if (doorbell_qid == 16'h0001) begin
                    if (doorbell_is_cq) begin
                        if (doorbell_val <= io_cq_last)
                            io_cq_head_db <= doorbell_val;
                        else if (io_cq_power2_entries)
                            io_cq_head_db <= doorbell_val & io_cq_last;
                    end else begin
                        if (doorbell_val <= io_sq_last)
                            io_sq_tail <= doorbell_val;
                        else if (io_sq_power2_entries)
                            io_sq_tail <= doorbell_val & io_sq_last;
                    end
                end
            end

            if (cc_reset_event) begin
                state              <= S_IDLE;
                return_state       <= S_IDLE;
                active_qid         <= 16'h0000;

                sq_tail            <= 16'h0;
                sq_head            <= 16'h0;
                cq_tail            <= 16'h0;
                cq_head_db         <= 16'h0;
                cq_phase           <= 1'b1;
                if (cc_start_event) begin
                    admin_aqa    <= aqa;
                    admin_asq_lo <= asq_lo;
                    admin_asq_hi <= asq_hi;
                    admin_acq_lo <= acq_lo;
                    admin_acq_hi <= acq_hi;
                end else begin
                    admin_aqa    <= 32'h0;
                    admin_asq_lo <= 32'h0;
                    admin_asq_hi <= 32'h0;
                    admin_acq_lo <= 32'h0;
                    admin_acq_hi <= 32'h0;
                end

                io_sq_created      <= 1'b0;
                io_cq_created      <= 1'b0;
                io_sq_base         <= 64'h0;
                io_cq_base         <= 64'h0;
                io_sq_last         <= 16'h0;
                io_cq_last         <= 16'h0;
                io_sq_tail         <= 16'h0;
                io_sq_head         <= 16'h0;
                io_cq_tail         <= 16'h0;
                io_cq_head_db      <= 16'h0;
                io_cq_phase        <= 1'b1;
                io_vector          <= 16'h0;

                sqe_dw_idx         <= 4'h0;
                cqe_dw_idx         <= 2'h0;
                cqe_result         <= 32'h0;
                cqe_status         <= 15'h0;
                last_error_count   <= 64'h0;
                last_error_sqid    <= 16'h0;
                last_error_cid     <= 16'h0;
                last_error_status  <= 16'h0;
                last_error_peloc   <= 16'h0;
                last_error_lba     <= 64'h0;
                last_error_nsid    <= 32'h0;
                timing_class       <= TIMING_ADMIN_SHORT;
                timing_effective_class <= TIMING_ADMIN_SHORT;
                timing_done_for_cmd <= 1'b0;
                timing_cmd_active  <= 1'b0;
                timing_saturated   <= 1'b0;
                timing_read_seen_hit <= 1'b0;
                timing_read_seen_miss <= 1'b0;
                timing_jitter_sample <= 16'h0000;
                timing_elapsed_cycles <= 32'h00000000;
                timing_target_cycles <= 32'h00000000;
                timing_wait_cycles <= 32'h00000000;
                data_dw_cnt        <= 11'h0;
                id_rom_offset      <= 13'h0;
                id_rom_addr        <= 13'h0;
                aer_registered     <= 1'b0;
                aer_cid            <= 16'h0000;
                aer_event_pending  <= 1'b0;
                aer_event_info     <= 32'h00000000;
                num_queues_granted <= 32'h00000000;

                io_dir             <= IO_DIR_READ;
                io_slba            <= 64'h0;
                io_total_dw        <= 24'h0;
                io_dw_idx          <= 24'h0;
                io_host_data       <= 32'h0;
                io_host_addr       <= 64'h0;
                prp_entry_lo       <= 32'h0;
                prp_entry_hi       <= 32'h0;
                prp_cached_valid   <= 1'b0;
                prp_cached_index   <= 20'h0;
                prp_cached_base    <= 64'h0;
                dsm_range_idx      <= 8'h0;
                dsm_range_last     <= 8'h0;
                dsm_dw_idx         <= 2'h0;
                dsm_dw0            <= 32'h0;
                dsm_dw1            <= 32'h0;
                dsm_dw2            <= 32'h0;
                dsm_dw3            <= 32'h0;
                warning_temp_time  <= 32'h0;
                critical_temp_time <= 32'h0;
                feat_arbitration   <= 32'h00000000;
                feat_power_mgmt    <= 32'h00000000;
                feat_temp_threshold <= 32'h00000157;
                feat_write_cache   <= 32'h00000001;
                feat_irq_coalescing <= 32'h00000000;
                feat_async_event_cfg <= 32'h00000000;
                if (cc_stop_event)
                    stat_unsafe_shutdowns <= stat_unsafe_shutdowns + 1'b1;
            end else if (!dma_enabled) begin
                state <= S_IDLE;
                return_state <= S_IDLE;
                timing_cmd_active <= 1'b0;
                timing_done_for_cmd <= 1'b0;
            end else if (!cc_en && state != S_SHUTDOWN) begin
                state <= S_IDLE;
            end else begin
                case (state)
                    S_IDLE: begin
                        if (aer_registered && aer_event_pending) begin
                            cqe[0] <= aer_event_info;
                            cqe[1] <= 32'h00000000;
                            cqe[2] <= {16'h0000, sq_head};
                            cqe[3] <= {15'h0000, cq_phase, aer_cid};
                            cqe_dw_idx <= 2'h0;
                            state <= S_AER_POST;
                        end else if (aer_registered && !aer_event_pending && (smart_warning_byte != 8'h00)) begin
                            aer_event_pending <= 1'b1;
                            aer_event_info <= 32'h00000002;
                        end else if (irq_delivery_valid && irq_delivery_ready) begin
                            dma_wr_req   <= 1'b1;
                            dma_wr_valid <= 1'b1;
                            dma_wr_addr  <= msix_vector_addr;
                            dma_wr_data  <= msix_vector_data;
                            dma_wr_be    <= 4'hF;
                            return_state <= S_IDLE;
                            state        <= S_WAIT_DMA_WR;
                        end else if ((sq_tail != sq_head) && admin_queue_config_valid) begin
                            active_qid  <= 16'h0000;
                            dma_rd_req  <= 1'b1;
                            dma_rd_addr <= asq_base + ({48'h0, sq_head} * 64);
                            dma_rd_len  <= 10'd16;
                            sqe_dw_idx  <= 4'h0;
                            timing_cmd_active <= 1'b1;
                            timing_done_for_cmd <= 1'b0;
                            timing_class <= TIMING_ADMIN_SHORT;
                            timing_read_seen_hit <= 1'b0;
                            timing_read_seen_miss <= 1'b0;
                            timing_elapsed_cycles <= 32'h00000000;
                            state       <= S_FETCH_SQE;
                        end else if (NVME_ENABLE_IO_QUEUES && io_sq_created && io_cq_created && (io_sq_tail != io_sq_head)) begin
                            active_qid  <= 16'h0001;
                            dma_rd_req  <= 1'b1;
                            dma_rd_addr <= io_sq_base + ({48'h0, io_sq_head} * 64);
                            dma_rd_len  <= 10'd16;
                            sqe_dw_idx  <= 4'h0;
                            timing_cmd_active <= 1'b1;
                            timing_done_for_cmd <= 1'b0;
                            timing_class <= TIMING_ADMIN_SHORT;
                            timing_read_seen_hit <= 1'b0;
                            timing_read_seen_miss <= 1'b0;
                            timing_elapsed_cycles <= 32'h00000000;
                            state       <= S_FETCH_SQE;
                        end
                    end

                    S_FETCH_SQE: begin
                        if (dma_rd_valid) begin
                            sqe[sqe_dw_idx] <= dma_rd_data;
                            sqe_dw_idx <= sqe_dw_idx + 1'b1;
                        end
                        if (dma_rd_done)
                            state <= S_DECODE_CMD;
                    end

                    S_DECODE_CMD: begin
                        cqe_result <= 32'h00000000;
                        cqe_status <= 15'h0000;
                        timing_class <= TIMING_ADMIN_SHORT;
                        timing_read_seen_hit <= 1'b0;
                        timing_read_seen_miss <= 1'b0;
                        timing_jitter_sample <= timing_mix_lfsr(timing_lfsr, {active_qid[7:0], cmd_opcode, cmd_cid});
                        timing_lfsr <= timing_mix_lfsr(timing_lfsr, cmd_slba[31:0] ^ {active_qid, cmd_cid});

                        if (active_io && NVME_STUB_IO_DATA) begin
                            case (cmd_opcode)
                                8'h00,
                                8'h09: cqe_status <= 15'h0000;
                                default: cqe_status <= 15'h0001;
                            endcase
                            state <= S_BUILD_CQE;
                        end else if (active_io) begin
                            case (cmd_opcode)
                                8'h00: begin
                                    timing_class <= TIMING_FLUSH;
                                    prp_cached_valid <= 1'b0;
                                    disk_req_valid <= 1'b1;
                                    disk_req_write <= 1'b0;
                                    disk_req_flush <= 1'b1;
                                    disk_req_lba   <= 64'h0;
                                    disk_req_word  <= 7'h0;
                                    stat_flush_cmds <= stat_flush_cmds + 1'b1;
                                    state <= S_IO_FLUSH_WAIT;
                                end
                                8'h01: begin
                                    timing_class <= TIMING_WRITE;
                                    if (NVME_ZERO_IO_READS) begin
                                        state <= S_BUILD_CQE;
                                    end else if (!cmd_mdts_ok) begin
                                        cqe_status <= NVME_SC_INVALID_FIELD;
                                        state <= S_BUILD_CQE;
                                    end else if (cmd_lba_ok) begin
                                        io_dir      <= IO_DIR_WRITE;
                                        io_slba     <= cmd_slba;
                                        io_total_dw <= cmd_total_dw;
                                        io_dw_idx   <= 24'h0;
                                        prp_cached_valid <= 1'b0;
                                        stat_host_write_cmds <= stat_host_write_cmds + 1'b1;
                                        stat_data_units_written <= stat_data_units_written + data_units_for_nlb(cmd_nlb_count);
                                        thermal_load <= (thermal_load == 8'hFF) ? 8'hFF : (thermal_load + 1'b1);
                                        return_state <= NVME_PRP_ONLY_IO ? S_IO_ADVANCE : S_IO_WRITE_DMA_REQ;
                                        state       <= S_RESOLVE_IO_PRP;
                                    end else begin
                                        cqe_status <= NVME_SC_LBA_RANGE;
                                        state <= S_BUILD_CQE;
                                    end
                                end
                                8'h02: begin
                                    timing_class <= (NVME_ZERO_IO_READS || NVME_PRP_ONLY_IO) ? TIMING_READ_MISS_ZERO : TIMING_READ_PENDING;
                                    if (!cmd_mdts_ok) begin
                                        cqe_status <= NVME_SC_INVALID_FIELD;
                                        state <= S_BUILD_CQE;
                                    end else if (cmd_lba_ok) begin
                                        io_dir      <= IO_DIR_READ;
                                        io_slba     <= cmd_slba;
                                        io_total_dw <= cmd_total_dw;
                                        io_dw_idx   <= 24'h0;
                                        prp_cached_valid <= 1'b0;
                                        stat_host_read_cmds <= stat_host_read_cmds + 1'b1;
                                        stat_data_units_read <= stat_data_units_read + data_units_for_nlb(cmd_nlb_count);
                                        thermal_load <= (thermal_load == 8'hFF) ? 8'hFF : (thermal_load + 1'b1);
                                        if (NVME_PRP_ONLY_IO) begin
                                            return_state <= S_IO_ADVANCE;
                                            state <= S_RESOLVE_IO_PRP;
                                        end else if (NVME_ZERO_IO_READS) begin
                                            io_host_data <= 32'h00000000;
                                            return_state <= S_IO_READ_HOST_WR;
                                            state <= S_RESOLVE_IO_PRP;
                                        end else begin
                                            state <= S_IO_READ_DISK_REQ;
                                        end
                                    end else begin
                                        cqe_status <= NVME_SC_LBA_RANGE;
                                        state <= S_BUILD_CQE;
                                    end
                                end
                                8'h08: begin
                                    timing_class <= TIMING_WRITE_ZEROES;
                                    if ((cmd_cdw12[31:16] != 16'h0000) ||
                                        (cmd_cdw13 != 32'h00000000) ||
                                        (cmd_cdw14 != 32'h00000000) ||
                                        (cmd_cdw15 != 32'h00000000)) begin
                                        cqe_status <= NVME_SC_INVALID_FIELD;
                                        state <= S_BUILD_CQE;
                                    end else if (!cmd_mdts_ok) begin
                                        cqe_status <= NVME_SC_INVALID_FIELD;
                                        state <= S_BUILD_CQE;
                                    end else if (cmd_lba_ok) begin
                                        io_dir      <= IO_DIR_ZERO;
                                        io_slba     <= cmd_slba;
                                        io_total_dw <= cmd_total_dw;
                                        io_dw_idx   <= 24'h0;
                                        prp_cached_valid <= 1'b0;
                                        stat_write_zero_cmds <= stat_write_zero_cmds + 1'b1;
                                        stat_data_units_written <= stat_data_units_written + data_units_for_nlb(cmd_nlb_count);
                                        disk_req_valid <= 1'b1;
                                        disk_req_write <= 1'b1;
                                        disk_req_flush <= 1'b1;
                                        disk_req_lba   <= cmd_slba;
                                        disk_req_word  <= 7'h0;
                                        disk_req_wdata <= {15'h0000, cmd_nlb_count};
                                        state          <= S_IO_FLUSH_WAIT;
                                    end else begin
                                        cqe_status <= NVME_SC_LBA_RANGE;
                                        state <= S_BUILD_CQE;
                                    end
                                end
                                8'h09: begin
                                    timing_class <= TIMING_DSM;
                                    stat_dataset_cmds <= stat_dataset_cmds + 1'b1;
                                    if (cmd_nsid != 32'd1) begin
                                        cqe_status <= NVME_SC_INVALID_NS;
                                        state <= S_BUILD_CQE;
                                    end else if (((cmd_cdw11 & 32'hFFFFFFFB) != 32'h00000000) ||
                                                 (cmd_cdw10[31:8] != 24'h000000)) begin
                                        cqe_status <= NVME_SC_INVALID_FIELD;
                                        state <= S_BUILD_CQE;
                                    end else if (cmd_cdw11[2]) begin
                                        // Deallocate: invalidate backing-cache slots in each range.
                                        io_total_dw    <= ({16'h0000, cmd_cdw10[7:0]} + 24'd1) << 2;
                                        io_dw_idx      <= 24'h0;
                                        dsm_range_idx  <= 8'h0;
                                        dsm_range_last <= cmd_cdw10[7:0];
                                        dsm_dw_idx     <= 2'h0;
                                        prp_cached_valid <= 1'b0;
                                        return_state   <= S_DSM_FETCH_REQ;
                                        state          <= S_RESOLVE_IO_PRP;
                                    end else begin
                                        // Advisory (no Deallocate): complete without mutating cache.
                                        state <= S_BUILD_CQE;
                                    end
                                end
                                default: begin
                                    // Unhandled IO opcode -> Invalid Command Opcode (SC=0x01).
                                    cqe_status <= 15'h0001;
                                    state <= S_BUILD_CQE;
                                end
                            endcase
                        end else begin
                            case (cmd_opcode)
                                8'h00: begin
                                    if (cmd_cdw10[15:0] == 16'h0001) begin
                                        io_sq_created <= 1'b0;
                                        io_sq_tail <= 16'h0;
                                        io_sq_head <= 16'h0;
                                    end
                                    state <= S_BUILD_CQE;
                                end

                                8'h01: begin
                                    if (!NVME_ENABLE_IO_QUEUES) begin
                                        cqe_status <= 15'h0001;
                                    end else if ((cmd_cdw10[15:0] == 16'h0001) &&
                                                 (cmd_cdw10[31:16] != 16'h0000) &&
                                                 (cmd_cdw11[0] == 1'b1) &&
                                                 (cmd_cdw11[31:16] == 16'h0001) &&
                                                 io_cq_created &&
                                                 cmd_prp1_page_valid) begin
                                        io_sq_base <= cmd_prp1 & 64'hFFFFFFFFFFFFF000;
                                        io_sq_last <= cmd_cdw10[31:16];
                                        io_sq_tail <= 16'h0;
                                        io_sq_head <= 16'h0;
                                        io_sq_created <= 1'b1;
                                    end else begin
                                        cqe_status <= 15'h0001;
                                    end
                                    state <= S_BUILD_CQE;
                                end

	                                8'h02: begin
                                    timing_class <= TIMING_GET_LOG;
	                                    case (cmd_cdw10[7:0])
                                        LOG_PAGE_SUPPORTED,
                                        LOG_PAGE_ERROR,
                                        LOG_PAGE_SMART,
                                        LOG_PAGE_FW_SLOT: begin
                                            data_dw_cnt <= 11'h0;
                                            state <= S_EXEC_LOGPAGE;
                                        end
                                        default: begin
                                            cqe_status <= NVME_SC_INVALID_FIELD;
                                            state <= S_BUILD_CQE;
                                        end
                                    endcase
                                end

                                8'h04: begin
                                    if (cmd_cdw10[15:0] == 16'h0001) begin
                                        io_cq_created <= 1'b0;
                                        io_cq_tail <= 16'h0;
                                        io_cq_head_db <= 16'h0;
                                    end
                                    state <= S_BUILD_CQE;
                                end

                                8'h05: begin
                                    if (!NVME_ENABLE_IO_QUEUES) begin
                                        cqe_status <= 15'h0001;
                                    end else if ((cmd_cdw10[15:0] == 16'h0001) &&
                                                 (cmd_cdw10[31:16] != 16'h0000) &&
                                                 (cmd_cdw11[0] == 1'b1) &&
                                                 cmd_prp1_page_valid) begin
                                        io_cq_base <= cmd_prp1 & 64'hFFFFFFFFFFFFF000;
                                        io_cq_last <= cmd_cdw10[31:16];
                                        io_cq_tail <= 16'h0;
                                        io_cq_head_db <= 16'h0;
                                        io_cq_phase <= 1'b1;
                                        io_vector <= (cmd_cdw11[31:16] >= NVME_NUM_MSIX_VECTORS) ? 16'h0000 : cmd_cdw11[31:16];
                                        io_cq_created <= 1'b1;
                                    end else begin
                                        cqe_status <= 15'h0001;
                                    end
                                    state <= S_BUILD_CQE;
                                end

	                                8'h06: begin
                                    timing_class <= TIMING_IDENTIFY;
		                                    case (identify_cns)
	                                        8'h00,
	                                        8'h11: begin
	                                            if (cmd_nsid_selects_ns1) begin
	                                                id_rom_offset <= 13'h1000;
	                                                id_rom_addr <= 13'h1000;
	                                                data_dw_cnt <= 11'h0;
	                                                state <= S_EXEC_IDENTIFY;
	                                            end else begin
	                                                cqe_status <= NVME_SC_INVALID_NS;
	                                                state <= S_BUILD_CQE;
	                                            end
	                                        end
	                                        8'h01: begin
	                                            id_rom_offset <= 13'h0000;
	                                            id_rom_addr <= 13'h0000;
	                                            data_dw_cnt <= 11'h0;
	                                            state <= S_EXEC_IDENTIFY;
	                                        end
	                                        8'h02,
	                                        8'h10: begin
	                                            data_dw_cnt <= 11'h0;
	                                            state <= S_EXEC_NSLIST;
	                                        end
	                                        8'h03: begin
	                                            if (cmd_nsid_selects_ns1) begin
	                                                data_dw_cnt <= 11'h0;
	                                                state <= S_EXEC_NSID_DESC;
	                                            end else begin
	                                                cqe_status <= NVME_SC_INVALID_NS;
	                                                state <= S_BUILD_CQE;
	                                            end
	                                        end
	                                        default: begin
	                                            cqe_status <= NVME_SC_INVALID_FIELD;
	                                            state <= S_BUILD_CQE;
	                                        end
	                                    endcase
                                end

                                8'h08: begin
                                    state <= S_BUILD_CQE;
                                end

                                8'h09: begin
                                    case (cmd_cdw10[7:0])
                                        8'h01: feat_arbitration <= cmd_cdw11;
                                        8'h02: feat_power_mgmt <= cmd_cdw11;
                                        8'h04: feat_temp_threshold <= cmd_cdw11;
                                        8'h06: feat_write_cache <= cmd_cdw11;
                                        8'h07: begin
                                            num_queues_granted <= 32'h00000000;
                                            cqe_result <= 32'h00000000;
                                        end
                                        8'h08, 8'h09, 8'h0A: ; // minimal: accept without persisting
                                        8'h0B: feat_async_event_cfg <= cmd_cdw11;
                                        default: cqe_status <= NVME_SC_INVALID_FIELD;
                                    endcase
                                    state <= S_BUILD_CQE;
                                end

                                8'h0A: begin
                                    case (cmd_cdw10[7:0])
                                        8'h01: cqe_result <= feat_arbitration;
                                        8'h02: cqe_result <= feat_power_mgmt;
                                        8'h04: cqe_result <= feat_temp_threshold;
                                        8'h06: cqe_result <= feat_write_cache;
                                        8'h07: cqe_result <= num_queues_granted;
                                        8'h08: cqe_result <= feat_irq_coalescing;
                                        8'h09, 8'h0A: cqe_result <= 32'h00000000;
                                        8'h0B: cqe_result <= feat_async_event_cfg;
                                        default: cqe_status <= NVME_SC_INVALID_FIELD;
                                    endcase
                                    state <= S_BUILD_CQE;
                                end

	                                8'h0C: begin
	                                    if (aer_registered) begin
	                                        cqe_status <= NVME_SC_INVALID_FIELD;
	                                        state <= S_BUILD_CQE;
	                                    end else begin
	                                        aer_cid <= cmd_cid;
	                                        aer_registered <= 1'b1;
	                                        sq_head <= sq_head_next;
	                                        timing_cmd_active <= 1'b0;
	                                        state <= S_IDLE;
	                                    end
	                                end

	                                8'h80: begin
                                    timing_class <= TIMING_FORMAT;
	                                    if (!format_nvm_ok) begin
                                        cqe_status <= NVME_SC_INVALID_FORMAT;
                                        state <= S_BUILD_CQE;
                                    end else begin
                                        disk_req_valid <= 1'b1;
                                        disk_req_write <= 1'b1;
                                        disk_req_flush <= 1'b1;
                                        disk_req_lba   <= 64'h0;
                                        disk_req_word  <= 7'h0;
                                        disk_req_wdata <= 32'hFFFFFFFF;
                                        state <= S_FORMAT_CLEAR;
                                    end
                                end

                                default: begin
                                    // Unhandled admin opcode -> Invalid Command Opcode (SC=0x01).
                                    cqe_status <= 15'h0001;
                                    state <= S_BUILD_CQE;
                                end
                            endcase
                        end
                    end

                    S_EXEC_IDENTIFY: begin
                        if (data_dw_cnt == 11'h0) begin
                            id_rom_addr <= id_rom_offset + 13'h0004;
                            data_dw_cnt <= 11'h1;
                        end else begin
                            dma_wr_req   <= 1'b1;
                            dma_wr_valid <= 1'b1;
                            dma_wr_addr  <= prp_data_addr({13'h0, data_dw_cnt - 11'h1});
                            dma_wr_data  <= identify_data_word(id_rom_offset, data_dw_cnt - 11'h1, id_rom_data);
                            dma_wr_be    <= 4'hF;
                            if (data_dw_cnt >= 11'd1024)
                                return_state <= S_BUILD_CQE;
                            else begin
                                if (data_dw_cnt < 11'd1023)
                                    id_rom_addr <= id_rom_offset + {data_dw_cnt + 11'h1, 2'b00};
                                data_dw_cnt <= data_dw_cnt + 1'b1;
                                return_state <= S_EXEC_IDENTIFY;
                            end
                            state <= S_WAIT_DMA_WR;
                        end
                    end

                    S_EXEC_NSLIST: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= prp_data_addr({13'h0, data_dw_cnt});
	                        dma_wr_data  <= ((data_dw_cnt == 11'h0) && cmd_nsid_lists_ns1) ? 32'h00000001 : 32'h00000000;
                        dma_wr_be    <= 4'hF;
                        if (data_dw_cnt >= 11'd1023)
                            return_state <= S_BUILD_CQE;
                        else begin
                            data_dw_cnt <= data_dw_cnt + 1'b1;
                            return_state <= S_EXEC_NSLIST;
                        end
                        state <= S_WAIT_DMA_WR;
                    end

                    S_EXEC_ZERO4K: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= prp_data_addr({13'h0, data_dw_cnt});
                        dma_wr_data  <= 32'h00000000;
                        dma_wr_be    <= 4'hF;
                        if (data_dw_cnt >= 11'd1023)
                            return_state <= S_BUILD_CQE;
                        else begin
                            data_dw_cnt <= data_dw_cnt + 1'b1;
                            return_state <= S_EXEC_ZERO4K;
                        end
                        state <= S_WAIT_DMA_WR;
                    end

                    S_EXEC_NSID_DESC: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= prp_data_addr({13'h0, data_dw_cnt});
                        dma_wr_be    <= 4'hF;
                        if (cmd_nsid_selects_ns1) begin
                            case (data_dw_cnt)
                                11'h000: dma_wr_data <= 32'h00001002; // NGUID descriptor: type=2, len=16
                                11'h001: dma_wr_data <= 32'hDDCC9ED1;
                                11'h002: dma_wr_data <= 32'hC24308EF;
                                11'h003: dma_wr_data <= 32'h25F2BB9D;
                                11'h004: dma_wr_data <= 32'h11BA97CE;
                                default: dma_wr_data <= 32'h00000000;
                            endcase
                        end else begin
                            dma_wr_data <= 32'h00000000;
                        end
                        if (data_dw_cnt >= 11'd1023)
                            return_state <= S_BUILD_CQE;
                        else begin
                            data_dw_cnt <= data_dw_cnt + 1'b1;
                            return_state <= S_EXEC_NSID_DESC;
                        end
                        state <= S_WAIT_DMA_WR;
                    end

                    S_EXEC_LOGPAGE: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= prp_data_addr({13'h0, data_dw_cnt});
                        dma_wr_be    <= 4'hF;
                        dma_wr_data  <= log_page_word(data_dw_cnt);
                        if (data_dw_cnt >= cmd_log_last_dw)
                            return_state <= S_BUILD_CQE;
                        else begin
                            data_dw_cnt <= data_dw_cnt + 1'b1;
                            return_state <= S_EXEC_LOGPAGE;
                        end
                        state <= S_WAIT_DMA_WR;
                    end

                    S_BUILD_CQE: begin
                        if (NVME_TIMING_ENABLE && !timing_done_for_cmd) begin
                            state <= S_TIMING_PREP;
                        end else begin
                            if (cqe_status != 15'h0000) begin
                                stat_error_log_entries <= stat_error_log_entries + 1'b1;
                                last_error_count <= {32'h00000000, stat_error_log_entries + 1'b1};
                                last_error_sqid <= active_qid;
                                last_error_cid <= cmd_cid;
                                last_error_status <= {cqe_status, 1'b0};
                                last_error_peloc <= 16'h0000;
                                last_error_lba <= (active_qid == 16'h0000) ? 64'h0000000000000000 : cmd_slba;
                                last_error_nsid <= cmd_nsid;
                            end
                            cqe[0] <= cqe_result;
                            cqe[1] <= 32'h00000000;
                            cqe[2] <= {active_qid, active_sq_head_next};
                            cqe[3] <= {cqe_status, active_cq_phase, cmd_cid};
                            cqe_dw_idx <= 2'h0;
                            state <= S_POST_CQE;
                        end
                    end

                    S_TIMING_PREP: begin
                        timing_done_for_cmd <= 1'b1;
                        timing_effective_class <= timing_completion_class;
                        timing_target_cycles <= timing_profile_cycles(
                            timing_completion_class,
                            cmd_nlb_count,
                            timing_dsm_ranges,
                            timing_jitter_sample
                        );
                        state <= S_TIMING_EVAL;
                    end

                    S_TIMING_EVAL: begin
                        if (timing_target_cycles > timing_elapsed_cycles) begin
                            timing_wait_cycles <= timing_target_cycles - timing_elapsed_cycles;
                            timing_saturated <= 1'b0;
                            state <= S_TIMING_DELAY;
                        end else begin
                            timing_wait_cycles <= 32'h00000000;
                            timing_saturated <= 1'b1;
                            state <= S_BUILD_CQE;
                        end
                    end

                    S_TIMING_DELAY: begin
                        if (timing_wait_cycles <= 32'd1) begin
                            timing_wait_cycles <= 32'h00000000;
                            state <= S_BUILD_CQE;
                        end else begin
                            timing_wait_cycles <= timing_wait_cycles - 32'd1;
                        end
                    end

                    S_POST_CQE: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= active_cq_base + {44'h0, active_cq_tail, 4'h0}
                                      + {62'h0, cqe_dw_idx, 2'b00};
                        dma_wr_data  <= cqe[cqe_dw_idx];
                        dma_wr_be    <= 4'hF;

                        if (cqe_dw_idx == 2'd3) begin
                            cqe_dw_idx <= 2'h0;
                            return_state <= S_SEND_MSIX;
                        end else begin
                            cqe_dw_idx <= cqe_dw_idx + 1'b1;
                            return_state <= S_POST_CQE;
                        end
                        state <= S_WAIT_DMA_WR;
                    end

                    S_AER_POST: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= acq_base + {44'h0, cq_tail, 4'h0}
                                      + {62'h0, cqe_dw_idx, 2'b00};
                        dma_wr_data  <= cqe[cqe_dw_idx];
                        dma_wr_be    <= 4'hF;

                        if (cqe_dw_idx == 2'd3) begin
                            cqe_dw_idx <= 2'h0;
                            return_state <= S_AER_FINISH;
                        end else begin
                            cqe_dw_idx <= cqe_dw_idx + 1'b1;
                            return_state <= S_AER_POST;
                        end
                        state <= S_WAIT_DMA_WR;
                    end

                    S_AER_FINISH: begin
                        aer_registered    <= 1'b0;
                        aer_event_pending <= 1'b0;
                        if (cq_tail >= acq_last) begin
                            cq_tail  <= 16'h0;
                            cq_phase <= ~cq_phase;
                        end else begin
                            cq_tail  <= cq_tail_next;
                        end
                        pba_set_valid  <= 1'b1;
                        pba_set_vector <= 16'h0000;
                        state <= S_IDLE;
                    end

                    S_SEND_MSIX: begin
                        stat_cmds_completed <= stat_cmds_completed + 1'b1;
                        timing_cmd_active <= 1'b0;
                        if (active_io) begin
                            io_sq_head <= io_sq_head_next;
                            if (io_cq_tail >= io_cq_last) begin
                                io_cq_tail <= 16'h0;
                                io_cq_phase <= ~io_cq_phase;
                            end else begin
                                io_cq_tail <= io_cq_tail_next;
                            end
                        end else begin
                            sq_head <= sq_head_next;
                            if (cq_tail >= acq_last) begin
                                cq_tail <= 16'h0;
                                cq_phase <= ~cq_phase;
                            end else begin
                                cq_tail <= cq_tail_next;
                            end
                        end

                        pba_set_valid  <= 1'b1;
                        pba_set_vector <= active_io ? io_vector : 16'h0000;
                        state <= S_IDLE;
                    end

                    S_WAIT_DMA_WR: begin
                        if (dma_wr_done) begin
                            if (return_state == S_IDLE)
                                irq_delivery_done <= 1'b1;
                            state <= return_state;
                        end
                    end

                    S_RESOLVE_IO_PRP: begin
	                        if (io_prp1_invalid || io_prp2_invalid) begin
	                            cqe_status <= NVME_SC_PRP_OFFSET_INVALID;
	                            state <= S_BUILD_CQE;
	                        end else if (!io_prp_after_first_page) begin
	                            io_host_addr <= cmd_prp1 + {32'h00000000, io_prp_byte_off};
	                            state <= return_state;
	                        end else if (!io_prp_uses_list) begin
	                            io_host_addr <= cmd_prp2 + {32'h00000000, io_prp_after_first};
	                            state <= return_state;
                        end else if (prp_cached_valid && (prp_cached_index == io_prp_list_index)) begin
                            io_host_addr <= prp_cached_base + {52'h0000000000000, io_prp_after_first[11:0]};
                            state <= return_state;
                        end else begin
                            dma_rd_req  <= 1'b1;
                            dma_rd_addr <= io_prp_list_entry_addr;
                            dma_rd_len  <= 10'd1;
                            state <= S_PRP_LIST_RD_LO;
                        end
                    end

                    S_PRP_LIST_RD_LO: begin
                        if (dma_rd_valid)
                            prp_entry_lo <= dma_rd_data;
                        if (dma_rd_done) begin
                            dma_rd_req  <= 1'b1;
                            dma_rd_addr <= io_prp_list_entry_addr + 64'd4;
                            dma_rd_len  <= 10'd1;
                            state <= S_PRP_LIST_RD_HI;
                        end
                    end

                    S_PRP_LIST_RD_HI: begin
                        if (dma_rd_valid)
                            prp_entry_hi <= dma_rd_data;
                        if (dma_rd_done) begin
		                            if (io_prp_list_index > PRP_LIST_MAX_ENTRIES) begin
                                    cqe_status <= NVME_SC_INVALID_FIELD;
                                    state <= S_BUILD_CQE;
                                end else if (prp_list_entry_invalid) begin
		                                cqe_status <= NVME_SC_PRP_OFFSET_INVALID;
		                                state <= S_BUILD_CQE;
		                            end else begin
                                prp_cached_valid <= 1'b1;
                                prp_cached_index <= io_prp_list_index;
                                prp_cached_base  <= prp_list_page_base;
                                io_host_addr <= prp_list_page_base + {52'h0000000000000, io_prp_after_first[11:0]};
                                state <= return_state;
                            end
                        end
                    end

                    S_DSM_FETCH_REQ: begin
                        dma_rd_req  <= 1'b1;
                        dma_rd_addr <= io_host_addr;
                        dma_rd_len  <= 10'd1;
                        state <= S_DSM_FETCH_WAIT;
                    end

                    S_DSM_FETCH_WAIT: begin
                        if (dma_rd_valid) begin
                            case (dsm_dw_idx)
                                2'd0: dsm_dw0 <= dma_rd_data;
                                2'd1: dsm_dw1 <= dma_rd_data;
                                2'd2: dsm_dw2 <= dma_rd_data;
                                default: dsm_dw3 <= dma_rd_data;
                            endcase
                        end

                        if (dma_rd_done) begin
                            if (dsm_dw_idx != 2'd3) begin
                                dsm_dw_idx   <= dsm_dw_idx + 1'b1;
                                io_dw_idx    <= io_dw_idx + 1'b1;
                                return_state <= S_DSM_FETCH_REQ;
                                state        <= S_RESOLVE_IO_PRP;
                            end else if (dsm_dw1 == 32'h00000000) begin
                                if (dsm_range_idx == dsm_range_last) begin
                                    state <= S_BUILD_CQE;
                                end else begin
                                    dsm_range_idx <= dsm_range_next;
                                    dsm_dw_idx    <= 2'h0;
                                    io_dw_idx     <= {14'h0000, dsm_range_next, 2'b00};
                                    return_state  <= S_DSM_FETCH_REQ;
                                    state         <= S_RESOLVE_IO_PRP;
                                end
                            end else if (dsm_range_ok) begin
                                disk_req_valid <= 1'b1;
                                disk_req_write <= 1'b1;
                                disk_req_flush <= 1'b1;
                                disk_req_lba   <= dsm_lba_value;
                                disk_req_word  <= 7'h0;
                                disk_req_wdata <= dsm_dw1;
                                state          <= S_DSM_CLEAR_WAIT;
                            end else begin
                                cqe_status <= NVME_SC_LBA_RANGE;
                                state <= S_BUILD_CQE;
                            end
                        end
                    end

                    S_DSM_CLEAR_WAIT: begin
                        if (disk_req_done) begin
                            if (disk_error) begin
                                cqe_status <= NVME_SC_DATA_XFER_ERROR;
                                state <= S_BUILD_CQE;
                            end else if (dsm_range_idx == dsm_range_last) begin
                                state <= S_BUILD_CQE;
                            end else begin
                                dsm_range_idx <= dsm_range_next;
                                dsm_dw_idx    <= 2'h0;
                                io_dw_idx     <= {14'h0000, dsm_range_next, 2'b00};
                                return_state  <= S_DSM_FETCH_REQ;
                                state         <= S_RESOLVE_IO_PRP;
                            end
                        end
                    end

                    S_FORMAT_CLEAR: begin
                        if (disk_req_done) begin
                            if (disk_error)
                                cqe_status <= NVME_SC_DATA_XFER_ERROR;
                            state <= S_BUILD_CQE;
                        end
                    end

                    S_IO_WRITE_DMA_REQ: begin
                        dma_rd_req  <= 1'b1;
                        dma_rd_addr <= io_host_addr;
                        dma_rd_len  <= 10'd1;
                        state <= S_IO_WRITE_DMA_WAIT;
                    end

                    S_IO_WRITE_DMA_WAIT: begin
                        if (dma_rd_valid)
                            io_host_data <= dma_rd_data;
                        if (dma_rd_done) begin
                            disk_req_valid <= 1'b1;
                            disk_req_write <= 1'b1;
                            disk_req_flush <= 1'b0;
                            disk_req_lba   <= io_disk_lba;
                            disk_req_word  <= io_disk_word;
                            disk_req_wdata <= dma_rd_valid ? dma_rd_data : io_host_data;
                            state <= S_IO_DISK_WR_WAIT;
                        end
                    end

                    S_IO_ZERO_REQ: begin
                        disk_req_valid <= 1'b1;
                        disk_req_write <= 1'b1;
                        disk_req_flush <= 1'b0;
                        disk_req_lba   <= io_disk_lba;
                        disk_req_word  <= io_disk_word;
                        disk_req_wdata <= 32'h00000000;
                        state <= S_IO_DISK_WR_WAIT;
                    end

                    S_IO_DISK_WR_WAIT: begin
                        if (disk_req_done) begin
	                            if (disk_error)
	                                cqe_status <= NVME_SC_DATA_XFER_ERROR;
                            state <= S_IO_ADVANCE;
                        end
                    end

                    S_IO_READ_DISK_REQ: begin
                        disk_req_valid <= 1'b1;
                        disk_req_write <= 1'b0;
                        disk_req_flush <= 1'b0;
                        disk_req_lba   <= io_disk_lba;
                        disk_req_word  <= io_disk_word;
                        state <= S_IO_READ_DISK_WAIT;
                    end

                    S_IO_READ_DISK_WAIT: begin
                        if (disk_req_done) begin
                            if (disk_req_hit)
                                timing_read_seen_hit <= 1'b1;
                            else
                                timing_read_seen_miss <= 1'b1;
		                            if (disk_error) begin
		                                cqe_status <= NVME_SC_DATA_XFER_ERROR;
	                                state <= S_BUILD_CQE;
                            end else begin
                                io_host_data <= disk_req_rdata;
                                return_state <= S_IO_READ_HOST_WR;
                                state <= S_RESOLVE_IO_PRP;
                            end
                        end
                    end

                    S_IO_READ_HOST_WR: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= io_host_addr;
                        dma_wr_data  <= io_host_data;
                        dma_wr_be    <= 4'hF;
                        return_state <= S_IO_ADVANCE;
                        state <= S_WAIT_DMA_WR;
                    end

                    S_IO_ADVANCE: begin
                        if (io_last_dw || (cqe_status != 15'h0000)) begin
                            if ((cqe_status == 15'h0000) &&
                                ((io_dir == IO_DIR_WRITE) || (io_dir == IO_DIR_ZERO))) begin
                                state <= S_IO_FLUSH_REQ;
                            end else begin
                                state <= S_BUILD_CQE;
                            end
                        end else begin
                            io_dw_idx <= io_dw_idx + 1'b1;
                            case (io_dir)
                                IO_DIR_READ: begin
                                    if (NVME_PRP_ONLY_IO) begin
                                        return_state <= S_IO_ADVANCE;
                                        state <= S_RESOLVE_IO_PRP;
                                    end else if (NVME_ZERO_IO_READS) begin
                                        io_host_data <= 32'h00000000;
                                        return_state <= S_IO_READ_HOST_WR;
                                        state <= S_RESOLVE_IO_PRP;
                                    end else begin
                                        state <= S_IO_READ_DISK_REQ;
                                    end
                                end
                                IO_DIR_ZERO:  state <= S_IO_ZERO_REQ;
                                default: begin
                                    return_state <= NVME_PRP_ONLY_IO ? S_IO_ADVANCE : S_IO_WRITE_DMA_REQ;
                                    state <= S_RESOLVE_IO_PRP;
                                end
                            endcase
                        end
                    end

                    S_IO_FLUSH_REQ: begin
                        disk_req_valid <= 1'b1;
                        disk_req_write <= 1'b0;
                        disk_req_flush <= 1'b1;
                        disk_req_lba   <= 64'h0;
                        disk_req_word  <= 7'h0;
                        state <= S_IO_FLUSH_WAIT;
                    end

                    S_IO_FLUSH_WAIT: begin
                        if (disk_req_done) begin
	                            if (disk_error)
	                                cqe_status <= NVME_SC_DATA_XFER_ERROR;
                            state <= S_BUILD_CQE;
                        end
                    end

                    S_SHUTDOWN: begin
                        sq_tail       <= 16'h0;
                        sq_head       <= 16'h0;
                        cq_tail       <= 16'h0;
                        cq_head_db    <= 16'h0;
                        cq_phase      <= 1'b1;
                        io_sq_created <= 1'b0;
                        io_cq_created <= 1'b0;
                        io_sq_tail    <= 16'h0;
                        io_sq_head    <= 16'h0;
                        io_cq_tail    <= 16'h0;
                        io_cq_head_db <= 16'h0;
                        io_cq_phase   <= 1'b1;
                        aer_registered    <= 1'b0;
                        aer_cid           <= 16'h0000;
                        aer_event_pending <= 1'b0;
                        aer_event_info    <= 32'h00000000;
                        state         <= S_IDLE;
                    end

                    default: state <= S_IDLE;
                endcase
            end
        end
    end

endmodule
