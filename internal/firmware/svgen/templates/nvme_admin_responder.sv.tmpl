//
// NVMe Admin Queue Handler
// {{ hex04 .DeviceIDs.VendorID }}:{{ hex04 .DeviceIDs.DeviceID }}
//
// This module sits behind the BAR controller and processes any command
// the host driver drops into the admin submission queue.  It doesn't
// pretend to be a full NVMe controller - we just need to survive the
// init handshake that stornvme.sys performs before we get DMA access.
//
//   0x02  Get Log Page – fake SMART health data (35°C, 100% spare)
//   0x06  Identify     – controller (CNS1), namespace (CNS0), NS list (CNS2)
//   0x08  Abort         – sure, "aborted" (we didn't find anything)
//   0x09  Set Features  – temperature, error recovery, queues, VWC, etc.
//   0x0A  Get Features  – number of queues, interrupt coalescing
//   0x0C  AER           – queued silently, never completed (that's legal)
//   0x80  Format NVM   – accept format requests
//   IO Q1 Flush/Write/Read/Write Zeroes/Dataset Mgmt – minimal disk emulation

`timescale 1ns / 1ps

module pcileech_nvme_admin_responder(
    input               rst,
    input               clk,

    input               cc_en,              // CC.EN bit from BAR0 register

    // queue base addresses – the driver writes these during init
    input [31:0]        asq_lo,
    input [31:0]        asq_hi,
    input [31:0]        acq_lo,
    input [31:0]        acq_hi,
    input [31:0]        aqa,

    // doorbell pulses from the BAR write engine
    input               sq0_doorbell_wr,     // BAR0 + 0x1000
    input [15:0]        sq0_doorbell_val,
    input               cq0_doorbell_wr,     // BAR0 + 0x1004
    input [15:0]        cq0_doorbell_val,
    input               sq1_doorbell_wr,     // BAR0 + 0x1008 (DSTRD=0)
    input [15:0]        sq1_doorbell_val,
    input               cq1_doorbell_wr,     // BAR0 + 0x100C (DSTRD=0)
    input [15:0]        cq1_doorbell_val,

    // MSI-X interrupt target — vector 0 config (from pcileech_msix_table).
    // Accepted to match the bar_controller wiring. The current interrupt
    // path raises a 1-cycle msix_trigger pulse (routed to intr_req ->
    // cfg_interrupt); per-vector Mask gating can be layered onto the
    // S_SEND_MSIX state later without changing the validated handshake.
    input               msix_enable,
    input               msix_function_mask,
    input [63:0]        msix_vector0_addr,
    input [31:0]        msix_vector0_data,
    input               msix_vector0_masked,

    // DMA read – we use this to pull SQEs from host RAM
    output reg          dma_rd_req,
    output reg [63:0]   dma_rd_addr,
    output reg [9:0]    dma_rd_len,
    input               dma_rd_valid,
    input [31:0]        dma_rd_data,
    input               dma_rd_done,

    // DMA write – pushing identify/log data and CQEs back to host
    output reg          dma_wr_req,
    output reg [63:0]   dma_wr_addr,
    output reg [31:0]   dma_wr_data,
    output reg [3:0]    dma_wr_be,
    output reg          dma_wr_valid,
    input               dma_wr_done,

    // one-cycle pulse to fire MSI-X vector 0
    output reg          msix_trigger,

    // identify data lives in a BRAM initialized from .hex at synthesis
    output reg [12:0]   id_rom_addr,
    input [31:0]        id_rom_data,

    output reg [31:0]   debug_status,
    output reg [31:0]   debug_last_cmd,
    output reg [31:0]   debug_last_nsid,
    output reg [31:0]   debug_last_cdw10,
    output reg [31:0]   debug_queue_state
);

    // FSM states – 4 bits is plenty, Vivado infers one-hot if it wants to
    localparam [3:0] S_IDLE          = 4'h0;
    localparam [3:0] S_FETCH_SQE    = 4'h1;
    localparam [3:0] S_DECODE_CMD   = 4'h2;
    localparam [3:0] S_EXEC_IDENTIFY = 4'h3;
    localparam [3:0] S_WRITE_DATA   = 4'h4;
    localparam [3:0] S_POST_CQE     = 4'h5;
    localparam [3:0] S_SEND_MSIX    = 4'h6;
    localparam [3:0] S_WAIT_DMA_RD  = 4'h7;
    localparam [3:0] S_WAIT_DMA_WR  = 4'h8;
    localparam [3:0] S_EXEC_NSLIST  = 4'h9;
    localparam [3:0] S_EXEC_LOGPAGE = 4'hA;
    localparam [3:0] S_SHUTDOWN     = 4'hB;
    localparam [3:0] S_EXEC_READ_ZERO = 4'hC;

    reg [3:0]   state;
    reg [3:0]   return_state;       // where to go after DMA wait completes

    // queue bookkeeping
    reg [15:0]  sq_tail;
    reg [15:0]  sq_head;
    reg [15:0]  cq_head;
    reg         cq_phase;           // flips each time CQ wraps around
    reg [15:0]  iosq_tail;
    reg [15:0]  iosq_head;
    reg [15:0]  iocq_head;
    reg         iocq_phase;
    reg         active_io_cmd;

    wire [11:0] asqs = aqa[11:0];
    wire [11:0] acqs = aqa[27:16];

    // we buffer one full SQE (64B = 16 DWORDs) before decoding
    reg [31:0]  sqe [0:15];
    reg [3:0]   sqe_dw_idx;

    // handy aliases into the SQE
    wire [7:0]  cmd_opcode   = sqe[0][7:0];
    wire [15:0] cmd_cid      = sqe[0][31:16];
    wire [31:0] cmd_nsid     = sqe[1];
    wire [63:0] cmd_prp1     = {sqe[7], sqe[6]};
    wire [63:0] cmd_prp2     = {sqe[9], sqe[8]};
    wire [31:0] cmd_cdw10    = sqe[10];
    wire [31:0] cmd_cdw11    = sqe[11];
    wire [31:0] cmd_cdw12    = sqe[12];
    wire [7:0]  identify_cns = cmd_cdw10[7:0];

    function [63:0] cmd_prp_addr;
        input [12:0] data_byte_offset;
        reg [12:0] prp_byte_offset;
        begin
            prp_byte_offset = {1'b0, cmd_prp1[11:0]} + data_byte_offset;
            if (prp_byte_offset[12])
                cmd_prp_addr = {cmd_prp2[63:12], 12'h000} + {52'h0, prp_byte_offset[11:0]};
            else
                cmd_prp_addr = cmd_prp1 + {51'h0, data_byte_offset};
        end
    endfunction

    // CQE we're building – 4 DWORDs, written to host one at a time
    reg [31:0]  cqe [0:3];
    reg [1:0]   cqe_dw_idx;

    // transfer progress
    reg [10:0]  data_dw_cnt;
    reg [10:0]  io_zero_dw_limit;
    reg [10:0]  log_dw_limit;
    reg [7:0]   log_page_id;
    reg [12:0]  id_rom_offset;

    // edge detect for CC.EN so we can do a clean shutdown
    reg         cc_en_prev;

    // masking low bits – NVMe spec says queue bases are page-aligned
    wire [63:0] asq_base = {asq_hi, asq_lo & 32'hFFFFF000};
    wire [63:0] acq_base = {acq_hi, acq_lo & 32'hFFFFF000};
    reg [63:0]  iosq_base;
    reg [63:0]  iocq_base;
    reg [15:0]  iosq_size;
    reg [15:0]  iocq_size;
    reg         iosq_enabled;
    reg         iocq_enabled;
    wire [63:0] active_cq_base = active_io_cmd ? iocq_base : acq_base;
    wire [15:0] active_cq_head = active_io_cmd ? iocq_head : cq_head;
    wire        active_cq_phase = active_io_cmd ? iocq_phase : cq_phase;

    // the spec says AER commands just sit around until something happens,
    // and nothing ever happens on our fake controller, so we count and ignore
    reg [3:0]   aer_pending;

    // Set/Get Features Number of Queues must be consistent - stornvme sets
    // the desired count then reads it back.  We clamp to what CAP.MQES allows.
    reg [31:0]  num_queues_granted;
    reg         volatile_write_cache_enabled;
    reg [31:0]  interrupt_coalescing;
    reg [31:0]  interrupt_vector_config;
    reg [31:0]  write_atomicity_normal;
    reg [31:0]  async_event_config;
    reg [31:0]  keep_alive_timer;

    always @(posedge clk) begin
        if (rst) begin
            state           <= S_IDLE;
            sq_tail         <= 16'h0;
            sq_head         <= 16'h0;
            cq_head         <= 16'h0;
            cq_phase        <= 1'b1;
            iosq_tail       <= 16'h0;
            iosq_head       <= 16'h0;
            iocq_head       <= 16'h0;
            iocq_phase      <= 1'b1;
            active_io_cmd   <= 1'b0;
            dma_rd_req      <= 1'b0;
            dma_wr_req      <= 1'b0;
            dma_wr_valid    <= 1'b0;
            msix_trigger    <= 1'b0;
            sqe_dw_idx      <= 4'h0;
            cqe_dw_idx      <= 2'h0;
            data_dw_cnt     <= 11'h0;
            io_zero_dw_limit <= 11'h0;
            log_dw_limit    <= 11'd128;
            log_page_id     <= 8'h02;
            id_rom_offset   <= 13'h0;
            id_rom_addr     <= 13'h0;
            debug_status    <= 32'h0;
            debug_last_cmd  <= 32'h0;
            debug_last_nsid <= 32'h0;
            debug_last_cdw10 <= 32'h0;
            debug_queue_state <= 32'h0;
            cc_en_prev      <= 1'b0;
            aer_pending     <= 4'h0;
            num_queues_granted <= 32'h00010001;  // default: 1 SQ + 1 CQ
            volatile_write_cache_enabled <= 1'b1;
            interrupt_coalescing <= 32'h0;
            interrupt_vector_config <= 32'h0;
            write_atomicity_normal <= 32'h0;
            async_event_config <= 32'h0;
            keep_alive_timer <= 32'h0;
            iosq_base       <= 64'h0;
            iocq_base       <= 64'h0;
            iosq_size       <= 16'h0;
            iocq_size       <= 16'h0;
            iosq_enabled    <= 1'b0;
            iocq_enabled    <= 1'b0;
        end else begin
            // pulse signals – cleared every cycle, only set when needed
            dma_rd_req      <= 1'b0;
            dma_wr_req      <= 1'b0;
            dma_wr_valid    <= 1'b0;
            msix_trigger    <= 1'b0;
            debug_status    <= {22'h0, state, active_io_cmd, iosq_enabled, iocq_enabled, cq_phase, iocq_phase, cc_en};
            debug_queue_state <= {sq_head[7:0], cq_head[7:0], iosq_head[7:0], iocq_head[7:0]};

            cc_en_prev <= cc_en;

            // driver is shutting us down
            if (!cc_en && cc_en_prev && state != S_SHUTDOWN) begin
                state <= S_SHUTDOWN;
            end

            // controller is disabled, nothing to do
            else if (!cc_en && state != S_SHUTDOWN) begin
                state <= S_IDLE;
            end

            else begin
                case (state)

                    // ---- sit around until the driver rings the doorbell ------
                    S_IDLE: begin
                        if (sq0_doorbell_wr)
                            sq_tail <= sq0_doorbell_val;

                        // host consumed some CQEs, update our copy of the head
                        if (cq0_doorbell_wr)
                            cq_head <= cq0_doorbell_val;
                        if (sq1_doorbell_wr)
                            iosq_tail <= sq1_doorbell_val;
                        if (cq1_doorbell_wr)
                            iocq_head <= cq1_doorbell_val;

                        // anything new? go fetch it
                        if (sq_tail != sq_head) begin
                            active_io_cmd <= 1'b0;
                            dma_rd_req  <= 1'b1;
                            dma_rd_addr <= asq_base + {48'h0, sq_head} * 64;
                            dma_rd_len  <= 10'd16;
                            sqe_dw_idx  <= 4'h0;
                            state       <= S_FETCH_SQE;
                        end else if (iosq_enabled && iocq_enabled && iosq_tail != iosq_head) begin
                            active_io_cmd <= 1'b1;
                            dma_rd_req  <= 1'b1;
                            dma_rd_addr <= iosq_base + {42'h0, iosq_head, 6'h0};
                            dma_rd_len  <= 10'd16;
                            sqe_dw_idx  <= 4'h0;
                            state       <= S_FETCH_SQE;
                        end
                    end

                    // ---- pull 64 bytes (one SQE) from host memory -----------
                    S_FETCH_SQE: begin
                        if (dma_rd_valid) begin
                            sqe[sqe_dw_idx] <= dma_rd_data;
                            sqe_dw_idx      <= sqe_dw_idx + 1'b1;
                        end
                        if (dma_rd_done)
                            state <= S_DECODE_CMD;
                    end

                    // ---- figure out what the driver wants --------------------
                    S_DECODE_CMD: begin
                        debug_last_cmd <= {7'h0, active_io_cmd, cmd_opcode, cmd_cid};
                        debug_last_nsid <= cmd_nsid;
                        debug_last_cdw10 <= cmd_cdw10;
                        if (active_io_cmd) begin
                            case (cmd_opcode)
                                8'h02: begin
                                    data_dw_cnt <= 11'h0;
                                    if (cmd_cdw12[15:0] >= 16'd7)
                                        io_zero_dw_limit <= 11'd1024;
                                    else
                                        io_zero_dw_limit <= ({8'h0, cmd_cdw12[2:0]} + 11'd1) << 7;
                                    state <= S_EXEC_READ_ZERO;
                                end
                                8'h00, 8'h01, 8'h08, 8'h09: begin
                                    cqe[0] <= 32'h0;
                                    cqe[1] <= 32'h0;
                                    cqe[2] <= {cmd_cid, iosq_head};
                                    cqe[3] <= {31'h0, iocq_phase};
                                    cqe_dw_idx <= 2'h0;
                                    state <= S_POST_CQE;
                                end
                                default: begin
                                    cqe[0] <= 32'h0;
                                    cqe[1] <= 32'h0;
                                    cqe[2] <= {cmd_cid, iosq_head};
                                    cqe[3] <= {31'h0, iocq_phase};
                                    cqe_dw_idx <= 2'h0;
                                    state <= S_POST_CQE;
                                end
                            endcase
                        end else begin
                        case (cmd_opcode)

                            // Delete IO Submission Queue
                            8'h00: begin
                                iosq_enabled <= 1'b0;
                                iosq_tail    <= 16'h0;
                                iosq_head    <= 16'h0;
                                cqe[0] <= 32'h0;
                                cqe[1] <= 32'h0;
                                cqe[2] <= {cmd_cid, sq_head};
                                cqe[3] <= {31'h0, cq_phase};
                                cqe_dw_idx <= 2'h0;
                                state <= S_POST_CQE;
                            end

                            // Create IO Submission Queue
                            8'h01: begin
                                iosq_base    <= {cmd_prp1[63:12], 12'h000};
                                iosq_size    <= cmd_cdw10[31:16];
                                iosq_enabled <= 1'b1;
                                iosq_tail    <= 16'h0;
                                iosq_head    <= 16'h0;
                                cqe[0] <= 32'h0;
                                cqe[1] <= 32'h0;
                                cqe[2] <= {cmd_cid, sq_head};
                                cqe[3] <= {31'h0, cq_phase};
                                cqe_dw_idx <= 2'h0;
                                state <= S_POST_CQE;
                            end

                            // Get Log Page
                            8'h02: begin
                                log_page_id <= cmd_cdw10[7:0];
                                data_dw_cnt <= 11'h0;
                                if (cmd_cdw10[31:16] >= 16'd1023)
                                    log_dw_limit <= 11'd1024;
                                else
                                    log_dw_limit <= {1'b0, cmd_cdw10[25:16]} + 11'd1;
                                state       <= S_EXEC_LOGPAGE;
                            end

                            // Delete IO Completion Queue
                            8'h04: begin
                                iocq_enabled <= 1'b0;
                                iocq_head    <= 16'h0;
                                iocq_phase   <= 1'b1;
                                cqe[0] <= 32'h0;
                                cqe[1] <= 32'h0;
                                cqe[2] <= {cmd_cid, sq_head};
                                cqe[3] <= {31'h0, cq_phase};
                                cqe_dw_idx <= 2'h0;
                                state <= S_POST_CQE;
                            end

                            // Create IO Completion Queue
                            8'h05: begin
                                iocq_base    <= {cmd_prp1[63:12], 12'h000};
                                iocq_size    <= cmd_cdw10[31:16];
                                iocq_enabled <= 1'b1;
                                iocq_head    <= 16'h0;
                                iocq_phase   <= 1'b1;
                                cqe[0] <= 32'h0;
                                cqe[1] <= 32'h0;
                                cqe[2] <= {cmd_cid, sq_head};
                                cqe[3] <= {31'h0, cq_phase};
                                cqe_dw_idx <= 2'h0;
                                state <= S_POST_CQE;
                            end

                            // Identify
                            8'h06: begin
                                case (identify_cns)
                                    8'h01: begin   // controller data
                                        id_rom_offset <= 13'h0000;
                                        data_dw_cnt   <= 11'h0;
                                        state         <= S_EXEC_IDENTIFY;
                                    end
                                    8'h00: begin   // namespace data
                                        id_rom_offset <= 13'h1000;
                                        data_dw_cnt   <= 11'h0;
                                        state         <= S_EXEC_IDENTIFY;
                                    end
                                    8'h02: begin   // active namespace list
                                        data_dw_cnt <= 11'h0;
                                        state       <= S_EXEC_NSLIST;
                                    end
                                    default: begin // unknown CNS, just say OK
                                        cqe[0] <= 32'h0;
                                        cqe[1] <= 32'h0;
                                        cqe[2] <= {cmd_cid, sq_head};
                                        cqe[3] <= {31'h0, cq_phase};
                                        cqe_dw_idx <= 2'h0;
                                        state  <= S_POST_CQE;
                                    end
                                endcase
                            end

                            // Abort – "yeah sure, we didn't find that command"
                            8'h08: begin
                                cqe[0] <= 32'h0;
                                cqe[1] <= 32'h0;
                                cqe[2] <= {cmd_cid, sq_head};
                                cqe[3] <= {31'h0, cq_phase};
                                cqe_dw_idx <= 2'h0;
                                state  <= S_POST_CQE;
                            end

                            // Set Features – the driver configures a bunch of stuff,
                            // we nod along and say everything's fine
                            8'h09: begin
                                case (cmd_cdw10[7:0])
                                    8'h04:   cqe[0] <= 32'h0;            // temp threshold
                                    8'h05:   cqe[0] <= 32'h0;            // error recovery
                                    8'h06: begin                           // volatile write cache
                                        volatile_write_cache_enabled <= cmd_cdw11[0];
                                        cqe[0] <= {31'h0, cmd_cdw11[0]};
                                    end
                                    8'h07: begin                           // number of queues
                                        num_queues_granted <= cmd_cdw11;
                                        cqe[0] <= cmd_cdw11;
                                    end
                                    8'h08: begin                           // interrupt coalescing
                                        interrupt_coalescing <= cmd_cdw11;
                                        cqe[0] <= cmd_cdw11;
                                    end
                                    8'h09: begin                           // interrupt vector config
                                        interrupt_vector_config <= cmd_cdw11;
                                        cqe[0] <= cmd_cdw11;
                                    end
                                    8'h0A: begin                           // write atomicity normal
                                        write_atomicity_normal <= cmd_cdw11;
                                        cqe[0] <= cmd_cdw11;
                                    end
                                    8'h0B: begin                           // async event config
                                        async_event_config <= cmd_cdw11;
                                        cqe[0] <= cmd_cdw11;
                                    end
                                    8'h0F: begin                           // keep alive timer
                                        keep_alive_timer <= cmd_cdw11;
                                        cqe[0] <= cmd_cdw11;
                                    end
                                    default: cqe[0] <= 32'h0;
                                endcase
                                cqe[1] <= 32'h0;
                                cqe[2] <= {cmd_cid, sq_head};
                                cqe[3] <= {31'h0, cq_phase};
                                cqe_dw_idx <= 2'h0;
                                state  <= S_POST_CQE;
                            end

                            // Get Features
                            8'h0A: begin
                                case (cmd_cdw10[7:0])
                                    8'h04:   cqe[0] <= 32'h00000135;  // 35C warning threshold
                                    8'h05:   cqe[0] <= 32'h0;  // no error recovery timeout
                                    8'h06:   cqe[0] <= {31'h0, volatile_write_cache_enabled};
                                    8'h07:   cqe[0] <= num_queues_granted;  // echo last Set Features value
                                    8'h08:   cqe[0] <= interrupt_coalescing;
                                    8'h09:   cqe[0] <= interrupt_vector_config;
                                    8'h0A:   cqe[0] <= write_atomicity_normal;
                                    8'h0B:   cqe[0] <= async_event_config;
                                    8'h0F:   cqe[0] <= keep_alive_timer;
                                    default: cqe[0] <= 32'h0;
                                endcase
                                cqe[1] <= 32'h0;
                                cqe[2] <= {cmd_cid, sq_head};
                                cqe[3] <= {31'h0, cq_phase};
                                cqe_dw_idx <= 2'h0;
                                state  <= S_POST_CQE;
                            end

                            // AER – these just pile up until an event happens.
                            // since nothing ever happens on our end, we eat them.
                            8'h0C: begin
                                if (aer_pending < 4'hF)
                                    aer_pending <= aer_pending + 1'b1;
                                // move the SQ head along but don't post any CQE
                                if (sq_head >= {4'h0, asqs})
                                    sq_head <= 16'h0;
                                else
                                    sq_head <= sq_head + 1'b1;
                                state <= S_IDLE;
                            end

                            // Format NVM – accept the host format request.  The
                            // minimal emulation reports an empty zeroed namespace.
                            8'h80: begin
                                cqe[0] <= 32'h0;
                                cqe[1] <= 32'h0;
                                cqe[2] <= {cmd_cid, sq_head};
                                cqe[3] <= {31'h0, cq_phase};
                                cqe_dw_idx <= 2'h0;
                                state  <= S_POST_CQE;
                            end

                            // everything else (Create IO CQ/SQ, etc.) – just say yes
                            default: begin
                                cqe[0] <= 32'h0;
                                cqe[1] <= 32'h0;
                                cqe[2] <= {cmd_cid, sq_head};
                                cqe[3] <= {31'h0, cq_phase};
                                cqe_dw_idx <= 2'h0;
                                state  <= S_POST_CQE;
                            end
                        endcase
                        end
                    end

                    // ---- stream 4KB of identify data from ROM to host -------
                    S_EXEC_IDENTIFY: begin
                        // ROM has one cycle of read latency, so we set the
                        // address first and grab the data next time around
                        id_rom_addr <= id_rom_offset + {data_dw_cnt, 2'b00};

                        if (data_dw_cnt == 11'h0) begin
                            // kick off the pipeline
                            data_dw_cnt <= 11'h1;
                        end else begin
                            dma_wr_req   <= 1'b1;
                            dma_wr_valid <= 1'b1;
                            dma_wr_addr  <= cmd_prp_addr({data_dw_cnt - 11'h1, 2'b00});
                            dma_wr_data  <= id_rom_data;
                            dma_wr_be    <= 4'hF;

                            if (data_dw_cnt >= 11'd1024) begin
                                return_state <= S_WRITE_DATA;   // done, go build CQE
                            end else begin
                                data_dw_cnt  <= data_dw_cnt + 1'b1;
                                return_state <= S_EXEC_IDENTIFY;
                            end
                            state <= S_WAIT_DMA_WR;
                        end
                    end

                    // ---- active namespace list: just one namespace for us ----
                    // 4KB buffer where only the first DWORD matters (NSID=1)
                    S_EXEC_NSLIST: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= cmd_prp_addr({data_dw_cnt, 2'b00});
                        dma_wr_data  <= (data_dw_cnt == 11'h0) ? 32'h00000001 : 32'h0;
                        dma_wr_be    <= 4'hF;

                        if (data_dw_cnt >= 11'd1023) begin
                            return_state <= S_WRITE_DATA;
                        end else begin
                            data_dw_cnt  <= data_dw_cnt + 1'b1;
                            return_state <= S_EXEC_NSLIST;
                        end
                        state <= S_WAIT_DMA_WR;
                    end

                    // ---- common admin logs: error, SMART, firmware, NS list -
                    S_EXEC_LOGPAGE: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= cmd_prp_addr({data_dw_cnt, 2'b00});
                        dma_wr_be    <= 4'hF;

                        case (log_page_id)
                            8'h01: dma_wr_data <= 32'h0;
                            8'h02: begin
                                case (data_dw_cnt)
                                    11'h000: dma_wr_data <= 32'h01340000;  // temp=308K (35C), no warnings
                                    11'h001: dma_wr_data <= 32'h00640064;  // 100% spare, 100% threshold
                                    11'h002: dma_wr_data <= 32'h00000000;  // 0% used
                                    default: dma_wr_data <= 32'h00000000;
                                endcase
                            end
                            8'h03: dma_wr_data <= (data_dw_cnt == 11'h0) ? 32'h00000001 : 32'h0;
                            8'h04: dma_wr_data <= 32'h0;
                            default: dma_wr_data <= 32'h0;
                        endcase

                        if (data_dw_cnt >= log_dw_limit - 11'd1) begin
                            return_state <= S_WRITE_DATA;
                        end else begin
                            data_dw_cnt  <= data_dw_cnt + 1'b1;
                            return_state <= S_EXEC_LOGPAGE;
                        end
                        state <= S_WAIT_DMA_WR;
                    end

                    // ---- IO read: return zeroed sectors for an empty disk ----
                    S_EXEC_READ_ZERO: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= cmd_prp_addr({data_dw_cnt, 2'b00});
                        dma_wr_data  <= 32'h00000000;
                        dma_wr_be    <= 4'hF;

                        if (data_dw_cnt >= io_zero_dw_limit - 11'd1) begin
                            return_state <= S_WRITE_DATA;
                        end else begin
                            data_dw_cnt  <= data_dw_cnt + 1'b1;
                            return_state <= S_EXEC_READ_ZERO;
                        end
                        state <= S_WAIT_DMA_WR;
                    end

                    // ---- all data has been sent, pack a success CQE ---------
                    S_WRITE_DATA: begin
                        cqe[0] <= 32'h0;
                        cqe[1] <= 32'h0;
                        cqe[2] <= active_io_cmd ? {cmd_cid, iosq_head} : {cmd_cid, sq_head};
                        cqe[3] <= {31'h0, active_cq_phase};
                        cqe_dw_idx <= 2'h0;
                        state  <= S_POST_CQE;
                    end

                    // ---- write 16 bytes of CQE to the completion queue ------
                    S_POST_CQE: begin
                        dma_wr_req   <= 1'b1;
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= active_cq_base + {44'h0, active_cq_head, 4'h0}
                                        + {60'h0, cqe_dw_idx, 2'b00};
                        dma_wr_data  <= cqe[cqe_dw_idx];
                        dma_wr_be    <= 4'hF;

                        if (cqe_dw_idx == 2'd3) begin
                            cqe_dw_idx   <= 2'h0;
                            return_state <= S_SEND_MSIX;
                        end else begin
                            cqe_dw_idx   <= cqe_dw_idx + 1'b1;
                            return_state <= S_POST_CQE;
                        end
                        state <= S_WAIT_DMA_WR;
                    end

                    // ---- park here until the DMA bridge says "done" ---------
                    S_WAIT_DMA_WR: begin
                        if (dma_wr_done)
                            state <= return_state;
                    end

                    // ---- ring the doorbell and move on ----------------------
                    S_SEND_MSIX: begin
                        msix_trigger <= 1'b1;

                        if (active_io_cmd) begin
                            if (iosq_head >= iosq_size)
                                iosq_head <= 16'h0;
                            else
                                iosq_head <= iosq_head + 1'b1;

                            if (iocq_head >= iocq_size) begin
                                iocq_head  <= 16'h0;
                                iocq_phase <= ~iocq_phase;
                            end else begin
                                iocq_head <= iocq_head + 1'b1;
                            end
                        end else begin
                            // wrap SQ head
                            if (sq_head >= {4'h0, asqs})
                                sq_head <= 16'h0;
                            else
                                sq_head <= sq_head + 1'b1;

                            // wrap CQ head and flip the phase bit
                            if (cq_head >= {4'h0, acqs}) begin
                                cq_head  <= 16'h0;
                                cq_phase <= ~cq_phase;
                            end else begin
                                cq_head <= cq_head + 1'b1;
                            end
                        end

                        state <= S_IDLE;
                    end

                    // ---- driver pulled CC.EN low, reset queue state ---------
                    S_SHUTDOWN: begin
                        sq_tail     <= 16'h0;
                        sq_head     <= 16'h0;
                        cq_head     <= 16'h0;
                        cq_phase    <= 1'b1;
                        iosq_tail   <= 16'h0;
                        iosq_head   <= 16'h0;
                        iocq_head   <= 16'h0;
                        iocq_phase  <= 1'b1;
                        active_io_cmd <= 1'b0;
                        aer_pending <= 4'h0;
                        state       <= S_IDLE;
                    end

                    default: state <= S_IDLE;
                endcase
            end
        end
    end

endmodule
