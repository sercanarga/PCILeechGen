//
// PCILeech NVMe Admin Command Responder
// Auto-generated by PCILeechGen
// Device: {{ hex04 .DeviceIDs.VendorID }}:{{ hex04 .DeviceIDs.DeviceID }}
//
// Handles admin queue commands: Identify, Set/Get Features, Create IO CQ/SQ.
//

`timescale 1ns / 1ps

module pcileech_nvme_admin_responder(
    input               rst,
    input               clk,

    input               cc_en,              // CC.EN from BAR0

    // Admin queue addresses from BAR0 registers
    input [31:0]        asq_lo,
    input [31:0]        asq_hi,
    input [31:0]        acq_lo,
    input [31:0]        acq_hi,
    input [31:0]        aqa,

    // Doorbell write detection
    input               sq0_doorbell_wr,
    input [15:0]        sq0_doorbell_val,

    // DMA Read (FPGA reads from host)
    output reg          dma_rd_req,
    output reg [63:0]   dma_rd_addr,
    output reg [9:0]    dma_rd_len,
    input               dma_rd_valid,
    input [31:0]        dma_rd_data,
    input               dma_rd_done,

    // DMA Write (FPGA writes to host)
    output reg          dma_wr_req,
    output reg [63:0]   dma_wr_addr,
    output reg [31:0]   dma_wr_data,
    output reg [3:0]    dma_wr_be,
    output reg          dma_wr_valid,
    input               dma_wr_done,

    // MSI-X trigger
    output reg          msix_trigger,

    // Identify ROM BRAM
    output reg [12:0]   id_rom_addr,
    input [31:0]        id_rom_data
);

    // State machine
    localparam [3:0] S_IDLE          = 4'h0;
    localparam [3:0] S_FETCH_SQE    = 4'h1;
    localparam [3:0] S_DECODE_CMD   = 4'h2;
    localparam [3:0] S_EXEC_IDENTIFY = 4'h3;
    localparam [3:0] S_WRITE_DATA   = 4'h4;
    localparam [3:0] S_POST_CQE     = 4'h5;
    localparam [3:0] S_SEND_MSIX    = 4'h6;
    localparam [3:0] S_WAIT_DMA_RD  = 4'h7;
    localparam [3:0] S_WAIT_DMA_WR  = 4'h8;

    reg [3:0]   state;
    reg [3:0]   return_state;

    // Queue pointers
    reg [15:0]  sq_tail;
    reg [15:0]  sq_head;
    reg [15:0]  cq_head;
    reg         cq_phase;           // toggles on CQ wrap

    wire [11:0] asqs = aqa[11:0];
    wire [11:0] acqs = aqa[27:16];

    // SQE buffer (64 bytes = 16 DWORDs)
    reg [31:0]  sqe [0:15];
    reg [3:0]   sqe_dw_idx;

    // Decoded fields
    wire [7:0]  cmd_opcode = sqe[0][7:0];
    wire [15:0] cmd_cid    = sqe[0][31:16];
    wire [31:0] cmd_nsid   = sqe[1];
    wire [63:0] cmd_prp1   = {sqe[7], sqe[6]};
    wire [63:0] cmd_prp2   = {sqe[9], sqe[8]};
    wire [31:0] cmd_cdw10  = sqe[10];
    wire [31:0] cmd_cdw11  = sqe[11];
    wire [7:0]  identify_cns = cmd_cdw10[7:0];

    // CQE buffer (4 DWORDs)
    reg [31:0]  cqe [0:3];
    reg [1:0]   cqe_dw_idx;

    // Data transfer
    reg [10:0]  data_dw_cnt;
    reg [12:0]  id_rom_offset;

    wire [63:0] asq_base = {asq_hi, asq_lo & 32'hFFFFF000};
    wire [63:0] acq_base = {acq_hi, acq_lo & 32'hFFFFF000};

    always @(posedge clk) begin
        if (rst || !cc_en) begin
            state           <= S_IDLE;
            sq_tail         <= 16'h0;
            sq_head         <= 16'h0;
            cq_head         <= 16'h0;
            cq_phase        <= 1'b1;
            dma_rd_req      <= 1'b0;
            dma_wr_req      <= 1'b0;
            dma_wr_valid    <= 1'b0;
            msix_trigger    <= 1'b0;
            sqe_dw_idx      <= 4'h0;
            cqe_dw_idx      <= 2'h0;
            data_dw_cnt     <= 11'h0;
            id_rom_offset   <= 13'h0;
            id_rom_addr     <= 13'h0;
        end else begin
            dma_rd_req      <= 1'b0;
            dma_wr_req      <= 1'b0;
            dma_wr_valid    <= 1'b0;
            msix_trigger    <= 1'b0;

            case (state)
                S_IDLE: begin
                    if (sq0_doorbell_wr)
                        sq_tail <= sq0_doorbell_val;

                    if (sq_tail != sq_head) begin
                        dma_rd_req  <= 1'b1;
                        dma_rd_addr <= asq_base + {48'h0, sq_head} * 64;
                        dma_rd_len  <= 10'd16;
                        sqe_dw_idx  <= 4'h0;
                        state       <= S_FETCH_SQE;
                    end
                end

                S_FETCH_SQE: begin
                    if (dma_rd_valid) begin
                        sqe[sqe_dw_idx] <= dma_rd_data;
                        sqe_dw_idx      <= sqe_dw_idx + 1'b1;
                    end
                    if (dma_rd_done)
                        state <= S_DECODE_CMD;
                end

                S_DECODE_CMD: begin
                    case (cmd_opcode)
                        8'h06: begin // Identify
                            id_rom_offset <= (identify_cns == 8'h01) ? 13'h0000 : 13'h1000;
                            data_dw_cnt   <= 11'h0;
                            state         <= S_EXEC_IDENTIFY;
                        end

                        8'h09: begin // Set Features
                            cqe[0] <= (cmd_cdw10[7:0] == 8'h07) ? cmd_cdw11 : 32'h0;
                            cqe[1] <= 32'h0;
                            cqe[2] <= {cmd_cid, 16'h0} | {16'h0, sq_head};
                            cqe[3] <= {15'h0, cq_phase};
                            state  <= S_POST_CQE;
                        end

                        8'h0A: begin // Get Features
                            case (cmd_cdw10[7:0])
                                8'h07:   cqe[0] <= 32'h00010001; // NumQueues: 1+1
                                8'h0B:   cqe[0] <= 32'h00000000; // IntCoalescing: off
                                default: cqe[0] <= 32'h0;
                            endcase
                            cqe[1] <= 32'h0;
                            cqe[2] <= {cmd_cid, 16'h0} | {16'h0, sq_head};
                            cqe[3] <= {15'h0, cq_phase};
                            state  <= S_POST_CQE;
                        end

                        default: begin // Create IO CQ/SQ, unknown → success
                            cqe[0] <= 32'h0;
                            cqe[1] <= 32'h0;
                            cqe[2] <= {cmd_cid, 16'h0} | {16'h0, sq_head};
                            cqe[3] <= {15'h0, cq_phase};
                            state  <= S_POST_CQE;
                        end
                    endcase
                end

                S_EXEC_IDENTIFY: begin
                    id_rom_addr <= id_rom_offset + {data_dw_cnt, 2'b00};

                    if (data_dw_cnt > 11'h0) begin
                        dma_wr_valid <= 1'b1;
                        dma_wr_addr  <= cmd_prp1 + {53'h0, data_dw_cnt - 11'h1, 2'b00};
                        dma_wr_data  <= id_rom_data;
                        dma_wr_be    <= 4'hF;
                    end

                    if (data_dw_cnt >= 11'd1024)
                        state <= S_WRITE_DATA;
                    else
                        data_dw_cnt <= data_dw_cnt + 1'b1;
                end

                S_WRITE_DATA: begin
                    dma_wr_valid <= 1'b1;
                    dma_wr_addr  <= cmd_prp1 + 64'd4092;
                    dma_wr_data  <= id_rom_data;
                    dma_wr_be    <= 4'hF;

                    cqe[0] <= 32'h0;
                    cqe[1] <= 32'h0;
                    cqe[2] <= {cmd_cid, 16'h0} | {16'h0, sq_head};
                    cqe[3] <= {15'h0, cq_phase};
                    state  <= S_POST_CQE;
                end

                S_POST_CQE: begin
                    dma_wr_valid <= 1'b1;
                    dma_wr_addr  <= acq_base + {48'h0, cq_head} * 16 + {62'h0, cqe_dw_idx, 2'b00};
                    dma_wr_data  <= cqe[cqe_dw_idx];
                    dma_wr_be    <= 4'hF;
                    cqe_dw_idx   <= cqe_dw_idx + 1'b1;

                    if (cqe_dw_idx == 2'd3) begin
                        cqe_dw_idx <= 2'h0;
                        state      <= S_SEND_MSIX;
                    end
                end

                S_SEND_MSIX: begin
                    msix_trigger <= 1'b1;

                    if (sq_head >= asqs)
                        sq_head <= 16'h0;
                    else
                        sq_head <= sq_head + 1'b1;

                    if (cq_head >= acqs) begin
                        cq_head  <= 16'h0;
                        cq_phase <= ~cq_phase;
                    end else begin
                        cq_head <= cq_head + 1'b1;
                    end

                    state <= S_IDLE;
                end

                default: state <= S_IDLE;
            endcase
        end
    end

endmodule
