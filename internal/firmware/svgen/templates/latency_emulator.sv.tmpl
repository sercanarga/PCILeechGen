// TLP Latency Emulator - Auto-generated by PCILeechGen
// Device: {{ hex04 .DeviceIDs.VendorID }}:{{ hex04 .DeviceIDs.DeviceID }}

`timescale 1ns / 1ps

module tlp_latency_emulator #(
    parameter MIN_LATENCY_CYCLES = {{ .LatencyConfig.MinCycles }},
    parameter MAX_LATENCY_CYCLES = {{ .LatencyConfig.MaxCycles }},
    parameter AVG_LATENCY_CYCLES = {{ .LatencyConfig.AvgCycles }},
    parameter ENABLE_JITTER      = 1,
    parameter BURST_CORRELATION  = {{ .LatencyConfig.BurstCorrelation }},
    parameter THERMAL_DRIFT_PERIOD = {{ .LatencyConfig.ThermalPeriod }},
    parameter WR_MIN_LATENCY     = {{ .LatencyConfig.WrMinCycles }},
    parameter WR_MAX_LATENCY     = {{ .LatencyConfig.WrMaxCycles }},
    parameter CPL_TIMEOUT_CYCLES = {{ .LatencyConfig.CplTimeoutCycles }},
    parameter [31:0] PRNG_SEED_0 = 32'h{{ hex08 (index .PRNGSeeds 0) }},
    parameter [31:0] PRNG_SEED_1 = 32'h{{ hex08 (index .PRNGSeeds 1) }},
    parameter [31:0] PRNG_SEED_2 = 32'h{{ hex08 (index .PRNGSeeds 2) }},
    parameter [31:0] PRNG_SEED_3 = 32'h{{ hex08 (index .PRNGSeeds 3) }}
)(
    input wire          clk,
    input wire          rst,

    // read path
    input wire          req_valid,
    input wire [87:0]   req_ctx,
    input wire [31:0]   req_data,
    input wire [31:0]   req_addr,
    output reg          req_ready,

    output reg          rsp_valid,
    output reg [87:0]   rsp_ctx,
    output reg [31:0]   rsp_data,
    input wire          rsp_ready,

    output wire         busy,

    // write acknowledge path
    input wire          wr_valid,
    input wire [31:0]   wr_addr,
    output reg          wr_ack
);

    reg request_pending;
    assign busy = request_pending;

    reg [7:0] latency_counter;
    reg [7:0] target_latency;

    reg [87:0] stored_ctx;
    reg [31:0] stored_data;

    reg [31:0] prev_addr;
    reg [7:0]  prev_latency;
    reg        prev_valid;

    // completion timeout counter
    reg [16:0] timeout_counter;
    wire timeout_expired = (CPL_TIMEOUT_CYCLES > 0) && request_pending &&
                           (timeout_counter >= CPL_TIMEOUT_CYCLES[16:0]);

    // xorshift128+ PRNG
    reg [31:0] prng_s0, prng_s1, prng_s2, prng_s3;
    wire [31:0] prng_out;
    wire [31:0] prng_next_s0, prng_next_s3;

    assign prng_next_s0 = prng_s0 ^ (prng_s0 << 11);
    assign prng_next_s3 = prng_s3 ^ (prng_s3 >> 19) ^ prng_next_s0 ^ (prng_next_s0 >> 8);
    assign prng_out = prng_s3 + prng_s0;

    always @(posedge clk) begin
        if (rst) begin
            prng_s0 <= PRNG_SEED_0;
            prng_s1 <= PRNG_SEED_1;
            prng_s2 <= PRNG_SEED_2;
            prng_s3 <= PRNG_SEED_3;
        end else begin
            // Advance every cycle to prevent deterministic thermal drift during idle
            prng_s0 <= prng_s1;
            prng_s1 <= prng_s2;
            prng_s2 <= prng_s3;
            prng_s3 <= prng_next_s3;
        end
    end

    // thermal drift
    reg [15:0] thermal_counter;
    reg [3:0]  thermal_offset;

    always @(posedge clk) begin
        if (rst) begin
            thermal_counter <= 16'h0;
            thermal_offset  <= 4'h0;
        end else begin
            thermal_counter <= thermal_counter + 1'b1;
            if (thermal_counter == THERMAL_DRIFT_PERIOD[15:0]) begin
                thermal_counter <= 16'h0;
                if (prng_out[0])
                    thermal_offset <= (thermal_offset < 4'h7) ? thermal_offset + 1'b1 : thermal_offset;
                else
                    thermal_offset <= (thermal_offset > 4'h8) ? thermal_offset - 1'b1 : thermal_offset;
            end
        end
    end

    // address-region latency variation
    wire [2:0] addr_region = req_addr[14:12];
    wire [7:0] region_adjust = (addr_region == 3'h0) ? 8'h00 :
                               (addr_region == 3'h1) ? 8'h02 :
                               (addr_region == 3'h2) ? 8'h04 :
                               (addr_region == 3'h3) ? 8'h01 :
                               8'h03;

    // burst correlation
    wire is_sequential = prev_valid && ((req_addr[31:8] == prev_addr[31:8]) ||
                                        (req_addr[31:8] == prev_addr[31:8] + 1'b1));
    wire [7:0] corr_weight = is_sequential ? BURST_CORRELATION[7:0] : 8'h00;
    wire [7:0] correlated_latency = ((prev_latency * corr_weight) +
                                     (prng_out[7:0] * (8'hFF - corr_weight))) >> 8;

    // donor-profiled CDF lookup
    reg [7:0] cdf_table [0:15];
    initial begin
        cdf_table[0]  = 8'd{{ cdfVal .LatencyConfig.CDF 0 }};
        cdf_table[1]  = 8'd{{ cdfVal .LatencyConfig.CDF 1 }};
        cdf_table[2]  = 8'd{{ cdfVal .LatencyConfig.CDF 2 }};
        cdf_table[3]  = 8'd{{ cdfVal .LatencyConfig.CDF 3 }};
        cdf_table[4]  = 8'd{{ cdfVal .LatencyConfig.CDF 4 }};
        cdf_table[5]  = 8'd{{ cdfVal .LatencyConfig.CDF 5 }};
        cdf_table[6]  = 8'd{{ cdfVal .LatencyConfig.CDF 6 }};
        cdf_table[7]  = 8'd{{ cdfVal .LatencyConfig.CDF 7 }};
        cdf_table[8]  = 8'd{{ cdfVal .LatencyConfig.CDF 8 }};
        cdf_table[9]  = 8'd{{ cdfVal .LatencyConfig.CDF 9 }};
        cdf_table[10] = 8'd{{ cdfVal .LatencyConfig.CDF 10 }};
        cdf_table[11] = 8'd{{ cdfVal .LatencyConfig.CDF 11 }};
        cdf_table[12] = 8'd{{ cdfVal .LatencyConfig.CDF 12 }};
        cdf_table[13] = 8'd{{ cdfVal .LatencyConfig.CDF 13 }};
        cdf_table[14] = 8'd{{ cdfVal .LatencyConfig.CDF 14 }};
        cdf_table[15] = 8'd255;
    end

    reg [3:0] cdf_bucket;
    always @(*) begin
        cdf_bucket = 4'd15;
        if (prng_out[7:0] < cdf_table[0])       cdf_bucket = 4'd0;
        else if (prng_out[7:0] < cdf_table[1])  cdf_bucket = 4'd1;
        else if (prng_out[7:0] < cdf_table[2])  cdf_bucket = 4'd2;
        else if (prng_out[7:0] < cdf_table[3])  cdf_bucket = 4'd3;
        else if (prng_out[7:0] < cdf_table[4])  cdf_bucket = 4'd4;
        else if (prng_out[7:0] < cdf_table[5])  cdf_bucket = 4'd5;
        else if (prng_out[7:0] < cdf_table[6])  cdf_bucket = 4'd6;
        else if (prng_out[7:0] < cdf_table[7])  cdf_bucket = 4'd7;
        else if (prng_out[7:0] < cdf_table[8])  cdf_bucket = 4'd8;
        else if (prng_out[7:0] < cdf_table[9])  cdf_bucket = 4'd9;
        else if (prng_out[7:0] < cdf_table[10]) cdf_bucket = 4'd10;
        else if (prng_out[7:0] < cdf_table[11]) cdf_bucket = 4'd11;
        else if (prng_out[7:0] < cdf_table[12]) cdf_bucket = 4'd12;
        else if (prng_out[7:0] < cdf_table[13]) cdf_bucket = 4'd13;
        else if (prng_out[7:0] < cdf_table[14]) cdf_bucket = 4'd14;
    end

    // read latency computation
    wire [7:0] latency_range = MAX_LATENCY_CYCLES - MIN_LATENCY_CYCLES + 1;
    wire [7:0] cdf_latency = MIN_LATENCY_CYCLES + ((cdf_bucket * latency_range) >> 4);
    wire [7:0] base_jitter = is_sequential ? correlated_latency : cdf_latency;
    wire [7:0] thermal_adj = base_jitter + $signed(thermal_offset);
    wire [7:0] region_adj  = thermal_adj + region_adjust;
    wire [7:0] jittered    = (MIN_LATENCY_CYCLES + region_adj > MAX_LATENCY_CYCLES) ? MAX_LATENCY_CYCLES :
                             (MIN_LATENCY_CYCLES + region_adj < MIN_LATENCY_CYCLES) ? MIN_LATENCY_CYCLES :
                             MIN_LATENCY_CYCLES + region_adj;
    wire [7:0] computed_latency = ENABLE_JITTER ? jittered : AVG_LATENCY_CYCLES;

    // write latency computation
    wire [7:0] wr_range = WR_MAX_LATENCY - WR_MIN_LATENCY + 1;
    wire [7:0] wr_latency = WR_MIN_LATENCY + (prng_out[15:8] % wr_range);

    reg [7:0] wr_counter;
    reg [7:0] wr_target;
    reg       wr_pending;

    always @(*) begin
        req_ready = !request_pending;
    end

    // read latency FSM
    always @(posedge clk) begin
        if (rst) begin
            request_pending <= 1'b0;
            latency_counter <= 8'h0;
            target_latency  <= AVG_LATENCY_CYCLES;
            rsp_valid       <= 1'b0;
            stored_ctx      <= 88'h0;
            stored_data     <= 32'h0;
            prev_addr       <= 32'h0;
            prev_latency    <= AVG_LATENCY_CYCLES;
            prev_valid      <= 1'b0;
            timeout_counter <= 17'h0;
        end else begin
            if (rsp_valid && rsp_ready)
                rsp_valid <= 1'b0;

            if (request_pending) begin
                timeout_counter <= timeout_counter + 1'b1;

                if (timeout_expired) begin
                    // timeout: release with stored data (UR would need TLP layer changes)
                    rsp_valid       <= 1'b1;
                    rsp_ctx         <= stored_ctx;
                    rsp_data        <= 32'hFFFFFFFF;
                    request_pending <= 1'b0;
                    latency_counter <= 8'h0;
                    timeout_counter <= 17'h0;
                    prev_valid      <= 1'b0;
                end else if (latency_counter < target_latency) begin
                    latency_counter <= latency_counter + 8'h1;
                end else if (!rsp_valid || rsp_ready) begin
                    rsp_valid       <= 1'b1;
                    rsp_ctx         <= stored_ctx;
                    rsp_data        <= stored_data;
                    request_pending <= 1'b0;
                    latency_counter <= 8'h0;
                    timeout_counter <= 17'h0;
                    prev_latency    <= target_latency;
                    prev_valid      <= 1'b1;
                end
            end else if (req_valid && req_ready) begin
                request_pending <= 1'b1;
                stored_ctx      <= req_ctx;
                stored_data     <= req_data;
                prev_addr       <= req_addr;
                latency_counter <= 8'h0;
                timeout_counter <= 17'h0;
                target_latency  <= computed_latency;
            end
        end
    end

    // write acknowledge FSM - delays wr_ack to emulate MMIO write latency
    always @(posedge clk) begin
        if (rst) begin
            wr_pending <= 1'b0;
            wr_counter <= 8'h0;
            wr_target  <= WR_MIN_LATENCY;
            wr_ack     <= 1'b0;
        end else begin
            wr_ack <= 1'b0;

            if (wr_pending) begin
                if (wr_counter < wr_target) begin
                    wr_counter <= wr_counter + 8'h1;
                end else begin
                    wr_ack     <= 1'b1;
                    wr_pending <= 1'b0;
                    wr_counter <= 8'h0;
                end
            end else if (wr_valid) begin
                wr_pending <= 1'b1;
                wr_counter <= 8'h0;
                wr_target  <= wr_latency;
            end
        end
    end

endmodule
