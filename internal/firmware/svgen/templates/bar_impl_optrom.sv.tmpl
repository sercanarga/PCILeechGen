//
// Expansion ROM (BAR6) responder for {{ hex04 .DeviceIDs.VendorID }}:{{ hex04 .DeviceIDs.DeviceID }}
// Serves the donor's option ROM image from BRAM. Auto-generated by PCILeechGen.
// Reads return ROM bytes; writes are ignored (ROM is read-only).
//
`timescale 1ns / 1ps

module pcileech_bar_impl_optrom #(
    parameter ROM_SIZE = {{ .OptionROMSize }}
)(
    input               rst,
    input               clk,

    input [31:0]        wr_addr,
    input [31:0]        wr_data,
    input [3:0]         wr_be,
    input               wr_valid,

    input [87:0]        rd_req_ctx,
    input [31:0]        rd_req_addr,
    input               rd_req_valid,

    output reg [87:0]   rd_rsp_ctx,
    output reg [31:0]   rd_rsp_data,
    output reg          rd_rsp_valid
);

    localparam ROM_WORDS = (ROM_SIZE > 0) ? (ROM_SIZE / 4) : 512;
    reg [31:0] rom_mem [0:ROM_WORDS-1];
    wire [31:0] rom_addr_mask = ROM_SIZE - 1;
    wire [31:0] ra = rd_req_addr & rom_addr_mask;
    integer i;
    initial begin
        for (i = 0; i < ROM_WORDS; i = i + 1) rom_mem[i] = 32'h00000000;
        $readmemh("{{ .OptionROMHexFile }}", rom_mem);
    end

    reg [87:0] rd_req_ctx_d1;
    reg        rd_req_valid_d1;
    wire [31:0] doutb = rom_mem[ra[31:2]];

    always @(posedge clk) begin
        rd_req_ctx_d1   <= rd_req_ctx;
        rd_req_valid_d1 <= rd_req_valid;
        rd_rsp_ctx      <= rd_req_ctx_d1;
        rd_rsp_valid    <= rd_req_valid_d1;
        rd_rsp_data     <= doutb;
    end
    // writes ignored: expansion ROM is read-only
endmodule
