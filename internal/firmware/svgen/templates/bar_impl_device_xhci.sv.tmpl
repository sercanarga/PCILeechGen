{{ define "bar_impl_device_xhci" }}{{ if eq .DeviceClass "xhci" }}
    // xHCI HCRST auto-clear + R/S-HCH tracking.
    // USBCMD (0x20) and USBSTS (0x24) are IsFSMDriven — sole driver is this block.
    reg [3:0] hcrst_cnt;
    reg       hcrst_pending;

    // R/S -> HCH tracking: when driver sets R/S=1, HCH must clear.
    reg       rs_prev;

    always @(posedge clk) begin
        if (rst) begin
            hcrst_cnt      <= 4'h0;
            hcrst_pending  <= 1'b0;
            rs_prev        <= 1'b0;
            reg_0x00000020 <= 32'h00000001;  // USBCMD: R/S=1 (running)
            reg_0x00000024 <= 32'h00000000;  // USBSTS: HCH=0 (not halted)
        end else begin
            rs_prev <= reg_0x00000020[0]; // USBCMD.R/S

            // USBCMD byte-0 mask must include R/S (bit 0); dropping it breaks halt/run + HCRST sequencing.
            if (wr_valid && (wr_addr[31:0] & 32'hFFFFFFFC) == 32'h00000020 && !hcrst_pending) begin
                if (wr_be[0]) reg_0x00000020[7:0]   <= (reg_0x00000020[7:0]   & ~8'h0F) | (wr_data[7:0]   & 8'h0F);
                if (wr_be[1]) reg_0x00000020[15:8]  <= (reg_0x00000020[15:8]  & ~8'h2F) | (wr_data[15:8]  & 8'h2F);
            end

            // HCRST handling
            if (reg_0x00000020[1] && !hcrst_pending) begin
                hcrst_pending <= 1'b1;
                hcrst_cnt     <= 4'h0;
            end
            if (hcrst_pending) begin
                hcrst_cnt <= hcrst_cnt + 1'b1;
                if (hcrst_cnt >= 4'h4) begin
                    reg_0x00000020[1] <= 1'b0;    // clear HCRST
                    reg_0x00000024    <= 32'h0001; // USBSTS = HCH (halted after reset)
                    hcrst_pending     <= 1'b0;
                end
            end

            // R/S rising edge -> clear HCH (controller running)
            if (reg_0x00000020[0] && !rs_prev && !hcrst_pending) begin
                reg_0x00000024[0] <= 1'b0;  // USBSTS.HCH = 0
            end

            // R/S falling edge -> set HCH (controller halted)
            if (!reg_0x00000020[0] && rs_prev && !hcrst_pending) begin
                reg_0x00000024[0] <= 1'b1;  // USBSTS.HCH = 1
            end
        end
    end
{{ end }}
{{ end }}
