//
// HDA RIRB DMA Bridge
// Writes fake RIRB responses to system memory at the address programmed
// in RIRBLBASE/RIRBUBASE so hdaudio.sys can read codec responses.
//
// Without this, the BAR module writes responses to MMIO registers (0x70/0x78)
// that hdaudio.sys never reads — it expects responses in the DMA buffer.
//
// RIRB buffer entry format (8 bytes per entry, LE):
//   offset+0 [3:0]   = response type (1=VERB response, 2=unsolicited)
//   offset+0 [31:4]  = NID (Node ID)
//   offset+4 [31:0]  = response payload (28-bit codec data)
//

`timescale 1ns / 1ps

module pcileech_hda_rirb_dma(
    input               rst,
    input               clk,

    input [15:0]        pcie_id,        // our BDF, goes into requester ID

    // handshaking with BAR module
    input               dma_req_valid,  // pulse: BAR module has response ready
    input [31:0]        dma_req_lo,     // RIRB entry [31:0]  (type + NID)
    input [31:0]        dma_req_hi,     // RIRB entry [63:32] (response payload)
    input [7:0]         dma_req_wp,     // RIRBWP value BEFORE increment
    output reg          dma_req_ready,  // 1 = ready to accept new response

    // RIRB base address from BAR module (live register values)
    input [31:0]        rirb_lbase,
    input [31:0]        rirb_ubase,

    // completion output: pulse when DMA write is done
    output reg          dma_done,       // 1-cycle pulse: write completed

    // outgoing TLP stream — gets muxed with bar controller responses
    output reg [127:0]  tlp_tx_tdata,
    output reg [3:0]    tlp_tx_tkeepdw,
    output reg          tlp_tx_tvalid,
    output reg          tlp_tx_tlast,
    output reg [8:0]    tlp_tx_tuser,
    input               tlp_tx_tready       // backpressure from downstream
);

    localparam [3:0] D_IDLE       = 4'h0;
    localparam [3:0] D_WR_TLP1    = 4'h1;  // first beat: header (+ data0 for 32-bit)
    localparam [3:0] D_WR_TLP2    = 4'h2;  // data beat 1 (32-bit: payload, 64-bit: type+NID)
    localparam [3:0] D_WR_TLP3    = 4'h3;  // data beat 2 (64-bit only: payload)
    localparam [3:0] D_DONE       = 4'h4;

    reg [3:0]  dstate;
    reg [7:0]  d_tag;               // tags start at 0x80 to avoid host tag collision
    reg [31:0] d_resp_lo;           // latched response low (type + NID)
    reg [31:0] d_resp_hi;           // latched response high (payload)
    reg [31:0] d_addr_lo;           // computed target address [31:0]
    reg [31:0] d_addr_hi;           // latched target address [63:32]
    reg        d_is_64bit;          // latched: 64-bit address mode

    always @(posedge clk) begin
        if (rst) begin
            dstate          <= D_IDLE;
            dma_req_ready   <= 1'b1;
            dma_done        <= 1'b0;
            tlp_tx_tvalid   <= 1'b0;
            tlp_tx_tlast    <= 1'b0;
            d_tag           <= 8'h80;
            d_resp_lo       <= 32'h0;
            d_resp_hi       <= 32'h0;
            d_addr_lo       <= 32'h0;
            d_addr_hi       <= 32'h0;
            d_is_64bit      <= 1'b0;
        end else begin
            dma_done      <= 1'b0;
            // tvalid/tlast/tdata/tkeepdw/tuser are set per-state below.
            // Don't blanket-reset them — backpressure requires holding values.

            case (dstate)

                // ---- idle: accept new response from BAR module ---------------
                D_IDLE: begin
                    tlp_tx_tvalid <= 1'b0;
                    dma_req_ready <= 1'b1;

                    if (dma_req_valid) begin
                        // Latch all inputs so we're not dependent on live signals
                        // during the TLP emission sequence.
                        d_resp_lo   <= dma_req_lo;
                        d_resp_hi   <= dma_req_hi;
                        d_addr_lo   <= rirb_lbase + ({24'h0, dma_req_wp} * 8);
                        d_addr_hi   <= rirb_ubase;
                        d_is_64bit  <= |rirb_ubase;
                        d_tag       <= (d_tag >= 8'hFF) ? 8'h80 : d_tag + 1'b1;

                        dma_req_ready <= 1'b0;
                        dstate <= D_WR_TLP1;
                    end
                end

                // ---- first beat: header (64-bit) or header+data0 (32-bit) ----
                D_WR_TLP1: begin
                    // tvalid already asserted from combinational logic; hold until tready.
                    if (tlp_tx_tready) begin
                        dstate <= D_WR_TLP2;
                    end
                end

                // ---- data beat 1: type+NID (64-bit) or payload (32-bit) ------
                D_WR_TLP2: begin
                    if (tlp_tx_tready) begin
                        if (d_is_64bit) begin
                            dstate <= D_WR_TLP3;
                        end else begin
                            dstate <= D_DONE;
                        end
                    end
                end

                // ---- data beat 2: payload (64-bit only) ----------------------
                D_WR_TLP3: begin
                    if (tlp_tx_tready) begin
                        dstate <= D_DONE;
                    end
                end

                // ---- signal completion to BAR module -------------------------
                D_DONE: begin
                    dma_done        <= 1'b1;
                    dma_req_ready   <= 1'b1;
                    tlp_tx_tvalid   <= 1'b0;
                    tlp_tx_tlast    <= 1'b0;
                    dstate          <= D_IDLE;
                end

                default: begin
                    dstate <= D_IDLE;
                    tlp_tx_tvalid <= 1'b0;
                end
            endcase
        end
    end

    // Combinational TLP output: set tdata/tkeepdw/tlast/tuser/tvalid based on
    // current state. This ensures values are held correctly during backpressure
    // (tready=0) since the state doesn't advance until tready=1.
    always @(*) begin
        // Default: inactive
        tlp_tx_tdata    = 128'h0;
        tlp_tx_tkeepdw  = 4'b0000;
        tlp_tx_tlast    = 1'b0;
        tlp_tx_tuser    = 9'h0;
        tlp_tx_tvalid   = 1'b0;

        case (dstate)
            D_WR_TLP1: begin
                if (d_is_64bit) begin
                    // 64-bit MWr: 4DW header only (data comes in next beats)
                    // Fmt=011 (4DW with data), Type=00000 (MWr), Length=2 DW
                    // Last DW BE=0xF, First DW BE=0xF (all bytes valid in both DWs)
                    tlp_tx_tdata[31:0]   = {
                        3'b011, 5'b00000, 1'b0, 3'b000,
                        4'b0000, 1'b0, 1'b0, 2'b00, 4'hF, 4'hF, 10'h002
                    };
                    tlp_tx_tdata[63:32]  = {pcie_id, d_tag, 4'hF, 4'h7};
                    tlp_tx_tdata[95:64]  = d_addr_hi;
                    tlp_tx_tdata[127:96] = {d_addr_lo[31:2], 2'b00};
                    tlp_tx_tkeepdw = 4'b1111;
                    tlp_tx_tuser   = {8'h00, 1'b1};  // first=1
                end else begin
                    // 32-bit MWr: 3DW header + 1st data DW
                    // Fmt=010 (3DW with data), Type=00000 (MWr), Length=2 DW
                    // Last DW BE=0xF, First DW BE=0xF (all bytes valid in both DWs)
                    tlp_tx_tdata[31:0]   = {
                        3'b010, 5'b00000, 1'b0, 3'b000,
                        4'b0000, 1'b0, 1'b0, 2'b00, 4'hF, 4'hF, 10'h002
                    };
                    tlp_tx_tdata[63:32]  = {pcie_id, d_tag, 4'hF, 4'h7};
                    tlp_tx_tdata[95:64]  = {d_addr_lo[31:2], 2'b00};
                    tlp_tx_tdata[127:96] = d_resp_lo;
                    tlp_tx_tkeepdw = 4'b1111;
                    tlp_tx_tuser   = {8'h00, 1'b1};  // first=1
                end
                tlp_tx_tvalid = 1'b1;
            end

            D_WR_TLP2: begin
                if (d_is_64bit) begin
                    // 64-bit: first data DW (type + NID)
                    tlp_tx_tdata[31:0]   = d_resp_lo;
                    tlp_tx_tkeepdw = 4'b0001;
                    tlp_tx_tuser   = 9'h0;
                end else begin
                    // 32-bit: second data DW (payload), last beat
                    tlp_tx_tdata[31:0]   = d_resp_hi;
                    tlp_tx_tkeepdw = 4'b0001;
                    tlp_tx_tlast   = 1'b1;
                    tlp_tx_tuser   = 9'h0;
                end
                tlp_tx_tvalid = 1'b1;
            end

            D_WR_TLP3: begin
                // 64-bit: second data DW (payload), last beat
                tlp_tx_tdata[31:0]   = d_resp_hi;
                tlp_tx_tkeepdw = 4'b0001;
                tlp_tx_tlast   = 1'b1;
                tlp_tx_tuser   = 9'h0;
                tlp_tx_tvalid = 1'b1;
            end

            default: begin
                // IDLE, DONE: no output
            end
        endcase
    end

endmodule
