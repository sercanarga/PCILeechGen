//
// HDA MSI Interrupt Generator
//
// Generates a multi-cycle intr_req pulse when msi_trigger fires.
// The pulse is OR'd into the FPGA's
// cfg_interrupt signal by the cfg module, which triggers an MSI TLP from
// the PCIe IP core.
//
// Without this, the hdaudio.sys driver polls RIRBWP endlessly and eventually
// times out with Code 10. MSI is the primary interrupt mechanism expected by
// the Windows HDA driver stack.
//
// Signal routing: the BAR module exposes RIRBINTSTS.INTFL via msi_trigger;
// this module produces an intr_req pulse that the cfg module routes to
// cfg_interrupt for MSI generation.
//

`timescale 1ns / 1ps

module pcileech_hda_msi(
    input               rst,
    input               clk,
    input               crst_falling,

    input [15:0]        pcie_id,        // our BDF

    // Trigger: 1-cycle pulse when INTFL transitions 0->1
    input               msi_trigger,

    // RIRBINTSTS live value (for edge detection)
    input [31:0]        rirbintsts,

    // Multi-cycle interrupt request pulse — routed to cfg_interrupt
    // by the cfg module (pcileech_pcie_cfg_a7). The pulse is held for
    // at least 2 cycles so the cfg latch reliably captures it.
    output              intr_req
);

    reg intr_req_reg;
    reg intr_req_hold;

    // Produce a 2-cycle minimum intr_req pulse on msi_trigger.
    // msi_trigger comes from BAR module with GIE+CIE gating already applied.
    // The cfg module routes intr_req to cfg_interrupt for MSI TLP generation.
    // crst_falling suppresses stray interrupts during HDA bus reset.
    always @(posedge clk) begin
        if (rst) begin
            intr_req_reg  <= 1'b0;
            intr_req_hold <= 1'b0;
        end else if (crst_falling) begin
            intr_req_reg  <= 1'b0;
            intr_req_hold <= 1'b0;
        end else begin
            if (msi_trigger) begin
                intr_req_reg  <= 1'b1;
                intr_req_hold <= 1'b1;
            end else if (intr_req_hold) begin
                intr_req_reg  <= 1'b0;
                intr_req_hold <= 1'b0;
            end else begin
                intr_req_reg  <= 1'b0;
            end
        end
    end

    assign intr_req = intr_req_reg;

endmodule
