//
// HDA MSI Interrupt Generator
//
// Generates a single-cycle intr_req pulse when RIRBINTSTS.INTFL transitions
// from 0 to 1 or when msi_trigger fires. The pulse is OR'd into the FPGA's
// cfg_interrupt signal by the cfg module, which triggers an MSI TLP from
// the PCIe IP core.
//
// Without this, the hdaudio.sys driver polls RIRBWP endlessly and eventually
// times out with Code 10. MSI is the primary interrupt mechanism expected by
// the Windows HDA driver stack.
//
// Signal routing: the BAR module exposes RIRBINTSTS.INTFL via msi_trigger;
// this module produces an intr_req pulse that the cfg module routes to
// cfg_interrupt for MSI generation.
//

`timescale 1ns / 1ps

module pcileech_hda_msi(
    input               rst,
    input               clk,

    input [15:0]        pcie_id,        // our BDF

    // Trigger: 1-cycle pulse when INTFL transitions 0->1
    input               msi_trigger,

    // RIRBINTSTS live value (for edge detection)
    input [31:0]        rirbintsts,

    // Single-cycle interrupt request pulse — routed to cfg_interrupt
    // by the cfg module (pcileech_pcie_cfg_a7).
    output              intr_req
);

    reg       msi_trigger_latched;
    reg       intfl_prev;
    reg       intr_req_reg;

    // Edge detection: INTFL 0->1 transition
    always @(posedge clk) begin
        if (rst) begin
            intfl_prev          <= 1'b0;
            msi_trigger_latched <= 1'b0;
        end else begin
            // Latch the rising edge
            if (rirbintsts[0] && !intfl_prev) begin
                msi_trigger_latched <= 1'b1;
            end

            // Clear when we produce the pulse
            if (intr_req_reg) begin
                msi_trigger_latched <= 1'b0;
            end

            intfl_prev <= rirbintsts[0];
        end
    end

    // Produce a single-cycle intr_req pulse on msi_trigger or latched edge.
    // The cfg module routes this to cfg_interrupt for MSI TLP generation.
    always @(posedge clk) begin
        if (rst) begin
            intr_req_reg <= 1'b0;
        end else if (msi_trigger || msi_trigger_latched) begin
            intr_req_reg <= 1'b1;
        end else begin
            intr_req_reg <= 1'b0;
        end
    end

    assign intr_req = intr_req_reg;

endmodule
