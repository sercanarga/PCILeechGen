    wire ur_request_ready;
    wire ur_request_pending = tlps_in.tvalid && in_is_bar && norm_request_present &&
                              norm_ur_required && norm_non_posted_request;
    reg [29:0] ur_request_fifo[0:255];
    reg [7:0] ur_request_read_ptr;
    reg [7:0] ur_request_write_ptr;
    reg [8:0] ur_request_count;
    wire ur_request_dequeue = (ur_request_count != 9'd0) && ur_request_ready;
    wire ur_request_enqueue = ur_request_pending &&
                              ((ur_request_count != 9'd256) || ur_request_dequeue);

