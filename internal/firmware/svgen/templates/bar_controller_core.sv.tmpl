    reg cpl_grant_ur;
    reg cpl_rr_ur;
    wire cpl_select_ur = cpl_grant_active ? cpl_grant_ur :
                         (tlps_ur.tvalid && tlps_rdeng.tvalid) ? cpl_rr_ur :
                         tlps_ur.tvalid;
    wire cpl_selected_valid = cpl_select_ur ? tlps_ur.tvalid : tlps_rdeng.tvalid;
    wire cpl_selected_last = cpl_select_ur ? tlps_ur.tlast : tlps_rdeng.tlast;

    assign tlps_cpl.tdata    = cpl_select_ur ? tlps_ur.tdata    : tlps_rdeng.tdata;
    assign tlps_cpl.tkeepdw  = cpl_select_ur ? tlps_ur.tkeepdw  : tlps_rdeng.tkeepdw;
    assign tlps_cpl.tvalid   = cpl_selected_valid;
    assign tlps_cpl.tlast    = cpl_selected_last;
    assign tlps_cpl.tuser    = cpl_select_ur ? tlps_ur.tuser    : tlps_rdeng.tuser;
    assign tlps_cpl.has_data = cpl_select_ur ? tlps_ur.has_data : tlps_rdeng.has_data;
    assign tlps_ur.tready    = tlps_cpl.tready && cpl_select_ur;
    assign tlps_rdeng.tready = tlps_cpl.tready && !cpl_select_ur;

    always @(posedge clk) begin
        if (device_reset) begin
            cpl_grant_active <= 1'b0;
            cpl_grant_ur     <= 1'b0;
            cpl_rr_ur        <= 1'b0;
        end else if (cpl_grant_active) begin
            if (cpl_selected_valid && tlps_cpl.tready && cpl_selected_last) begin
                cpl_grant_active <= 1'b0;
                cpl_rr_ur        <= !cpl_grant_ur;
            end
        end else if (cpl_selected_valid) begin
            if (tlps_cpl.tready && cpl_selected_last) begin
                cpl_rr_ur <= !cpl_select_ur;
            end else begin
                cpl_grant_active <= 1'b1;
                cpl_grant_ur     <= cpl_select_ur;
            end
        end
    end

    wire        wrengine_ready;

    pcileech_tlps128_bar_wrengine i_pcileech_tlps128_bar_wrengine(
