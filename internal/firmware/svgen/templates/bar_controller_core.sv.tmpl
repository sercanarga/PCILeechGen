        if (device_reset) begin
            ur_request_read_ptr  <= 8'd0;
            ur_request_write_ptr <= 8'd0;
            ur_request_count     <= 9'd0;
        end else begin
            if (ur_request_enqueue) begin
                ur_request_fifo[ur_request_write_ptr] <= {
                    norm_requester_id,
                    norm_tag,
                    norm_traffic_class,
                    norm_attributes
                };
                ur_request_write_ptr <= ur_request_write_ptr + 1'b1;
            end
            if (ur_request_dequeue)
                ur_request_read_ptr <= ur_request_read_ptr + 1'b1;
            case ({ur_request_enqueue, ur_request_dequeue})
                2'b10: ur_request_count <= ur_request_count + 1'b1;
                2'b01: ur_request_count <= ur_request_count - 1'b1;
                default: ur_request_count <= ur_request_count;
            endcase
        end
    end

    pcileech_tlp_ur_completer i_tlp_ur_completer(
        .rst           ( device_reset                                 ),
